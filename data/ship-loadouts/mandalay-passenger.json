  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A medium-pad converted-liner fit: economy seating plus one premium first-class cabin, a bi-weave shield for safety and a max-range SCO FSD. Initial is buy-only; A-rated is the working baseline; Engineered stretches range and trims mass. There is no Saud Kruger comfort bonus here, so the case is reach and cheap medium-pad access, not per-seat pay.",
          "callout": {
            "label": "An explorer pressed into liner work",
            "text": "The Mandalay carries fewer seats than any dedicated liner and earns no comfort bonus, so it is a volume-economy hauler, not a VIP earner. What it brings is range: the SCO FSD keeps distant scenic drop-offs one hop closer than the medium field, and the light hull lands at outposts the large liners cannot reach. Size-1 slots take no cabins, so headcount caps around 66 economy."
          },
          "notes": {
            "TinyHardpoint1": "0A shield booster; Heavy Duty multiplies the size-4 bi-weave's raw MJ for cheap passenger safety.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat when interdicted.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff breaks gimbal locks to buy an escape window.",
            "PowerPlant": "Low Emissions keeps the cool-running SCO hull cold with ample power for cabins and shield; Thermal Spread bleeds the last heat.",
            "MainEngines": "A-rated thrusters with Dirty Drives for the speed to shake an interdiction; Drag Drives sharpens boost.",
            "FrameShiftDrive": "The SCO drive is the whole case for this hull — Increased Range at G5 with Mass Manager keeps distant drop-offs one hop closer than the medium field.",
            "LifeSupport": "A-rated for endurance; Lightweight trims mass to stretch laden jump range. Life support has no experimental effect.",
            "PowerDistributor": "Engine Focused biases the class-5 distributor toward boosting away from danger; Cluster Capacitors deepens the reservoir.",
            "Radar": "Drop to D and go Lightweight — a liner needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock class-C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Economy Cabin 6 (32 seats) carries the volume — the single largest berth block on the hull.",
            "Slot02_Size5": "Economy Cabin 5 (16 seats) — bulk economy capacity for group transport fares.",
            "Slot03_Size4": "First-Class Cabin 4 (3 seats) is the one premium VIP cabin; first-class is the largest grade this size-4 slot accepts, and without a liner bonus it earns less here than on a Saud Kruger hull.",
            "Slot04_Size4": "Size-4 bi-weave is the smallest that deploys over the 230t hull; Reinforced maximises MJ and Fast Charge speeds the recharge for passenger safety.",
            "Slot05_Size3": "Economy Cabin 3 (4 seats) tops up headcount.",
            "Slot06_Size3": "Second Economy Cabin 3 (4 seats) for more bulk economy fares.",
            "Slot07_Size2": "Economy Cabin 2 (2 seats); size-2 is the smallest slot that takes a cabin at all.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps scenic bodies for sightseeing tours.",
            "Slot09_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot10_Size1": "Light module reinforcement spreads penetrating-hit damage across the internals; not engineerable. Size-1 slots take no passenger cabins."
          },
