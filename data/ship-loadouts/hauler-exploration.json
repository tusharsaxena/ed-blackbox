  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A minimalist featherweight explorer fit — the barest essentials on the lightest hull in the game. Initial is buy-only; A-rated is the expedition baseline; Engineered squeezes maximum range from minimal mass.",
          "callout": {
            "label": "Keep it light, keep it simple",
            "text": "The Hauler's range comes from its 14-tonne mass — don't load it down. A class-3 scoop, Guardian booster, scanner, one AFMU, a single-seat SRV bay and a light landing shield is all it fits, and all it needs. There's no room for redundancy; plan short hops and frequent resupply."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "D-rate to save mass; Low Emissions runs the plant cool so you can sit deep in a star's corona and scoop.",
            "MainEngines": "D-rated thrusters are ample for a 14t hull; Clean Drive Tuning trims heat and power, and Stripped Down sheds mass for range.",
            "FrameShiftDrive": "A-rate this FIRST and max Increased Range with Mass Manager — on 14 tonnes the range is the whole point of the build.",
            "LifeSupport": "D-rate and Lightweight to save every kilo; life support has no experimental effect.",
            "PowerDistributor": "D-rate is enough with no guns to feed; Engine Focused keeps the boost charging for fast scooping turns.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-3 (8t) tank; plan short jump chains and scoop often. Fuel capacity cannot be engineered.",
            "Slot01_Size3": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size3": "Guardian FSD Booster (size 3, the biggest flat bonus that fits) stacks straight onto the engineered drive; Guardian tech carries no blueprint.",
            "Slot03_Size2": "SRV Hangar (the lighter 2G) in the only size-2 slot opens surface prospecting and exobiology; hangars are not engineerable.",
            "Slot04_Size1": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot06_Size1": "Enhanced Low Power keeps the shield light and low-draw for the long haul."
          },
