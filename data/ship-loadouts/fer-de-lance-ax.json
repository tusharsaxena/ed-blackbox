  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A fast, cramped anti-Xeno fit: a Guardian Gauss pair and Enhanced AX/Guardian support on the four medium mounts, a large Enhanced AX Multi-Cannon under-filling the wasted huge mount, and Guardian reinforcement squeezed into six small optionals. Initial is buy-only cores; A-Rated adds the AX kit; Engineered hardens mobility, heat and shield. AX/Guardian weapons take no engineering — the gains are in flying and the ship modules.",
          "callout": {
            "label": "Dodge, don't tank",
            "text": "The Fer-de-Lance brings four medium mounts for Gauss and best-in-class agility, but the smallest internals in the AX field — six optionals, no military slots, thin armour. It survives by physically dodging Interceptor lightning, not by absorbing it. Fire Gauss in short bursts on a 250-tonne hull that runs hot, and keep two heat sinks ready."
          },
          "notes": {
            "HugeHardpoint1": "The huge mount is wasted on AX — no huge AX weapon exists, so a large Enhanced AX Multi-Cannon under-fills it for gimballed chip damage and Scout clearing. Not engineerable.",
            "MediumHardpoint1": "Primary heart-cracker — Guardian Gauss is the best AX penetrator and fits the medium mount exactly. Fire in short bursts to manage heat; not engineerable.",
            "MediumHardpoint2": "Second Gauss completes the pair; the four medium mounts give it real Gauss capacity, but the small hull's heat ceiling caps how long the pair can run. No blueprint.",
            "MediumHardpoint3": "Enhanced AX Multi-Cannon, gimballed for ammo-efficient chip damage and Scout swarms. Not engineerable.",
            "MediumHardpoint4": "Guardian Shard Cannon adds close-range heart burst; fixed for full damage. Not engineerable.",
            "TinyHardpoint1": "Xeno Scanner reveals Interceptor hearts and subsystems — essential for target priority; no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running on a hull that runs hot.",
            "TinyHardpoint4": "Second Heat Sink Launcher — a 250t hull with heavy Gauss heat wants two sinks. Ammo Capacity adds charges.",
            "TinyHardpoint5": "Shield Booster grows the bi-weave; Thermal Resistant tilts it toward Thargoid thermal damage.",
            "TinyHardpoint6": "Second Thermal-Resistant booster — the FDL's heavy utility count is its one defensive luxury.",
            "PowerPlant": "A-rate first — Gauss and Guardian guns are power-hungry; Overcharged adds headroom and Thermal Spread bleeds the extra heat this small hull struggles to shed.",
            "MainEngines": "A-rated + Dirty Drives is the whole case: out-turn and dodge Thargoid lightning the heavier AX hulls must eat.",
            "FrameShiftDrive": "A-rated; Increased Range + Mass Manager stretch the short size-4 range — the FDL still needs a carrier lift to distant Maelstroms.",
            "LifeSupport": "A-rated for a long oxygen timer after a canopy breach; Lightweight trims mass; no experimental effect.",
            "PowerDistributor": "Charge Enhanced + Super Conduits feed the Gauss capacitor so the pair keeps firing.",
            "Radar": "D-rated and Lightweight — AX needs no sensor range, so save the mass for speed.",
            "FuelTank": "Stock size-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Bi-Weave in the largest slot — the FDL's high base shield is its main defence; Thermal Resistant + Fast Charge suit sustained Thargoid thermal damage.",
            "Slot02_Size4": "Guardian Hull Reinforcement — caustic-resistant armour, the FDL's hardening with no military slots; not engineerable.",
            "Slot03_Size4": "AFMU repairs modules struck by Thargoid lightning between passes; Shielded hardens it. The caustic-sink launcher covers caustic clearing — no room for a decon limpet.",
            "Slot04_Size2": "Guardian Module Reinforcement spreads penetrating-hit damage across internals; caustic-resistant, no blueprint.",
            "Slot05_Size1": "A small Guardian HRP tops up effective armour where the tiny slot allows; not engineerable.",
            "Slot06_Size1": "Guardian Module Reinforcement in the last optional — the cramped internals are the FDL's hard AX limit; no blueprint."
          },
          "engineeringPlan": [
