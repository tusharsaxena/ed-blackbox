  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A self-sufficient survey fit that fills all nine optionals. Initial is buy-only — strip the guns, A-rate the FSD and fit a class-5 scoop first; A-Rated is the expedition baseline; Engineered strips mass from the cores for maximum range while keeping the full survey kit aboard. Cores run D-rated (FSD excepted) to claw range out of a heavy small hull.",
          "callout": {
            "label": "Capacity over distance",
            "text": "The nine optionals carry a class-5 scoop, a two-SRV bay, two AFMUs, a landing shield, a scanner and spare fuel all at once — self-sufficiency a Diamondback can't match. The price is range: this fit jumps ~50 LY, not 68+."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "One shield booster toughens the light landing shield for hard surface set-downs; Heavy Duty multiplies its raw MJ.",
            "PowerPlant": "D-rate to save mass; Low Emissions runs it cold so scooping and close orbits don't cook the ship, Thermal Spread bleeds more heat.",
            "MainEngines": "D-rated thrusters save mass; Clean Drive Tuning keeps them cool and efficient, Double Braced stiffens them for hard landings.",
            "FrameShiftDrive": "The one core A-rated — jump range is everything; Increased Range G5 plus Mass Manager is the foundation of the ~50 LY range.",
            "LifeSupport": "D-rate and go Lightweight; on a heavy small hull every kilo shed off life support buys real range. No experimental effect.",
            "PowerDistributor": "D-rated and Engine-Focused so boost recharges fast for surface hops; weapons-grade charge is wasted on an unarmed explorer.",
            "Radar": "D-rate and go Lightweight; survey work needs no sensor range, so save the mass. No experimental effect.",
            "FuelTank": "Stock C-rated tank; capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size4": "Guardian FSD Booster — the largest flat jump-range bonus available; not engineerable (Guardian tech).",
            "Slot03_Size4": "Size-4 SRV bay carries two buggies for surface science; the G-rated bay is lighter than the H. Hangars carry no blueprint.",
            "Slot04_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size3": "Light bi-weave for landing bumps only; Enhanced Low Power plus Stripped Down keep its mass and draw minimal for range.",
            "Slot06_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size3": "Extra C-rated fuel tank extends the range between scoopable stars; capacity is fixed, no blueprint.",
            "Slot08_Size2": "A size-1 repair limpet controller (under-fills the size-2 slot) for hull repair; carry limpets to use it. Controllers have no blueprint.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
