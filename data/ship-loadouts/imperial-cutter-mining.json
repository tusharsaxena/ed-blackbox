  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete mining fit for laser and core work that keeps a gun and the game's best shield for self-defence. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on shield, mobility and heat — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "Tools, limpets, an unbreakable shield",
            "text": "A complete capital miner: lasers and a seismic launcher for both mining styles, a Pulse Wave Analyser to find rocks, a refinery and several big collector controllers to work fast, and — the Cutter's signature — a prismatic shield, a full booster suite and a gun so the pirates that swarm a laden capital miner achieve nothing. Ore fills everything else."
          },
          "notes": {
            "HugeHardpoint1": "Huge multi-cannon for self-defence; Overcharged with Corrosive Shell strips a pirate's armour resistance so the laden Cutter is never robbed.",
            "LargeHardpoint1": "Primary mining laser — a medium (size-2) is the largest the game makes, so it under-fills this large mount; mining lasers carry no blueprint.",
            "LargeHardpoint2": "Seismic Charge Launcher for cracking high-value cores; a medium-only tool in a large slot, left stock.",
            "MediumHardpoint1": "Sub-surface Displacement Missile pops surface deposits on cracked cores; mining tool, unengineered.",
            "MediumHardpoint2": "Abrasion Blaster shears surface chunks off rocks; a small-only tool, left stock.",
            "MediumHardpoint3": "Second mining laser doubles laser-mining yield; no blueprint exists for it.",
            "MediumHardpoint4": "Medium multi-cannon backs up the huge gun; Overcharged with Auto Loader keeps it firing through a pirate fight.",
            "TinyHardpoint1": "Pulse Wave Analyser highlights mineral-rich rocks across the ring; a scanner with no blueprint.",
            "TinyHardpoint2": "First of six Heavy-Duty shield boosters — the cheapest large multiplier on the prismatic's raw MJ.",
            "TinyHardpoint3": "Stacked Heavy-Duty booster; Super Capacitors adds more raw shield.",
            "TinyHardpoint4": "Third Heavy-Duty booster building the wall the laden Cutter hides behind.",
            "TinyHardpoint5": "Fourth Heavy-Duty booster; diminishing returns set in but still pays at capital scale.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Fifth Heavy-Duty booster continuing the shield stack.",
            "TinyHardpoint8": "Sixth Heavy-Duty booster rounds out the strongest shield in the game.",
            "PowerPlant": "Size-8 plant runs lasers, limpets, the prismatic and a gun together; Low Emissions keeps heat low through long mining sessions, Thermal Spread bleeds the rest.",
            "MainEngines": "A-rated size-8 thrusters move a 1,100t hull between rocks; Dirty Drives restore the agility a laden Cutter sorely lacks.",
            "FrameShiftDrive": "A-rated FSD with Increased Range and Mass Manager to reach distant hotspots and haul ore home.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate so lasers and limpets never brown out; Engine Focused feeds the boost, Cluster Capacitors deepens the reservoirs.",
            "Radar": "Drop to D and go Lightweight; mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Military02": "Heavy-Duty hull reinforcement backstops the shield with effective armour; Deep Plating adds more.",
            "Slot01_Size8": "Prismatic Shield Generator — the Cutter's signature; Reinforced maximises its raw MJ and Hi-Cap adds capacity for the unrobable laden miner.",
            "Slot02_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot05_Size6": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot08_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot09_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Prismatic Shield Generator",
              "size": 8,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
