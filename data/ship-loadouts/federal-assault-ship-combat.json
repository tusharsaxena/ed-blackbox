  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "An aggressive armour-tank brawler that uses both military slots and the optional internals for reinforcement, with a bi-weave shield run purely as a regenerating buffer. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern weighted to speed and hull.",
          "callout": {
            "label": "Armour-tank with a bi-weave buffer",
            "text": "The FAS's low base shield means it tanks on armour — fill both military slots and the optionals with Heavy-Duty reinforcement, and run a bi-weave shield purely as a regenerating buffer. Speed and toughness are the strategy: close fast, brawl, disengage."
          },
          "notes": {
            "LargeHardpoint1": "Primary huge-of-its-class mount; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a gimballed beam once A-rated; Thermal Vent runs it cold for shield-stripping.",
            "MediumHardpoint2": "Medium multi-cannon adds sustained kinetic DPS; Auto Loader keeps it topped up.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ buffer.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength on this hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers two large guns, a shield, cells and utilities; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate + Dirty Drives first — speed and agility are the FAS's whole identity.",
            "FrameShiftDrive": "A-rated to reach fights and Federal-rank turn-ins; only G3 range — a brawler doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate early — two large guns plus boost drain the class-6 distributor fast; Charge Enhanced restores WEP.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the first military slot is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size5": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Fast Charge speeds the buffer's recovery.",
            "Slot02_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size4": "More Heavy-Duty hull where the size-4 slot allows — armour stacks linearly.",
            "Slot04_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size2": "Module Reinforcement protects the cores that keep you flying; not engineerable.",
            "Slot06_Size2": "More Heavy-Duty hull in the size-2 slot for the armour tank.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
