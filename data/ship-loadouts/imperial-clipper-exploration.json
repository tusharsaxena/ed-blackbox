  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A travel-light exploration fit. Initial is buy-only; A-Rated is the expedition baseline; Engineered strips mass to push the class-5 drive as far as it will go. Plans and costs follow in the sections below.",
          "callout": {
            "label": "Light is right",
            "text": "The class-5 drive rewards a stripped hull: a class-7 scoop and class-5 Guardian booster are the range workhorses, while D-rated lightweight cores keep mass down. Don't over-fit — every extra tonne costs you light-years on this heavy 400 t frame."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "One light booster cheaply multiplies the landing bi-weave's raw MJ; Heavy Duty + Super Capacitors is the biggest gain per tonne.",
            "PowerPlant": "6D keeps mass down — with no guns to feed, output is not the limit; Low Emissions cuts heat and draw, Thermal Spread bleeds more while scooping.",
            "MainEngines": "6D thrusters; Clean Drive Tuning runs cool and efficient, Drag Drives adds boost speed to climb the Clipper out of gravity wells.",
            "FrameShiftDrive": "The whole build — a 5A SCO drive for maximum range and fast in-system travel; Increased Range + Mass Manager is the single biggest lever on this heavy hull's reach.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "6D is plenty without weapons; Engine Focused (G3) gives engine-capacitor headroom for repeated boosts on landing approaches — only a partial roll is needed.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass on this heavy frame.",
            "FuelTank": "Stock 4C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size6": "The Guardian FSD Booster — a flat ~+10 LY jump-range gain unlocked at a Guardian site, not bought; the single largest range bolt-on and not engineerable.",
            "Slot03_Size4": "A size-4 SRV hangar (2 bays) for exobiology, surface prospecting and Guardian-site runs; carries no blueprint.",
            "Slot04_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size3": "A light bi-weave gives a fast-regenerating buffer for landings and accidental scrapes; Enhanced Low Power + Lo-Draw keeps its draw and mass minimal (bi-weaves are C-rated only).",
            "Slot06_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size2": "Extra fuel tank to stretch the gap between scoopable stars on sparse routes; fuel tanks are not engineerable.",
            "Slot08_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
