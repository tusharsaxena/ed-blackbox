  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defensible large-pad bulk fit: keep a bi-weave shield, a six-booster stack and two deterrent multi-cannon turrets, then fill every remaining optional with cargo. Initial is cheapest buy-only with a shield from day one; A-rated is the trade baseline; Engineered maximises protected cargo and laden range on a 1,200 t hull that simply refuses to die.",
          "callout": {
            "label": "Tank the interdiction, keep the cargo",
            "text": "The Type-10's trade case is survivability, not tonnage — game-highest armour, eight utilities and two military slots mean it tanks or fights off any pirate a Type-9 would have to run from. It still carries less than a Type-9 for more money, so fly it when you want cargo that cannot be robbed, not the biggest hold per credit."
          },
          "notes": {
            "LargeHardpoint1": "Lead large multi-cannon turret as a deterrent; Overcharged for damage and Corrosive Shell so a single gun still bites through armour.",
            "LargeHardpoint2": "Second large MC turret; Auto Loader removes reloads so the deterrent keeps tracking while you focus on the wake.",
            "TinyHardpoint1": "First Heavy-Duty shield booster; multiplies the bi-weave's raw MJ to protect the hold.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays over the cargo.",
            "TinyHardpoint4": "Fourth Heavy-Duty booster continues the protective shield stack.",
            "TinyHardpoint5": "Fifth Heavy-Duty booster; the Type-10's eight utilities let it out-stack any dedicated freighter.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and low-signature approaches.",
            "TinyHardpoint8": "Sixth Heavy-Duty booster completes the shield stack across the utility suite.",
            "PowerPlant": "Low Emissions keeps the plant cool and the signature low on contested routes; Thermal Spread bleeds the remaining heat.",
            "MainEngines": "A-rated + Dirty Drives recover the barest mobility a 1,200 t hull allows when laden.",
            "FrameShiftDrive": "A-rated G5 Increased Range with Mass Manager is the only lever against a poor laden jump; even so the huge hull keeps range short.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "Engine Focused sustains boost to break interdictions; Super Conduits enlarges the engine capacitor.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass for cargo and range.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Military02": "Heavy-Duty hull reinforcement in the military slot; the cheapest large multiplier on the Type-10's already game-leading armour.",
            "Slot01_Size8": "Bi-weave regenerates fast under fire — the right shield for surviving a hit and holding; Reinforced maximises the MJ buffer and Hi-Cap adds more.",
            "Slot02_Size7": "Primary cargo rack — the size-7 slot carries the bulk of the hold. Cargo racks aren't engineerable.",
            "Slot03_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot07_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot08_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data on the side."
          },
          "engineeringPlan": [
