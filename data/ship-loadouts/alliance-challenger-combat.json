  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A stand-and-fight tank build using all three military slots and deep shield sustain. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern weighted to durability.",
          "callout": {
            "label": "Tank on two layers",
            "text": "The Challenger's best-in-class shields plus three military slots let it tank on both shield and hull at once. Run a strong shield generator with cell banks and Heavy-Duty reinforcement — few mediums can do both this well."
          },
          "notes": {
            "LargeHardpoint1": "The one large mount; gimballed multi-cannon Overcharged, and the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a gimballed beam once A-rated; Thermal Vent vents heat so it strips shields cold.",
            "MediumHardpoint2": "Overcharged multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint3": "Second Overcharged multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "SmallHardpoint1": "Buy a cheap pulse, swap to a beam once A-rated; Thermal-Vent beam adds heat-free shield work.",
            "SmallHardpoint2": "Left empty on the buy-only fit; add an Efficient pulse once the hull is paid off, Phasing Sequence to chip through shields.",
            "SmallHardpoint3": "Second Efficient pulse for chip damage; Phasing Sequence bleeds through shields.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the generator's raw MJ, Super Capacitors adds more.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers seven guns, a big shield and cell banks; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover what mobility the heavy hull allows; Drag Drives sharpens the boost.",
            "FrameShiftDrive": "A-rated to reach fights and turn-ins; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — seven guns plus shield-cell draw drain the class-6 distributor under sustained fire.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour; Deep Plating adds raw HP.",
            "Military02": "Second Heavy-Duty HRP fills the next military slot — armour stacks linearly.",
            "Military03": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size6": "The largest shield the class-6 bay allows; Reinforced maximises its MJ and Hi-Cap adds more — the first tank layer.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size3": "More Heavy-Duty hull reinforcement for the second tank layer.",
            "Slot04_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size2": "Module Reinforcement protects the cores; not engineerable.",
            "Slot06_Size2": "More Heavy-Duty hull where the slot allows.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 6,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 6,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Multi-Cannons",
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Corrosive Shell (one) / Auto Loader (rest)",
              "engineer": "Tod McQuinn"
            },
            {
              "module": "Beam & Pulse Lasers",
              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Thermal Vent (beams) / Phasing Sequence (pulses)",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Power Distributor",
              "size": 6,
              "grade": "G5",
              "blueprint": "Charge Enhanced",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Shield Generator",
              "size": 6,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Hull Reinforcement",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Deep Plating",
              "engineer": "Selene Jean"
            },
            {
