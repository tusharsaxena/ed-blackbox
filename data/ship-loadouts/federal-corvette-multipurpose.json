  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit — the two huge guns kept, a capital shield, deep reinforcement and real cargo room, ready to re-tune for any job. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it a fortress that hauls.",
          "callout": {
            "label": "Built to re-tune",
            "text": "This is one balanced configuration. The Corvette's all-rounder trick is the module swap: keep the two huge guns and the tank, then trade the optionals between cargo racks (hauling), a mining suite and limpets (mining), or a fuel scoop and SRV (planetary work). Store role sets at your home base and switch as the week demands — just don't expect explorer range."
          },
          "notes": {
            "HugeHardpoint1": "Primary huge mount; the single Corrosive Shell strips armour resistance for the whole battery.",
            "HugeHardpoint2": "Second huge mount; Auto Loader removes reloads so it keeps firing through a long fight.",
            "LargeHardpoint1": "Gimballed beam for shield-stripping; Thermal Vent runs it cold so heat never forces a let-up.",
            "MediumHardpoint1": "Fill-in multi-cannon; Auto Loader keeps its DPS uninterrupted across role swaps.",
            "MediumHardpoint2": "Pulse laser for sustained, ammo-free pressure; Thermal Vent keeps the hull cool — swap to a mining laser when the week turns to ore.",
            "SmallHardpoint1": "Small multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Small pulse; Phasing Sequence leaks damage through shields — cheap, flexible utility fire.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint7": "Fourth Heavy-Duty booster rounds out the shield stack.",
            "TinyHardpoint8": "Fifth Heavy-Duty booster — the last utility goes to the tank that carries every role.",
            "PowerPlant": "Powers eight guns, a big shield and cells across roles; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives keep the capital agility that makes a 900t hull manageable loaded or in a fight.",
            "FrameShiftDrive": "A-rated, Increased Range G5 + Mass Manager — push range to the class-6 ceiling so it can transit between jobs.",
            "LifeSupport": "A-rated for long emergency air; Lightweight trims the mass back — life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — two huge guns, boost and a big shield all draw on the class-8 distributor.",
            "Radar": "Drop to D and go Lightweight; no role here needs sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size7": "Bi-weave regenerates fast under fire and recovers quickly between fights; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size5": "Hull reinforcement caps at size 5, so a 5D HRP fills this slot for max effective armour.",
            "Slot07_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size4": "Second HRP (size-4) for more Heavy-Duty armour where the slot allows.",
            "Slot10_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot11_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
