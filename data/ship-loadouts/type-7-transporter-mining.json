  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A cheap volume laser-mining fit with a big ore hold and an escape-grade bi-weave shield. Initial is the cheapest buy-only suite that can actually mine — one laser, refinery, prospector and collector controllers; A-rated is the full mining baseline; Engineered targets the ship's reach and survival — the mining tools are not meaningfully engineered.",
          "callout": {
            "label": "Big hold, cheap suite",
            "text": "Fit lasers, a refinery and collector controllers, then fill the rest with ore racks for a big haul. Its four small hardpoints suit laser and sub-surface mining over heavy core tools. Keep a bi-weave shield — it escapes pirates rather than fighting them."
          },
          "notes": {
            "SmallHardpoint1": "Primary mining laser; the cheap small fixed laser is the only one fitted on day one and mining tools carry no engineering.",
            "SmallHardpoint2": "Second mining laser doubles fragment yield once the hull is paid off; not engineerable.",
            "SmallHardpoint3": "Abrasion Blaster knocks surface deposits off asteroids for surface mining; not engineerable.",
            "SmallHardpoint4": "Sub-surface Displacement Missile cracks deep-rock deposits; not engineerable.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up the rich rocks in a ring; scanners carry no blueprint.",
            "TinyHardpoint2": "Heavy Duty booster lifts the bi-weave's raw MJ so you survive the run to escape; Super Capacitors adds more.",
            "TinyHardpoint3": "Second Heavy Duty booster — the cheapest large gain in shield strength for fleeing.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Low Emissions keeps the plant cool over long mining sessions; Thermal Spread bleeds heat further.",
            "MainEngines": "A-rated + Dirty Drives give the burst speed to break interdiction when laden.",
            "FrameShiftDrive": "Increased Range first — exploit the good laden reach to work distant, quiet hotspots; Mass Manager extends it.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rated for sustained laser and limpet power; Engine Focused feeds the boost that gets you clear.",
            "Radar": "Drop to D and go Lightweight; a miner needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises MJ and Fast Charge speeds the recharge for escape.",
            "Slot04_Size5": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot05_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot09_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
