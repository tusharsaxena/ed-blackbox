      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A pure dogfighting fit — everything bent toward staying on target and alive. Initial is buy-only; A-rated is the combat-ready baseline; Engineered maximises agility and the thin shield. With three small guns, one utility and an eggshell hull, the Eagle wins by never being hit.",
          "callout": {
            "label": "Agility is the only defence",
            "text": "With an eggshell hull, one utility and a minimal shield, the Eagle survives purely by not being hit — engineer thrusters and a bi-weave, and fly to stay on the enemy's blind side. One solid salvo can end you."
          },
          "notes": {
            "SmallHardpoint1": "Primary multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "SmallHardpoint2": "Second multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint3": "Efficient pulse laser for shield work; Thermal Vent runs it cold so the tiny plant stays cool.",
            "TinyHardpoint1": "The Eagle's only utility — a Heavy-Duty booster is the cheapest large gain on the thin shield.",
            "PowerPlant": "A-rate to run three guns, shield and the booster on a class-2 plant; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rate and Dirty Drive Tune FIRST — agility is the Eagle's only real defence.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; only G3 range — a dogfighter needs no jump monster.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate to sustain three guns plus boost on a class-2 distributor; Charge Enhanced + Super Conduits keep WEP full.",
            "Radar": "Drop to D and go Lightweight — combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot is the cheapest large multiplier on the eggshell hull.",
            "Slot01_Size3": "Bi-weave regenerates fast under fire; Reinforced lifts its low MJ and Fast Charge speeds the regen.",
            "Slot02_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size1": "A size-1 Heavy-Duty HRP adds what little armour the hull can carry.",
            "Slot04_Size1": "Module Reinforcement spreads penetrating-hit damage across the internals; not engineerable.",
            "Slot05_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot06_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies."
          },
