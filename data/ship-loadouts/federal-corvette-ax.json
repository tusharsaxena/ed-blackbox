  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A battleship AX tank: large enhanced AX multi-cannons on the huge mounts (no huge AX gun exists), Guardian Gauss cannons on the mediums for heart damage, Guardian reinforcement filling both military slots and the deep optionals, eight utilities and an SLF decoy. Initial is the buy-only bare hull; A-Rated adds the unlock-gated AX kit; Engineered hardens shields, hull, heat and mobility.",
          "callout": {
            "label": "Stand in the fire, harden everything",
            "text": "Unlike the AX mediums, the Corvette fills both military slots and several optionals with Guardian reinforcement — it survives by absorbing the lightning, not dodging it. Put Gauss on the mediums for heart damage, large AX multi-cannons in the huge slots (no huge AX gun exists), and run caustic and heat kit hard. The SLF decoy buys time when a swarm piles on."
          },
          "notes": {
            "HugeHardpoint1": "No huge AX gun exists — a large enhanced AX multi-cannon under-fills the huge mount; gimballed to hold fire on a weaving Interceptor.",
            "HugeHardpoint2": "Second large enhanced AX MC in the other huge mount; AX/Guardian weapons take no engineering, so this is the ceiling.",
            "LargeHardpoint1": "Third enhanced AX multi-cannon for sustained anti-Xeno hull damage between heart exposures.",
            "MediumHardpoint1": "Guardian Gauss cannon — the heart-killer; fixed-only, so the Corvette's stable platform earns its keep.",
            "MediumHardpoint2": "Second Gauss for double heart damage in the exposed-heart window; manage the heavy heat spike with the sinks.",
            "SmallHardpoint1": "Guardian Shard cannon — close-range Guardian damage that chews exposed hearts and hull.",
            "SmallHardpoint2": "Second shard rounds out the Guardian battery on the small mounts.",
            "TinyHardpoint1": "Advanced Xeno Scanner reveals Interceptor hearts and variant; mandatory AX kit, not engineerable.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Thermal-Resistant booster hardens the shield against Thargoid thermal and caustic damage.",
            "TinyHardpoint6": "Second Thermal-Resistant booster — resistance stacking is the AX shield's edge.",
            "TinyHardpoint7": "Heavy-Duty booster trades resistance for raw MJ once two resist boosters are stacked.",
            "TinyHardpoint8": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "Gauss, a capital shield and cells are power-hungry; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives keep the agility that holds Gauss on a heart at capital mass.",
            "FrameShiftDrive": "A-rated with Increased Range to move a 900t hull to distant Maelstroms and Titans.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate FIRST — Gauss draws hard on the weapon capacitor; Charge Enhanced sustains the rate of fire.",
            "Radar": "Drop to D and go Lightweight; the Xeno Scanner does the targeting, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement in the first military slot — module hardening is the Corvette's whole AX case.",
            "Military02": "Second Guardian MRP; two filled military slots is what sets the warship apart from the AX mediums.",
            "Slot01_Size7": "Capital bi-weave regenerates under fire; Thermal Resistant hardens it and Hi-Cap adds MJ.",
            "Slot02_Size7": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size7": "SLF bay adds a second gun platform that draws fire off you; hangars are not engineerable.",
            "Slot04_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size6": "Decontamination Limpet Controller scrubs caustic corrosion mid-fight; limpet controllers carry no blueprint.",
            "Slot06_Size5": "Guardian Hull Reinforcement — heavy effective-armour and caustic resistance, no blueprint needed.",
            "Slot07_Size5": "Third Guardian MRP spreads penetrating-hit damage across the internals.",
            "Slot08_Size4": "More Guardian hull where the slot allows; Guardian HRP also adds caustic resist.",
            "Slot09_Size4": "Regular HRP here — Heavy Duty + Deep Plating is the cheapest large effective-armour multiplier.",
            "Slot10_Size3": "Guardian Hull Reinforcement continues the armour stack into the size-3 slot.",
            "Slot11_Size1": "Last optional filled with a size-1 Guardian HRP — every point of effective armour counts in a held AXCZ."
          },
          "engineeringPlan": [
