  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "The whole exploration build on one screen. Initial is a jump-capable starter; A-Rated is the best buy-only expedition fit; Engineered is the long-range end state — almost entirely about range and weight, with one engineer doing most of the work. Plans and costs follow in the sections below.",
          "callout": {
            "label": "The two modules that define the build",
            "text": "The Guardian FSD Booster (a flat range gain, unlocked at a Guardian site) and the fuel scoop (so you never strand) are non-negotiable. Everything else is comfort and survival kit you tune to taste."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "One light booster cheaply multiplies the bi-weave's raw MJ for safer landings; Heavy Duty + Super Capacitors is the biggest gain per tonne.",
            "PowerPlant": "5D keeps mass down — with no guns to feed, output is not the limit; Low Emissions cuts heat and draw, Thermal Spread bleeds more.",
            "MainEngines": "5D thrusters; Clean Drive Tuning runs cool for safe planetary work, Drag Drives adds boost speed to climb out of gravity wells.",
            "FrameShiftDrive": "The whole build — a 5A SCO drive for maximum range and fast in-system travel; Increased Range + Mass Manager is the single biggest roll in exploration.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "4D is plenty without weapons; Engine Focused + Cluster Capacitors gives engine-capacitor headroom for repeated boosts on landing approaches — optional.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size5": "A light size-4 bi-weave under-fills this slot for a fast-regenerating landing buffer; Enhanced Low Power + Lo-Draw keeps its draw minimal (bi-weaves are C-rated only).",
            "Slot03_Size3": "The Guardian FSD Booster — a flat jump-range gain unlocked at a Guardian site, not bought; non-negotiable and not engineerable.",
            "Slot04_Size3": "A light size-2 SRV hangar (1 bay) for exobiology and Guardian-site runs; under-fills the size-3 slot and carries no blueprint.",
            "Slot05_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot06_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot07_Size2": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot08_Size1": "A cheap repair limpet controller for hull repairs the AFMU cannot reach; optional and not engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Clean Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
