  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "An anti-Xeno fit built on the Chieftain's agility: two large Enhanced AX Multi-Cannons for sustained fire, three Guardian Gauss Cannons for precision burst, a Guardian Shard Cannon for close work, and the full caustic/heat toolkit. Initial is the buy-only bare hull; A-Rated bolts on the Thargoid kit and Guardian reinforcement; Engineered hardens mobility, shields and survival — the AX/Guardian weapons themselves carry no engineering.",
          "callout": {
            "label": "Dodge, harden, manage heat",
            "text": "AX combat is evasion and survival: dodge the lightning, soak what lands behind Guardian module and hull reinforcement (the three military slots are gold here), clear caustic with the sink launcher and a heat-sink overheat, repair stripped modules with the AFMU, and watch heat — Gauss and AX weapons run hot. The Chieftain's agility makes the dodging possible.",
            "tone": "tip"
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon (gimballed) — the large mounts are the only ones that take an AX multi-cannon; gimbals make the sustained anti-Thargoid DPS easy to land. No weapon engineering exists.",
            "LargeHardpoint2": "Second large Enhanced AX Multi-Cannon for sustained kinetic AX damage on hearts and exertions; not engineerable.",
            "MediumHardpoint1": "Guardian Gauss Cannon (medium, fixed) — the hardest-hitting AX precision weapon; charge-and-release on exposed hearts. Gauss has no blueprint.",
            "SmallHardpoint1": "Guardian Gauss Cannon (small) — Gauss only fits small/medium, so the small mounts carry the precision battery; fixed, high distributor draw, not engineerable.",
            "SmallHardpoint2": "Second small Guardian Gauss Cannon; trigger discipline keeps the WEP capacitor from emptying. No engineering.",
            "SmallHardpoint3": "Guardian Shard Cannon (small) — shotgun burst for scouts and close passes; no blueprint available.",
            "TinyHardpoint1": "Xeno Scanner reads Thargoid type and exposed hearts; utility scanner, not engineerable.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Shield Booster — Thermal Resistant against Thargoid thermal fire, Super Capacitors adds raw MJ back.",
            "PowerPlant": "A-rate first to power Gauss, AX guns and the shield; Overcharged adds headroom, Thermal Spread bleeds the extra heat that AX weapons generate.",
            "MainEngines": "A-rated + Dirty Drive Tuning gives the agility that dodges Interceptor lightning — the single most important AX upgrade.",
            "FrameShiftDrive": "A-rated with Increased Range + Mass Manager to reach Thargoid airspace and Maelstroms; pin Farseer's blueprint for remote application.",
            "LifeSupport": "A-rated with Lightweight to trim mass; life support has no experimental effect.",
            "PowerDistributor": "A-rate and Charge-Enhance it — Gauss cannons drain the WEP capacitor fast; Super Conduits stretches each charge.",
            "Radar": "Drop to D and go Lightweight; AX fights are close-range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement — spreads Thargoid module-stripping damage and adds caustic resistance; Guardian tech is not engineerable.",
            "Military02": "Second Guardian Module Reinforcement; the military slots are the cheapest survival gain against Thargoid weapons.",
            "Military03": "Guardian Hull Reinforcement adds armour with built-in caustic resistance; no blueprint.",
            "Slot01_Size6": "Bi-Weave Shield (6C, the only size-6 bi-weave rating) regenerates fast under fire; Thermal Resistant + Fast Charge against thermal Thargoid attacks.",
            "Slot02_Size5": "Guardian Hull Reinforcement 5 — large caustic-resistant armour block; Guardian modules cannot be engineered.",
            "Slot03_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot04_Size2": "Hull Reinforcement Package — Heavy Duty + Deep Plating for the cheapest effective-armour multiplier.",
            "Slot05_Size2": "Module Reinforcement Package protects the internals; not engineerable.",
            "Slot06_Size1": "Small Hull Reinforcement Package, Heavy Duty + Deep Plating — armour stacks linearly, so even a size-1 helps."
          },
          "engineeringPlan": [
