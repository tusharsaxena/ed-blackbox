  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A high-capacity converted-explorer liner: the size-7 slot holds the shield so every size-6 goes to fares, filling a deep mixed cabin suite behind a fast-charging bi-weave on a 950t hull. Initial is buy-only (a base shield and two economy cabins to start earning); A-Rated is the tourer baseline; Engineered leans the hull for range while keeping VIPs safe. Cabins are swap-to-suit — economy for bulk sightseeing, first/luxury for premium boards.",
          "callout": {
            "label": "Capacity without the comfort bonus",
            "text": "The Caspian fills the largest converted cabin suite outside the Cutter, but as a Zorgon Peterson explorer it earns NO liner comfort bonus — every seat pays standard fares, so a Beluga, Orca or Lynx out-earns it per cabin. Its case is raw headcount and range, not premium polish; keep the bi-weave and point defence for threatened routes."
          },
          "notes": {
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large multiplier on the bi-weave's MJ to keep passengers safe.",
            "TinyHardpoint2": "Second Heavy-Duty booster; stacking is the bulk of a soft liner's shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns begin but it still pays on a fare run.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running.",
            "TinyHardpoint6": "Fourth Heavy-Duty booster once credits allow; drop a booster or two for the lightest possible hull if range matters more than safety.",
            "PowerPlant": "8A powers the shield, cabins and boosters; Low Emissions runs cool and quiet so the big hull draws less heat on busy routes.",
            "MainEngines": "7A + Dirty Drives give the heavy 950t hull the speed to escape interdiction with passengers aboard.",
            "FrameShiftDrive": "The class-8 SCO drive is the range story — Increased Range + Mass Manager reach the scenic spots that pay, though the laden hull still jumps well short of a stripped explorer.",
            "LifeSupport": "Lightweight trims mass from the big hull; life support only needs to outlast an emergency, and it has no experimental effect.",
            "PowerDistributor": "7A holds the ENG capacitor for boosting; Engine Focused biases it to engines so the heavy hull boosts clear of interdiction, Super Conduits speeds recharge.",
            "Radar": "D-rate and go Lightweight — a liner needs no sensor range, so the mass saving buys jump range.",
            "FuelTank": "7C stock tank for long legs; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Bi-Weave 7 in the size-7 slot (cabins cap at size 6, so no fare is lost here); Reinforced maxes MJ and Fast Charge restores the bi-weave's quick regen for passenger safety.",
            "Slot02_Size6": "Economy Cabin 6 — the bulk of the passenger payload for high-volume tourist runs.",
            "Slot03_Size6": "Luxury Cabin 6 for top-tier VIP boards; luxury needs a size-5+ slot, so the big internals earn the premium berths.",
            "Slot04_Size5": "Economy Cabin 5 — more bulk seats; swap to business when the board pays for comfort.",
            "Slot05_Size5": "Luxury Cabin 5 for premium VIP sightseeing — the smallest slot luxury fits.",
            "Slot06_Size5": "Economy Cabin 5 — flexible bulk volume where the board wants headcount.",
            "Slot07_Size5": "First Class Cabin 5 for higher-paying fares; first-class needs size-4+.",
            "Slot08_Size4": "Economy Cabin 4 — swap to first-class (size-4 minimum) for a premium berth.",
            "Slot09_Size4": "First Class Cabin 4 — the smallest first-class berth, for a mixed premium board.",
            "Slot10_Size3": "Business Cabin 3 — the best premium class that fits a size-3 slot (first/luxury need larger).",
            "Slot11_Size2": "Economy Cabin 2 — a size-2 slot takes only economy (business/first/luxury start at size 3+).",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data on the side."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
