  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A duelling fit built around the huge hardpoint and a heavy utility suite, tanked as deeply as six small optionals allow. Initial is buy-only; A-rated is the duel-ready baseline; Engineered applies the house combat pattern.",
          "callout": {
            "label": "Feed the huge gun",
            "text": "The FDL's identity is its huge hardpoint — a huge multi-cannon (Corrosive) or plasma accelerator. The oversized class-6 distributor means you can fire it continuously; build the rest of the ship to keep that gun on target."
          },
          "notes": {
            "HugeHardpoint1": "Primary huge mount — Overcharged with the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint1": "Gimballed beam — Efficient with Thermal Vent strips shields and vents heat so it runs cold.",
            "MediumHardpoint2": "Second Thermal-Vent beam doubles the cool shield-stripping output.",
            "MediumHardpoint3": "Gimballed multi-cannon — Overcharged with Auto Loader chews hull without reload gaps.",
            "MediumHardpoint4": "Second Overcharged multi-cannon keeps sustained hull DPS on target.",
            "TinyHardpoint1": "First of four Heavy-Duty shield boosters — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more raw shield MJ.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Fourth Heavy-Duty booster fills the last utility — this hull shield-tanks, so boosters beat point defence in a duel.",
            "PowerPlant": "Overcharged adds the headroom for the huge gun, four mediums, shield & cells; Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated plus Dirty Drives & Drag Drives preserve the class-leading agility that wins duels.",
            "FrameShiftDrive": "A-rated with G3 Increased Range only — Mass Manager softens the heavy combat fit; the FDL is no jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — the oversized class-6 unit lets the huge gun and four mediums fire without browning out; Charge Enhanced + Super Conduits deepen the WEP pool.",
            "Radar": "Drop to D and go Lightweight — combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Bi-weave regenerates fast under fire; Reinforced adds MJ and Fast Charge speeds the regen that defines it.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size4": "Heavy-Duty hull reinforcement — the cheapest large multiplier on effective armour.",
            "Slot04_Size2": "Second Heavy-Duty HRP; armour stacks linearly across the small internals.",
            "Slot05_Size1": "Module Reinforcement spreads penetrating-hit damage across the internals; not engineerable.",
            "Slot06_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies."
          },
