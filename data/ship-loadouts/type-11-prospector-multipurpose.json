              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 6,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
