  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit on the game's toughest hull — nine gimballed guns, a deep bi-weave over stacked armour, ~216 t of cargo and enough range to travel. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it capable across combat, hauling and defence. Strip the cargo and HRPs for a bigger hold to trade, or add more reinforcement to tank — the T-10 re-tunes at a station.",
          "callout": {
            "label": "A tank that dabbles",
            "text": "The Type-10's identity is armour and mount count, not versatility — feeble ~99 MJ base shields, glacial 179/219 m/s handling and a size-7 FSD cap how far it stretches. This is one balanced configuration; keep role-specific module sets in storage, but accept that even fully kitted it hauls, jumps and fights worse than a Python or Anaconda of the same class."
          },
          "notes": {
            "LargeHardpoint1": "Lead large multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon for sustained kinetic DPS; Auto Loader removes reloads.",
            "LargeHardpoint3": "Large beam for shield-stripping; Thermal Vent keeps it cold under sustained fire.",
            "LargeHardpoint4": "Large pulse adds efficient laser damage; Efficient + Thermal Vent runs it cool.",
            "MediumHardpoint1": "Medium multi-cannon fills the kinetic battery; Auto Loader keeps it firing.",
            "MediumHardpoint2": "Medium pulse rounds out the laser side; cheap on power and heat.",
            "MediumHardpoint3": "Second medium multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint1": "Small multi-cannon fills a firing arc; Auto Loader keeps it uninterrupted.",
            "SmallHardpoint2": "Small pulse fills the last mount; swap freely when re-roling.",
            "TinyHardpoint1": "First shield-booster; Heavy Duty multiplies the bi-weave's raw MJ — vital on a hull with feeble base shields.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; the shield needs the stack to be worth anything.",
            "TinyHardpoint4": "Fourth Heavy-Duty booster before utilities turn to defence.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint8": "Fifth Heavy-Duty booster fills the last utility; the huge utility suite is what lets the thin shield hold up.",
            "PowerPlant": "Powers nine guns, a big shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover the barest agility a 1,200 t hull allows — it stays glacial.",
            "FrameShiftDrive": "A-rated with Increased Range and Mass Manager; the size-7 FSD needs both just to make the hull travel-usable.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate early — nine guns plus boost drain the class-7 distributor; Charge Enhanced + Super Conduits keep WEP and ENG up.",
            "Radar": "Drop to D and go Lightweight; multirole needs no sensor range, so save the mass.",
            "FuelTank": "Stock 6C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the first military slot is the cheapest large multiplier on effective armour — the T-10's whole point.",
            "Military02": "Module Reinforcement in the second military slot spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size8": "Size-8 bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more — the survivable all-round choice for a shield-poor hull.",
            "Slot02_Size7": "Cargo rack for hauling; strip it for more reinforcement when tanking. Cargo racks aren't engineerable.",
            "Slot03_Size6": "Optional — more cargo space for dedicated trade runs. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Heavy-Duty hull reinforcement; armour stacks linearly and this hull leans on it, not shields.",
            "Slot05_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size4": "Optional — adds cargo space; swap for an HRP when a pure tank is wanted. Cargo racks aren't engineerable.",
            "Slot07_Size3": "More Heavy-Duty hull reinforcement where the slot allows.",
            "Slot08_Size3": "Optional — adds cargo space; worth it for haulers. Cargo racks aren't engineerable.",
            "Slot09_Size2": "Module Reinforcement protects the internals; not engineerable.",
            "Slot10_Size1": "Heavy-Duty hull reinforcement fills the lone size-1 slot — every internal earns its mass on this hull."
          },
          "engineeringPlan": [
