  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A capital-grade combat fit: a huge main gun and three large mounts, deep shields and reinforcement, eight utilities and an SLF bay. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern at battleship scale.",
          "callout": {
            "label": "A battleship's depth",
            "text": "Twelve optionals, a military slot and eight utilities let the Anaconda tank on shields and hull simultaneously while carrying a fighter and a full booster suite. Few ships can field everything at once like this — use the scale."
          },
          "notes": {
            "HugeHardpoint1": "The single huge mount; one Corrosive Shell here strips armour resistance for the whole battery.",
            "LargeHardpoint1": "Beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "LargeHardpoint2": "Large multi-cannon for sustained kinetic DPS; Auto Loader removes reloads.",
            "LargeHardpoint3": "Second beam doubles shield-strip rate; Thermal Vent keeps the heat budget in check.",
            "MediumHardpoint1": "Fill-in multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint2": "Efficient pulse adds low-draw laser damage; Thermal Vent makes it a heat sink too.",
            "SmallHardpoint1": "Small multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Second small multi-cannon; left empty on the buy-only fit, added once the hull is paid off.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth booster rounds out the core shield stack.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Fifth Heavy-Duty booster fills the last of the eight utility mounts.",
            "PowerPlant": "Powers eight guns, an SLF, a big shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover what agility a 400t-mass capital can manage.",
            "FrameShiftDrive": "A-rated to move a heavy battleship between fights; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — eight guns plus boost drain the class-8 distributor faster than anything else.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot is the cheapest large multiplier on effective armour.",
            "Slot01_Size7": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size6": "SLF bay adds a second gun platform that draws fire; hangars are not engineerable.",
            "Slot04_Size6": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-6 slot for max effective armour.",
            "Slot05_Size5": "Heavy-Duty HRP; armour stacks linearly so every reinforcement pays.",
            "Slot06_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size5": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot08_Size4": "More Heavy-Duty hull where the slot allows.",
            "Slot09_Size4": "More internal protection for the modules that keep you flying.",
            "Slot10_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot11_Size2": "Small Module Reinforcement for the last of the internal protection.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 8,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 7,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Multi-Cannons",
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Corrosive Shell (one) / Auto Loader (rest)",
              "engineer": "Tod McQuinn"
            },
            {
              "module": "Beam & Pulse Lasers",
              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Thermal Vent",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Power Distributor",
              "size": 8,
              "grade": "G5",
              "blueprint": "Charge Enhanced",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Shield Generator",
              "size": 7,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Bulkheads",
              "blueprint": "Heavy Duty",
              "grade": "G5",
              "engineer": "Selene Jean",
              "experimental": "Deep Plating"
            },
            {
              "module": "Hull Reinforcement",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Deep Plating",
              "engineer": "Selene Jean"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            }
          ]
        }
      }
