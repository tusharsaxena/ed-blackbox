  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A no-frills armour-tank brawler fit using both military slots. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern weighted to hull, since shields are weak.",
          "callout": {
            "label": "Armour-tank, shield-buffer",
            "text": "With the lowest shields of the Federal trio, the Dropship leans hard on armour. Fill the military slots and several optionals with Heavy-Duty reinforcement and treat the bi-weave as a regenerating buffer, not the main defence."
          },
          "notes": {
            "LargeHardpoint1": "The single large mount carries the Corrosive Shell multi-cannon, stripping armour resistance for the whole battery.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a Thermal-Vent beam once A-rated for heat-free shield-stripping.",
            "MediumHardpoint2": "Gimballed medium multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint3": "Second medium multi-cannon; Auto Loader removes reloads so the kinetic battery never stops firing.",
            "MediumHardpoint4": "Efficient pulse runs cool and chips at hulls; Phasing Sequence leaks damage through shields.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the thin bi-weave's raw MJ where it matters most.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain on a weak shield.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers five guns, a shield and reinforcement; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover what mobility the heavy hull allows.",
            "FrameShiftDrive": "A-rated to reach fights and Federal-rank turn-ins; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — five guns plus boost drain the class-6 distributor fast.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the first military slot is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Fast Charge speeds the buffer's recovery.",
            "Slot02_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size5": "Hull reinforcement caps at size 5, so a 5D HRP fully fills this slot for max effective armour.",
            "Slot04_Size4": "Second Heavy-Duty HRP — armour stacks linearly, so more plating is more survival.",
            "Slot05_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size3": "Module Reinforcement protects the cores; not engineerable.",
            "Slot07_Size2": "More internal protection for the modules that keep you flying; not engineerable.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
