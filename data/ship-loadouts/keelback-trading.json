      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defended budget trade fit built around the fighter bay. Initial is buy-only; A-rated is the trade baseline; Engineered balances modest cargo, a shield and the SLF.",
          "callout": {
            "label": "The fighter is the point",
            "text": "A class-5 fighter hangar is the Keelback's reason to exist — deploy an SLF (yourself, a crewmate or an NPC) to fight off pirates while the freighter survives. The cargo it costs you is the price of that defence; if you don't want the fighter, buy a Type-6 instead."
          },
          "notes": {
            "MediumHardpoint1": "A single gimballed multi-cannon is token self-defence; Overcharged & Corrosive Shell let the mothership chip in while the SLF does the work.",
            "TinyHardpoint1": "Heavy-Duty shield booster multiplies the small bi-weave's raw MJ — the cheapest survivability gain on the hull.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "4A plant runs the hangar, shield and modules; Low Emissions plus Thermal Spread keep heat and signature low.",
            "MainEngines": "A-rated thrusters move the laden hull; Dirty Drives plus Drag Drives add the speed to reposition or run.",
            "FrameShiftDrive": "A-rated FSD for laden range; Increased Range plus Mass Manager stretch the jump on a heavy little freighter.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support needs no rating for a hauler and has no experimental.",
            "PowerDistributor": "A-rated so boost and the hangar stay fed; Engine Focused recharges the ENG capacitor faster for escapes.",
            "Radar": "D-rate and go Lightweight; a trader needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "The class-5 fighter hangar — the Keelback's whole reason to exist; SLF bays carry no blueprint.",
            "Slot02_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot03_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size3": "Bi-weave regenerates fast under fire; Reinforced plus Hi-Cap maximise its MJ so it outlasts a pirate.",
            "Slot05_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
