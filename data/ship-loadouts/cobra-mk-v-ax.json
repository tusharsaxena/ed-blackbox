  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A small-pad anti-Xeno fit built on Gauss density: two medium and one small Guardian Gauss Cannon for heart damage, a medium Enhanced AX Multi-Cannon for sustained fire, and a Guardian Shard Cannon for scouts. Initial is the buy-only bare hull; A-Rated bolts on the Thargoid kit and crams Guardian reinforcement into the civilian optionals; Engineered hardens mobility, shields and survival — the AX/Guardian weapons carry no engineering. The Cobra docks at any outpost, but a 150 t hull with 245 heat capacity and no military slot pays for its three Gauss in heat and thin tank.",
          "callout": {
            "label": "Kite, burst Gauss, watch the heat",
            "text": "Three Gauss on a small hull is a lot of heat and distributor drain — fire in short volleys, dump with the single Heat Sink and disengage before the shallow armour matters. There are no military slots, so every Guardian reinforcement block eats an optional the shield and decon also want. The Cobra survives AX by speed and evasion, not soak.",
            "tone": "tip"
          },
          "notes": {
            "MediumHardpoint1": "Guardian Gauss Cannon (medium, fixed) — the hardest-hitting AX precision weapon; charge-and-release on exposed hearts. The Cobra's three medium mounts are what let it carry medium Gauss at all. Gauss has no blueprint.",
            "MediumHardpoint2": "Second medium Guardian Gauss Cannon; the pair is the heart-stripping core, but two mediums firing together spike heat hard on a small hull. Not engineerable.",
            "MediumHardpoint3": "Enhanced AX Multi-Cannon (gimballed, medium) — gimbals make the sustained anti-Thargoid DPS easy to land while the Gauss recharge. No weapon engineering exists.",
            "SmallHardpoint1": "Guardian Gauss Cannon (small) — a third heart gun for extra burst; fixed, high distributor draw. Trigger discipline keeps the WEP capacitor from emptying. No engineering.",
            "SmallHardpoint2": "Guardian Shard Cannon (small) — shotgun burst for scouts and close passes; no blueprint available.",
            "TinyHardpoint1": "Xeno Scanner reads Thargoid type and exposed hearts — essential for target priority; utility scanner, not engineerable.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. The only heat sink on the hull; four utility mounts leave no room for a second, so heat management is tight.",
            "TinyHardpoint4": "Shield Booster — Thermal Resistant against Thargoid thermal fire, Super Capacitors adds raw MJ back to a small shield.",
            "PowerPlant": "A-rate first to power three Gauss, the AX gun and the shield; the class-4 plant is a hard ceiling. Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drive Tuning gives the agility that dodges Interceptor lightning — the Cobra's whole AX survival case on a light hull.",
            "FrameShiftDrive": "A-rated with Increased Range + Mass Manager to reach Thargoid airspace and Maelstroms; pin Farseer's blueprint for remote application.",
            "LifeSupport": "A-rated with Lightweight to trim mass; life support has no experimental effect.",
            "PowerDistributor": "A-rate and Charge-Enhance it — the class-4 distributor is the tightest system on the hull; three Gauss drain the WEP capacitor fast, so Super Conduits stretches each charge.",
            "Radar": "Drop to D and go Lightweight; AX fights are close-range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Bi-Weave Shield (5C, the largest the optional bay allows) regenerates fast under fire; Thermal Resistant + Fast Charge against thermal Thargoid attacks.",
            "Slot02_Size4": "Guardian Hull Reinforcement — caustic-resistant armour, the biggest single hardening block on a thin-armour hull; not engineerable.",
            "Slot03_Size4": "Guardian Module Reinforcement — spreads Thargoid module-stripping damage and adds caustic resistance; with no military slot the Cobra pays an optional for it. Not engineerable.",
            "Slot04_Size4": "Second Guardian Hull Reinforcement; effective armour stacks linearly and this light hull needs every point. Not engineerable.",
            "Slot05_Size3": "Decontamination Limpet Controller strips caustic off the hull mid-fight; limpet drones carry no engineering.",
            "Slot06_Size3": "More Guardian Hull Reinforcement where the optional allows; caustic-resistant, no blueprint.",
            "Slot07_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules stripped by Thargoid lightning between passes.",
            "Slot08_Size2": "Guardian Module Reinforcement protects the internals a small hull can't afford to lose; not engineerable.",
            "Slot09_Size1": "A small Guardian HRP tops up effective armour where the last optional allows; not engineerable."
          },
          "engineeringPlan": [
