  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A shield-tank combat fit built around the game's best shields. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern with a prismatic-class shield and deep cell banks.",
          "callout": {
            "label": "Prismatic shields are the point",
            "text": "The Cutter's identity is its shield tank — a prismatic generator plus four Heavy-Duty boosters and multiple cell banks push it past 2,500 MJ, beyond anything else in the game. Build around the shield; the huge gun and reinforcement are the supporting cast."
          },
          "notes": {
            "HugeHardpoint1": "The huge mount is the Cutter's hammer; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint1": "Large beam for shield-stripping; Thermal Vent runs it cold under sustained fire.",
            "LargeHardpoint2": "Large multi-cannon for sustained kinetic DPS; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint1": "Medium multi-cannon fills the battery; Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint2": "Medium beam adds shield-stripping; Thermal Vent keeps heat in check.",
            "MediumHardpoint3": "Second medium multi-cannon; Auto Loader keeps it topped up between salvoes.",
            "MediumHardpoint4": "Medium pulse for an efficient, low-draw finisher; Thermal Vent runs it cool.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the prismatic's raw MJ.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth booster rounds out the shield stack before utilities turn to defence.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Fifth Heavy-Duty booster in the last utility once credits allow.",
            "PowerPlant": "The class-8 plant feeds seven guns, a huge prismatic shield, cell banks, an SLF and eight utilities; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives recover what straight-line speed a 1,100t hull can manage.",
            "FrameShiftDrive": "A-rated to move a vast warship between fights; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this to sustain seven guns plus the shield-cell draw; Charge Enhanced + Super Conduits keep weapon and SYS capacitors deep.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-6 tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the dedicated military slot — the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size8": "The class-8 prismatic generator is the whole ship; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size8": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size6": "SLF bay adds a second gun platform that draws fire; hangars are not engineerable.",
            "Slot04_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size6": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-6 slot for max effective armour.",
            "Slot06_Size5": "Second Heavy-Duty HRP — armour stacks linearly under the shields.",
            "Slot07_Size5": "Module Reinforcement protects the cores; not engineerable.",
            "Slot08_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot09_Size3": "More internal protection for the modules that keep you flying; not engineerable.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
