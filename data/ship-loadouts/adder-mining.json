  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete (if tiny) core-mining fit on the cheapest hull that takes one. Initial is buy-only; A-rated is the working baseline; Engineered focuses on range and cool running so the small frame travels well. The mining tools themselves are not meaningfully engineered. For pure laser mining, swap the seismic launcher for a mining laser and drop the missile.",
          "callout": {
            "label": "A whole loop, almost no hold",
            "text": "This fits the complete cycle — prospector to find the rock, seismic launcher and abrasion blaster to crack it, collector limpets to gather, refinery to process — into seven small slots. What it can't fit is much ore: two class-3 racks leave ~16 t after the suite, so you'll dock often. Strip the shield and collector for ~30 t max if you only laser-mine in safe space."
          },
          "notes": {
            "MediumHardpoint1": "Core-mining's main tool — lob a seismic charge into a fissure to crack the rock; a fixed medium warhead is the only size the hull mounts, and mining tools carry no weapon blueprint.",
            "SmallHardpoint1": "Abrasion Blaster shears surface deposits off a cracked core for the limpets to scoop; mining tools aren't engineerable.",
            "SmallHardpoint2": "Sub-surface Displacement Missile reaches the deep deposits the blaster can't; no blueprint applies.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks and core fissures; held at class 3 so it doesn't swamp the tiny power budget, and scanners carry no blueprint.",
            "TinyHardpoint2": "One Heavy-Duty booster roughly doubles the small bi-weave's raw MJ — the cheapest survivability gain on the hull.",
            "PowerPlant": "A-rate it to run lasers, the seismic launcher and the limpet swarm together; Low Emissions + Thermal Spread keep heat down through long sessions.",
            "MainEngines": "A-rated thrusters with Clean Drive Tuning + Drag Drives so the light hull can boost clear of interdictions it can't fight.",
            "FrameShiftDrive": "Increased Range + Mass Manager stretch every jump so the short-legged hull reaches distant rings and hauls ore home in fewer hops.",
            "LifeSupport": "D-rated and Lightweight — life support is mass to shed on a hull this small, and it has no experimental effect.",
            "PowerDistributor": "A-rate the class-2 distributor first or the tools and limpets brown out together; Engine Focused at G3 feeds the boost you escape pirates with.",
            "Radar": "Dropped to D and Lightweight — a miner needs no sensor range, so save the mass; sensors have no experimental effect.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot04_Size2": "A size-2 bi-weave is all that fits; Reinforced + Fast Charge maximise MJ while keeping the bi-weave's quick recharge — enough to survive a clumsy landing, not a pirate.",
            "Slot05_Size1": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot06_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
