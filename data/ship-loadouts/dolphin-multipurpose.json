  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced small-hull fit — two self-defence guns, a fast-regen shield, useful cargo room and modest range on a ship that lands anywhere. Initial is buy-only; A-rated is the all-round baseline; Engineered layers on the Dolphin's signature cool-running thermals. Re-role by swapping the optional internals: cargo for hauling, a cabin for passengers, or scanners plus an SRV bay for light exploration.",
          "callout": {
            "label": "Re-role by the optionals, but know the ceiling",
            "text": "Cores stay fixed; the optional internals define the job — cargo racks for trading, a class-5 cabin for passenger runs, or scanner plus SRV bay for light survey work. What it cannot do is fight anything: two small mounts are deterrent guns, not a battery. Lean on its heat, comfort, small pad and price."
          },
          "notes": {
            "SmallHardpoint1": "First of only two weapon mounts; a gimballed small multi-cannon is the easy self-defence pick, Overcharged with the one Corrosive Shell to strip armour resistance.",
            "SmallHardpoint2": "Second small multi-cannon pairs with the first; Auto Loader keeps its DPS uninterrupted. Two small guns is deterrent fire, not a warship battery.",
            "TinyHardpoint1": "One shield booster is the cheapest large gain to the bi-weave; Heavy Duty multiplies its raw MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. The Dolphin barely needs it, but it resets heat for silent running.",
            "PowerPlant": "Powers guns, shield and utilities together; Overcharged adds headroom, Thermal Spread bleeds the extra heat — deepening the Dolphin's class-leading thermals.",
            "MainEngines": "A-rated plus Dirty Drives lift the light hull's agility for docking and disengaging.",
            "FrameShiftDrive": "A-rate first; Increased Range plus Mass Manager pushes the laden Dolphin's modest jump toward ~30 LY — the class-4 drive caps it there.",
            "LifeSupport": "A-rated for long emergency oxygen; Lightweight trims mass — life support has no experimental effect.",
            "PowerDistributor": "A-rate for weapon and boost recharge; Charge Enhanced plus Super Conduits sustains the two guns and boost.",
            "Radar": "Drop to Lightweight; a generalist needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional — the largest cargo rack (biggest single slot); swap for a class-5 cabin to run passengers. Cargo racks aren't engineerable.",
            "Slot02_Size4": "Bi-Weave shield sized to the light 140 t hull for fast regen; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot03_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size2": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stack it on a thin small hull.",
            "Slot06_Size2": "Second Heavy-Duty HRP; the light hull needs every point of effective armour it can get.",
            "Slot07_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for light survey work.",
            "Slot09_Size1": "Third Heavy-Duty HRP fills the last size-1 slot for a little more effective armour."
          },
