  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced defensive-hauler fit — the biggest non-Cutter hold, a survivable shield, self-defence guns and mass-managed range, ready to re-tune for whatever job the week demands. Initial is buy-only; A-rated is the all-round baseline; Engineered hardens the cores, shields and hull so the barge can take a hit and still reach market. Re-role by swapping the optional internals: fill with cargo racks to haul, drop in a passenger cabin, or add mining tools and a refinery for ore.",
          "callout": {
            "label": "A barge, not a warship",
            "text": "The Type-9's identity is volume, not violence. The five guns are self-defence — enough to make a lone pirate think twice, never enough to win a fight. Build the ship to survive the interdiction and jump away with a full hold: shields, boosters, cells and reinforcement first, then re-tune the optionals for the task."
          },
          "notes": {
            "MediumHardpoint1": "Main gun; a gimballed multi-cannon is the easy self-defence pick, Overcharged with the one Corrosive Shell to strip armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium runs a beam for shield-stripping; Thermal Vent vents heat so a soft, slow hull stays cool under return fire.",
            "MediumHardpoint3": "Third medium multi-cannon adds sustained kinetic DPS; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint1": "Small multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Small pulse fills the last mount; Efficient keeps heat and power low on a barge with a class-6 plant.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in survivability for a soft hull.",
            "TinyHardpoint2": "Second Heavy-Duty booster; on a fragile barge every point of shield buys time to jump away.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire while you line up the jump.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers five guns, a big shield and cells; Overcharged adds headroom on the class-6 plant, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated plus Dirty Drives claw back what agility an 850 t barge can have; it stays slow, so the shield does the surviving.",
            "FrameShiftDrive": "A-rated with Increased Range and Mass Manager — the size-6 FSD drags a heavy hull, so every point of range matters when hauling to market.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate early — the guns plus boost drain the class-6 distributor; Charge Enhanced plus Super Conduits keep WEP and ENG usable.",
            "Radar": "Drop to D and go Lightweight; a barge needs no sensor range, so save the mass for jump.",
            "FuelTank": "Stock 6C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size8": "Optional — one of two class-8 slots; pure cargo for a hauler. Cargo racks aren't engineerable.",
            "Slot02_Size8": "Optional — the second class-8 slot; together the two hold the bulk of the load. Cargo racks aren't engineerable.",
            "Slot03_Size7": "Bi-weave shield in the size-7 slot for fast regen under fire; Reinforced maximises its MJ and Hi-Cap adds more — the survivable all-round choice for a soft hull.",
            "Slot04_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing to survive an interdiction.",
            "Slot06_Size4": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stack it.",
            "Slot07_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot08_Size3": "Second Heavy-Duty hull reinforcement; armour stacks linearly, so a fragile barge wants the extra plating.",
            "Slot09_Size3": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot10_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot11_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 6,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 7,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
