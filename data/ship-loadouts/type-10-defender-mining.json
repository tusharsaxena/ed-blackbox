  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A heavy mining fit for laser and core work that keeps a turreted gun battery and deep armour for self-defence. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on armour, mobility and heat — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "Tools, limpets, and a wall of armour",
            "text": "A complete heavy miner: two lasers and a seismic launcher for both mining styles, a Pulse Wave Analyser to find rocks, a refinery, prospector and collector controllers to work fast, and a large ore rack — plus the Type-10's signature wall of armour, hull/module reinforcement and a turreted gun battery so the pirate who interdicts you regrets it. The bi-weave is a buffer; the armour is the tank."
          },
          "notes": {
            "LargeHardpoint1": "Fixed mining laser is the bread-and-butter laser-mining tool; mining tools gain nothing from engineering, so leave it stock.",
            "LargeHardpoint2": "Second mining laser doubles laser throughput on a fragment rock; it under-fills the large slot but lasers max at size 2.",
            "LargeHardpoint3": "Seismic charge launcher for core (motherlode) mining; ordnance with no blueprint, fitted in a large slot since it only comes in medium.",
            "LargeHardpoint4": "Size-3 turret multi-cannon is the heaviest defensive gun; Overcharged + Corrosive Shell strips a pirate's hull resistance for the whole battery.",
            "MediumHardpoint1": "Sub-surface displacement missile cracks deposits inside cores; mining ordnance, left stock.",
            "MediumHardpoint2": "Turret multi-cannon so it tracks the pirate while you keep lasers on the rock; Overcharged + Auto Loader for uninterrupted fire.",
            "MediumHardpoint3": "Second medium defensive turret; Overcharged + Auto Loader keeps the gun battery firing while you mine.",
            "SmallHardpoint1": "Abrasion blaster knocks surface deposits off asteroids; fixed-only mining tool, left stock.",
            "SmallHardpoint2": "Small turret multi-cannon fills the last weapon mount for extra tracking fire; Overcharged + Auto Loader.",
            "TinyHardpoint1": "Pulse wave analyser lights up high-yield rocks across the ring; A-rated for the widest pulse, no blueprint exists.",
            "TinyHardpoint2": "Shield booster stacks onto the bi-weave buffer; Heavy Duty + Super Capacitors is the cheapest large gain in raw MJ.",
            "TinyHardpoint3": "Second Heavy-Duty booster thickens the buffer that buys time while the armour does the tanking.",
            "TinyHardpoint4": "Third Heavy-Duty booster rounds out the shield stack before utilities turn to countermeasures.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "Powers lasers, limpets, turrets and reinforcement together; Low Emissions + Thermal Spread keeps heat down across long mining runs.",
            "MainEngines": "A-rated + Dirty Drives recover the barest mobility a 1,200t hull allows.",
            "FrameShiftDrive": "A-rated + Increased Range (G5) eases the jumps to distant hotspots; Mass Manager offsets the heavy fit.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more, and life support has no experimental effect.",
            "PowerDistributor": "A-rate FIRST so lasers and limpets never brown out; Engine Focused + Super Conduits speeds recharge for sustained mining.",
            "Radar": "Drop to D and go Lightweight; mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot is the cheapest large multiplier on the Type-10's signature armour.",
            "Military02": "Module reinforcement spreads penetrating-hit damage across the internals that keep you mining; not engineerable.",
            "Slot01_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Bi-weave shield is just a fast-regen buffer over the armour; Reinforced + Fast Charge maximise that buffer.",
            "Slot04_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot06_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot08_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot09_Size2": "Extra Heavy-Duty hull reinforcement where the small slot allows; armour is the tank.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
