  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A high-capacity liner fit built around the game's best shields. Initial is buy-only economy seating behind a basic shield; A-Rated swaps in a prismatic generator and a VIP cabin mix; Engineered preserves speed and protection while maximising berths. Economy cabins cap at size 6, so the two size-8 optional slots hold a size-6 cabin (or the prismatic) — there is no larger passenger module.",
          "callout": {
            "label": "Shield first, then cabins",
            "text": "The Cutter's edge over the dedicated liners is protection — fit a prismatic generator in the class-8 slot and a full booster suite, then fill the rest with cabins. Run all-economy for mass transport, or mix in first/luxury suites for VIP boards. Either way the passengers are genuinely safe, and you can outrun what you can't out-tank."
          },
          "notes": {
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the prismatic's raw MJ so the board stays protected.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster deepens the buffer before utilities turn to defence.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Fourth Heavy-Duty booster — the prismatic scales hard with stacked boosters.",
            "TinyHardpoint7": "Fifth Heavy-Duty booster once credits allow.",
            "TinyHardpoint8": "Sixth Heavy-Duty booster tops out the shield stack.",
            "PowerPlant": "A-rate to power the prismatic, cabins and utilities; Low Emissions keeps a laden liner cool and quiet.",
            "MainEngines": "A-rated size-8 thrusters with Dirty Drives preserve the speed that lets a loaded Cutter outrun trouble.",
            "FrameShiftDrive": "A-rated with Increased Range to reach distant tourist beacons; Mass Manager offsets the heavy hull.",
            "LifeSupport": "A-rated for endurance; Lightweight trims mass and life support has no experimental effect.",
            "PowerDistributor": "Engine Focused feeds the boost that powers the escape; Super Conduits deepen the ENG reservoir.",
            "Radar": "Drop to D and go Lightweight — a liner needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement — cheap survivability for the moment a shield drops mid-interdiction.",
            "Military02": "Second Heavy-Duty HRP; the military slots take no cabins, so armour is the best use of them.",
            "Slot01_Size8": "Prismatic generator in the largest slot — the Cutter's defining edge; Reinforced + Hi-Cap maximise raw MJ.",
            "Slot02_Size8": "Economy cabins cap at size 6, so a 6E cabin under-fills this size-8 slot — the most berths available here.",
            "Slot03_Size6": "Size-6 economy cabin — 32 berths, the bulk of the payload.",
            "Slot04_Size6": "Second size-6 economy cabin for maximum headcount.",
            "Slot05_Size6": "First-class cabin for VIP boards; swap to luxury for the highest-value fares.",
            "Slot06_Size5": "Economy cabin for volume; swap to business for mixed boards.",
            "Slot07_Size5": "Business cabin covers mid-tier fares without sacrificing too many seats.",
            "Slot08_Size4": "Smaller economy cabin fills the size-4 slot with extra berths.",
            "Slot09_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
