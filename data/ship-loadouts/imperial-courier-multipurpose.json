  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced light multirole fit — three mediums for self-defence, a strong bi-weave shield, a small hold and a fuel scoop so it can switch tasks on the move. Initial is buy-only; A-rated is the multirole baseline; Engineered makes the shield and speed excellent for a hull this cheap.",
          "callout": {
            "label": "Built to re-tune",
            "text": "This is one balanced configuration; the Courier's small modules make role-swaps cheap — fill the optionals with cargo racks to run a trade loop, drop in a fuel scoop and DSS to explore, or swap an SRV bay into the planetary suite for surface work. Keep a spare set or two in storage and re-tune at any outpost."
          },
          "notes": {
            "MediumHardpoint1": "Gimballed multi-cannon; the single Corrosive Shell strips armour resistance for both guns. Buy a cheap pulse first, swap once A-rated.",
            "MediumHardpoint2": "Second gimballed multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint3": "Gimballed beam for shield-stripping; Thermal Vent vents heat so it runs cold on this low-heat-capacity hull.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain on a thin hull.",
            "TinyHardpoint2": "Second Heavy-Duty booster; Super Capacitors squeezes out more shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "PowerPlant": "Small class-4 plant runs guns, a big shield, scoop and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives keep the Courier among the fastest ships in the game — speed is its all-round edge.",
            "FrameShiftDrive": "A-rated + Increased Range; Mass Manager keeps jump range healthy so it can also serve as a light explorer.",
            "LifeSupport": "D-rate to save mass on the size-1 slot; Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate for simultaneous guns, boost and shield draw; Charge Enhanced + Super Conduits keep the WEP/SYS pools full.",
            "Radar": "Drop to D and go Lightweight; a multirole light hull needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Bi-weave regenerates fast under fire — ideal for a thin hull; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size2": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot04_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot07_Size1": "Hull reinforcement is the cheapest effective-armour multiplier; Heavy Duty + Deep Plating on the size-1 slot.",
            "Slot08_Size1": "Left empty for heat-sink storage or a spare module; fill per role."
          },
