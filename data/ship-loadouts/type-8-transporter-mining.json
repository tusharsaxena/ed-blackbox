  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A high-volume laser-mining fit built around a huge ore hold and a defensive shield. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on the ship's mobility, defence and heat — the mining tools are not meaningfully engineered.",
          "callout": {
            "label": "Volume is the point",
            "text": "The Type-8's hold is enormous — fit lasers, a refinery and a big collector controller, then fill the rest with ore racks for the longest sessions before docking. Keep a bi-weave shield: it can't fight pirates, so survival means tanking the hit and boosting away."
          },
          "notes": {
            "MediumHardpoint1": "Medium mining laser is the main ore-cutting tool; mining lasers carry no engineering blueprint, so it stays stock.",
            "SmallHardpoint1": "Second mining laser doubles cutting rate on a deposit; left stock like all mining tools.",
            "SmallHardpoint2": "Abrasion Blaster pops surface deposits off asteroids for collectors to scoop; not engineerable.",
            "SmallHardpoint3": "Sub-surface Displacement Missile blasts out sub-surface deposits; not engineerable.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up core- and deposit-bearing rocks across a ring; scanners carry no blueprint.",
            "TinyHardpoint2": "Shield booster stacks raw MJ onto the bi-weave; Heavy Duty is the cheapest large gain in escape buffer.",
            "TinyHardpoint3": "Second Heavy-Duty booster — more buffer to tank one pirate hit before boosting clear.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate to power the whole mining suite; Low Emissions runs cool through long sessions and Thermal Spread bleeds more heat.",
            "MainEngines": "A-rated + Dirty Drives give the speed to escape interdiction when laden with ore.",
            "FrameShiftDrive": "A-rated + Increased Range to reach distant hotspots and haul ore home; Mass Manager offsets the cargo mass.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate to sustain laser fire and limpets; Engine Focused biases the reservoir toward boosting away.",
            "Radar": "Drop to D and go Lightweight; mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Bi-weave regenerates fast under fire; Reinforced maxes its MJ and Fast Charge speeds the recharge for escape tanking.",
            "Slot05_Size5": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot06_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Distributor",
              "size": 4,
              "grade": "G3",
              "blueprint": "Engine Focused",
              "experimental": "—",
              "engineer": "The Dweller"
            },
            {
              "module": "Power Plant",
              "size": 5,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 6,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Bulkheads",
              "blueprint": "Lightweight",
              "grade": "G5",
              "engineer": "Selene Jean",
              "experimental": "Deep Plating"
            }
          ]
        }
      }
    },
