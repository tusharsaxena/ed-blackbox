        "edbb": {
          "role": "multipurpose",
          "intro": "A cheap balanced multirole fit. Initial is buy-only; A-rated is the multirole baseline; Engineered is optional on so cheap a hull but sharpens it if you wish.",
          "callout": {
            "label": "A little of everything, cheaply",
            "text": "The Adder's tiny internals fit modest guns, a small hold, a shield and a scoop or SRV — re-tune to try any role. It does each only modestly, but it lands anywhere and costs nothing, which is the whole point."
          },
          "notes": {
            "MediumHardpoint1": "The one medium mount carries the main gun; a gimballed multi-cannon is the easy all-round choice, Overcharged for more damage.",
            "SmallHardpoint1": "Gimballed pulse laser for shield work; Efficient keeps heat and power low on a tiny plant.",
            "SmallHardpoint2": "Second Efficient pulse pairs with the first for steady, cheap-to-run laser DPS.",
            "TinyHardpoint1": "A single shield booster is the cheapest large gain to the small bi-weave; Heavy Duty multiplies its raw MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Small plant runs everything; Overcharged adds the headroom a couple of guns and a shield need, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives lift the Adder's modest agility — the cheapest fun upgrade on the hull.",
            "FrameShiftDrive": "A-rated then Increased Range is the single best Adder upgrade; Mass Manager stretches jump range further for exploration.",
            "LifeSupport": "D-rate to save mass on a size-1 slot; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate for weapon and boost recharge; Engine Focused favours the boost that makes the light hull lively.",
            "Radar": "Drop to D and go Lightweight; a generalist needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Largest slot takes a bi-weave shield (3C — the only bi-weave rating at this size) for fast-regen survivability; Reinforced maximises its MJ.",
            "Slot02_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot06_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
