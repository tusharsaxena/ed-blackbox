  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "The whole exploration build on one screen. Initial is a jump-capable starter; A-Rated is the best buy-only expedition fit; Engineered is the long-range end state. The Type-11's problem is fixed: a class-5 FSD dragging a 320 t hull caps range near ~45 LY however hard you engineer it. The build leans on that hull's one asset — deep, redundant internals — and trims every core to save mass.",
          "callout": {
            "label": "The two modules that define the build",
            "text": "The Guardian FSD Booster (a flat range gain, unlocked at a Guardian site) and the size-6 fuel scoop (so you never strand) are non-negotiable. The rest is comfort, redundancy and survival kit the roomy hull carries easily — none of it fixes the range."
          },
          "notes": {
            "Armour": "Stock mining-grade lightweight alloy; G5 Lightweight shaves hull mass for a little more range.",
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running near hot stars.",
            "TinyHardpoint2": "One light booster cheaply multiplies the bi-weave's raw MJ for safer landings; Heavy Duty + Super Capacitors is the biggest gain per tonne.",
            "PowerPlant": "6D keeps mass down — with no guns to feed, output is not the limit; Low Emissions cuts heat and draw, Thermal Spread bleeds more.",
            "MainEngines": "5D thrusters; Clean Drive Tuning runs cool for safe planetary work and adds a little speed to climb out of gravity wells.",
            "FrameShiftDrive": "The whole build — a 5A SCO drive for the most range this hull can reach and fast in-system travel; Increased Range + Mass Manager is the single biggest roll.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "The size-7 core slot forces a heavy distributor this fit never uses; D-rate it to claw mass back — Engine Focused + Cluster Capacitors gives boost headroom on landing approaches.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional / low-priority — Shielded hardens the size-6 scoop; scoop rate is unchanged. Refuels fast from stars.",
            "Slot02_Size6": "A full size-6 AFMU — the roomy hull can carry a large repair reserve; Shielded hardens it. Repairs modules between sites.",
            "Slot03_Size6": "The Guardian FSD Booster — a flat jump-range gain unlocked at a Guardian site, not bought; under-fills the size-6 slot, non-engineerable, and the most range you can add.",
            "Slot04_Size5": "A size-5 bi-weave for a fast-regenerating landing buffer; Enhanced Low Power + Lo-Draw keeps its draw minimal (bi-weaves are C-rated only).",
            "Slot05_Size5": "A size-4 SRV hangar (2 bays) for exobiology and Guardian-site runs; under-fills the size-5 slot and carries no blueprint.",
            "Slot06_Size5": "A repair limpet controller in the hull's limpet-restricted slot, for hull repairs the AFMU cannot reach; under-fills and is not engineerable.",
            "Slot08_Size4": "A second AFMU for redundancy on long expeditions; Shielded hardens it.",
            "Slot09_Size3": "A spare 3C fuel tank widens reach between scoopable stars — the one thing the big internals genuinely buy you.",
            "Slot10_Size2": "Another small fuel tank; more range between refuels, no engineering.",
            "Slot11_Size1": "Detailed Surface Scanner; Expanded Probe Scanning widens probe coverage for full-system mapping."
          },
