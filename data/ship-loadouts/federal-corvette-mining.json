  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A mining fit that leans into the one thing the Corvette does better than any miner: surviving. The small and medium mounts carry the mining tools; the huge and large mounts carry guns so no pirate lives to rob you. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on defence, mobility and heat — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "Tools small, guns huge",
            "text": "The mining tools all fit the small and medium mounts — laser, seismic launcher, abrasion blaster, sub-surface missile — which frees the two huge and one large mounts for guns. A laden Corvette is the rare miner that wants to be interdicted. Refinery, two collectors and a prospector run the loop; ore fills the rest."
          },
          "notes": {
            "HugeHardpoint1": "Huge gimballed multi-cannon for pirate defence; Overcharged with a Corrosive Shell strips resistance off anyone who interdicts a laden hull.",
            "HugeHardpoint2": "Second huge multi-cannon; Auto Loader keeps it firing through the whole engagement so the loop never stops for long.",
            "LargeHardpoint1": "Gimballed beam for shield-stripping defence; Thermal Vent keeps it cold so it adds no heat over the mining tools.",
            "MediumHardpoint1": "Mining laser on the medium mount — the laser-mining tool; left stock, as mining lasers gain nothing from engineering.",
            "MediumHardpoint2": "Seismic charge launcher cracks asteroid cores; fixed medium, left stock — no useful blueprint exists.",
            "SmallHardpoint1": "Abrasion blaster knocks surface deposits loose for the collectors; stock, not engineerable.",
            "SmallHardpoint2": "Sub-surface displacement missile pops sub-surface deposits; stock, not engineerable.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up which rocks are worth cracking; A-rated for range, no blueprint available.",
            "TinyHardpoint2": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for the exposed minutes of cracking a core.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more shield strength against pirate alpha.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint6": "Third Heavy-Duty booster rounds out the shield stack once credits allow.",
            "PowerPlant": "Runs tools, limpets, a capital shield and the guns together; Low Emissions keeps heat down over long sessions, Thermal Spread bleeds more.",
            "MainEngines": "A-rated + Dirty Drives keep a 900t laden hull able to turn and run when the fight comes.",
            "FrameShiftDrive": "A-rated + Increased Range offsets the heavy laden hull when hauling ore home; Mass Manager extends jump range further.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate the class-8 FIRST — mining lasers, limpets and the guns all draw heavily; Engine Focused + Super Conduits feed the boost to escape.",
            "Radar": "D-rate and go Lightweight; mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement with Deep Plating is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across the internals; not engineerable.",
            "Slot01_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size7": "Bi-weave shield regenerates fast under fire; Reinforced maxes the MJ and Fast Charge restores its regen rate for the exposed core-cracking window.",
            "Slot04_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size6": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot08_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot09_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot10_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot11_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Distributor",
              "size": 8,
