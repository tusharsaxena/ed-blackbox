  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "ax-combat",
          "intro": "A tough anti-Xeno medium that tanks rather than dodges: three large Enhanced AX Multi-Cannons, two fixed Guardian Gauss on the mediums for heart-kills, Guardian reinforcement layered into the ten optionals (no military slots), and a tight four-utility AX kit. Initial is buy-only cores; A-Rated adds the unlocked AX kit; Engineered hardens shield, hull, heat and mobility.",
          "callout": {
            "label": "No military slots — harden in the optionals",
            "text": "Unlike the Chieftain or Krait, the Python has no military slots, so Guardian Module and Hull Reinforcement come out of its ten optionals — trading tank depth for module hardening. Gauss on the mediums for heart damage, large AX multi-cannons on the big mounts, and a deliberate four-utility kit: Xeno scanner, caustic sink, heat sink and a thermal-resistant booster. It absorbs the lightning a lighter hull would dodge."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon — the v2 large fills the big mount with sustained anti-Thargoid DPS; AX weapons take no engineering.",
            "LargeHardpoint2": "Second large Enhanced AX Multi-Cannon keeps continuous AX pressure on hearts and swarm; no blueprint.",
            "LargeHardpoint3": "Third large Enhanced AX Multi-Cannon — three large AX guns are the Python's sustained-fire core; no blueprint.",
            "MediumHardpoint1": "Fixed Guardian Gauss Cannon — the premium heart-killer; size 2 is the largest Gauss made, so the medium mount is a perfect fit; Guardian tech, no engineering.",
            "MediumHardpoint2": "Second fixed Guardian Gauss for the alpha that melts an Interceptor's exposed hearts fastest; no blueprint.",
            "TinyHardpoint1": "Xeno Scanner reveals Interceptor heart count and cycle — essential targeting data; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Single shield booster — only four utilities, so this one goes Thermal Resistant against Thargoid thermal damage; Super Capacitors adds raw MJ.",
            "PowerPlant": "A-rate first — Gauss and AX guns are power-hungry; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover what agility the heavy hull allows, to hold Gauss on a heart; Drag Drives sharpens the boost.",
            "FrameShiftDrive": "A-rated + Increased Range to reach distant AX sites and Maelstroms; Mass Manager stretches the jump further.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate + Charge Enhanced so the WEP capacitor sustains Gauss volleys; Super Conduits speeds the recharge.",
            "Radar": "Drop to D and go Lightweight — AX needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Class-6 Bi-Weave regenerates fast under fire; Thermal Resistant counters Thargoid thermal and Hi-Cap adds more MJ.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size6": "Guardian Module Reinforcement protects internals from the lightning the Python can't harden with military slots; Guardian MRP caps at size 5, so it under-fills this size-6 slot; no blueprint.",
            "Slot04_Size5": "Guardian Hull Reinforcement adds armour AND caustic resistance — the AX-specific hardening; Guardian tech, no blueprint.",
            "Slot05_Size5": "Second Guardian Module Reinforcement spreads more penetrating-hit protection across the cores; not engineerable.",
            "Slot06_Size4": "Guardian Hull Reinforcement stacks more armour and caustic resistance where the slot allows; no blueprint.",
            "Slot07_Size3": "Decontamination Limpet Controller scrubs caustic damage that the sink can't fully purge; limpet controllers carry no blueprint.",
            "Slot08_Size3": "Third Guardian HRP for more effective armour and caustic resistance; Guardian tech, no blueprint.",
            "Slot09_Size2": "Regular Hull Reinforcement — the one HRP that CAN be engineered; Heavy Duty + Deep Plating maximise raw armour.",
            "Slot10_Size1": "Guardian FSD Booster extends jump range to reach far AX sites and Maelstroms; Guardian tech, not engineerable."
          },
