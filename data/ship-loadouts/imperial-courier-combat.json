      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A pure shield-tank skirmisher fit. Initial is buy-only; A-rated is the combat-ready baseline; Engineered maximises shields and speed — the only things keeping this hull alive.",
          "callout": {
            "label": "Shields are everything",
            "text": "With paper armour and no military slots, the Courier lives entirely on shields — three Heavy-Duty boosters, a Reinforced bi-weave and cell banks. The moment shields drop, disengage; the bare hull won't last seconds."
          },
          "notes": {
            "MediumHardpoint1": "Primary gimballed multi-cannon; Overcharged for damage and the single Corrosive Shell strips target resistance for the whole battery.",
            "MediumHardpoint2": "Second gimballed multi-cannon; Overcharged + Auto Loader keeps it firing through reloads.",
            "MediumHardpoint3": "Gimballed beam for shield-stripping; Efficient + Thermal Vent runs it cold on this heat-tight hull.",
            "TinyHardpoint1": "First of the booster stack; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster; stacking is the Courier's only path to a real shield.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays on so light a hull.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "PowerPlant": "A-rate and Overcharge to power three guns, a big shield and cell banks; Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives push the 35t hull to its blistering speed ceiling — speed is half the defence.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; only G3 range — a skirmisher doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate to sustain three guns plus the shield-cell draw; Charge Enhanced refills WEP faster.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass on a hull that lives on speed.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Bi-weave regenerates fast under fire — ideal for a hit-and-run skirmisher; Reinforced maxes its MJ and Hi-Cap adds more.",
            "Slot02_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot04_Size2": "Heavy-Duty hull reinforcement — the cheapest large multiplier on the Courier's otherwise paper armour.",
            "Slot05_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot06_Size1": "More Heavy-Duty hull where the small slot allows; armour stacks linearly.",
            "Slot07_Size1": "More internal protection for the modules that keep you flying; not engineerable.",
            "Slot08_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies."
          },
