  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A budget tourer fit — a premium cabin up top, economy below, a real shield and a long-range SCO FSD, hardpoints clean. Initial is buy-only; A-Rated is the passenger baseline; Engineered maximises reach and keeps the board safe. The Asp has no military slots.",
          "callout": {
            "label": "Premium up top, economy below",
            "text": "Put your one high-value first/luxury cabin in the class-6 slot — it's where the per-seat money lives — and fill the rest with economy. Keep the class-5 as a bi-weave shield on threatened routes; swap it for a second luxury cabin only when the run is safe and escorted. With no comfort bonus, range and access are what the Asp brings; swap the cabins for an explorer suite when the week turns."
          },
          "notes": {
            "TinyHardpoint1": "Shield booster stacks raw MJ onto the bi-weave; Heavy Duty is the cheapest large gain in passenger safety.",
            "TinyHardpoint2": "Second Heavy-Duty booster — diminishing returns set in but still the best-value defence on a soft hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "5A covers cabins, shield and boost; Low Emissions runs it cool and quiet, Thermal Spread bleeds the rest.",
            "MainEngines": "A-rated + Dirty Drives keep the loaded hull mobile enough to break interdictions and dock fast.",
            "FrameShiftDrive": "The defining module — 5A SCO for in-system speed; Increased Range + Mass Manager take scattered boards in fewer hops.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; lower mass compounds with the FSD for range. No experimental.",
            "PowerDistributor": "4A for boost and pip recovery; Engine Focused + Super Conduits favour the engine cap to escape trouble.",
            "Radar": "Drop to D and go Lightweight; tourism needs no sensor range, so save the mass for jump range. No experimental.",
            "FuelTank": "5C stock tank sized to the SCO FSD's thirst; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "The one premium berth — a First Class cabin in the largest slot, where the per-seat money lives. Cabins are not engineerable.",
            "Slot02_Size5": "Bi-weave regenerates fast under fire for passenger safety; Reinforced maximises MJ, Fast Charge speeds recovery. Swap for a Luxury cabin on safe, escorted runs.",
            "Slot03_Size3": "Business Class cabin adds mid-tier fares above the economy floor; cabins carry no blueprint.",
            "Slot04_Size3": "Economy cabin — bulk seats that fill the board cheaply; not engineerable.",
            "Slot05_Size3": "Economy cabin — more bulk seats; not engineerable.",
            "Slot06_Size2": "Economy cabin — small-slot seats round out the manifest; not engineerable.",
            "Slot07_Size2": "Economy cabin — last of the bulk economy berths; not engineerable.",
            "Slot08_Size1": "Size-1 slot fits no passenger cabin (economy starts at size 2), so a Guardian FSD Booster goes here to stretch jump range; not engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
