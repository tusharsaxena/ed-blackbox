  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A balanced six-gun combat fit using the deep optionals to shield-tank. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern. Re-weight optionals toward hull reinforcement for a tankier variant.",
          "callout": {
            "label": "Tank with the depth, not military slots",
            "text": "The Corsair has no military bays, but ten optionals — three of them class-6 — let it tank deeply anyway. Decide shield-tank vs hull-tank and weight the optionals accordingly; you have the room either way."
          },
          "notes": {
            "LargeHardpoint1": "Primary large multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so its DPS never pauses.",
            "LargeHardpoint3": "Large beam strips shields; Thermal Vent vents heat so it runs cold under sustained fire.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a Thermal-Vent beam once A-rated for heat-free shield work.",
            "MediumHardpoint2": "Medium multi-cannon adds sustained kinetic DPS; Auto Loader keeps it topped up.",
            "MediumHardpoint3": "Second medium multi-cannon; Auto Loader keeps the kinetic fire uninterrupted.",
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks raw MJ onto the bi-weave.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers six guns plus a shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the Imperial speed and agility that define the Corsair.",
            "FrameShiftDrive": "A-rated to reach fights and turn-ins; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — six guns plus boost drain the class-7 distributor faster than anything else.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast for a brawler that re-engages; Reinforced maximises MJ and Fast Charge keeps regen high.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size6": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-6 slot for max effective armour.",
            "Slot04_Size5": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Slot05_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size5": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot07_Size4": "More Heavy-Duty hull where the slot allows.",
            "Slot08_Size3": "More internal protection for the modules that keep you flying; not engineerable.",
            "Slot09_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
