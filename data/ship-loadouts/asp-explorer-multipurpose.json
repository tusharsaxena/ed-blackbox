  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multipurpose fit — able to defend itself, carry a useful load and still jump well. Initial is buy-only; A-rated is the all-round baseline; Engineered layers the Asp's signature jump range on top. Re-role by swapping the optional internals: cargo for trading, a cabin for passengers, mining tools plus a refinery for ore, or scanners plus an SRV bay and a fuel scoop for exploration.",
          "callout": {
            "label": "Re-role by the optionals",
            "text": "Cores stay fixed; the optional internals define the job. Cargo racks for trading, a class-5 cabin for passengers, mining laser plus refinery plus collectors for ore, or scanners plus AFMU plus a size-6 fuel scoop and SRV bay for exploration — one hull, four ships."
          },
          "notes": {
            "MediumHardpoint1": "Main gun on the larger mount; a gimballed multi-cannon is the easy all-round pick, Overcharged with the one Corrosive Shell to strip armour resistance.",
            "MediumHardpoint2": "Second medium runs a beam for shield-stripping; Thermal Vent vents heat so it stays cool under sustained fire.",
            "SmallHardpoint1": "Gimballed small multi-cannon adds chip damage; Auto Loader keeps it firing without reloads.",
            "SmallHardpoint2": "Second small multi-cannon pairs with the first; Auto Loader keeps its DPS uninterrupted.",
            "SmallHardpoint3": "Gimballed pulse for shield work; Efficient keeps heat and power low on a medium hull.",
            "SmallHardpoint4": "Second Efficient pulse rounds out the laser battery for steady, cheap-to-run DPS.",
            "TinyHardpoint1": "One shield booster is the cheapest large gain to the bi-weave; Heavy Duty multiplies its raw MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Long Range extends scan reach. Reveals bounties for higher payouts.",
            "PowerPlant": "Powers guns, shield and utilities together; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated plus Dirty Drives lift the Asp's modest agility for combat and docking.",
            "FrameShiftDrive": "A-rate first — range is the Asp's calling card; Increased Range plus Mass Manager pushes the laden jump past 60 LY.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate for weapon and boost recharge; Charge Enhanced plus Super Conduits sustains the battery and boost.",
            "Radar": "Drop to D and go Lightweight; a generalist needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot02_Size5": "Bi-weave shield (5C — the only bi-weave rating at this size) for fast regen; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot03_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size3": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stack it.",
            "Slot05_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot07_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
