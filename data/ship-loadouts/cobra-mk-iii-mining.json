  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete small-pad mining fit for laser and core work, trading ore hold for a basic shield. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on range, heat and a bi-weave — the mining tools themselves are not meaningfully engineered. For pure laser mining, drop the seismic launcher and missile for a third cargo rack.",
          "callout": {
            "label": "Tools first, ore where it fits",
            "text": "The hardpoints take the full toolkit — mining laser, seismic launcher, sub-surface missile and abrasion blaster — with a Pulse Wave Analyser to find rocks. The squeeze is internals: a refinery, two collector controllers and a prospector leave only two class-4 racks for ore, so the hold caps near 32 t. Drop the bi-weave for a third rack if you mine somewhere quiet."
          },
          "notes": {
            "MediumHardpoint1": "The primary laser-mining tool; a medium fixed laser is the largest the hull mounts, and mining tools carry no weapon blueprint.",
            "MediumHardpoint2": "Core mining's main tool — lob a seismic charge into a fissure to crack the rock; the fixed medium warhead is the only size and is not engineerable.",
            "SmallHardpoint1": "Sub-surface Displacement Missile reaches the deep deposits the blaster can't; no blueprint applies.",
            "SmallHardpoint2": "Abrasion Blaster shears surface deposits off a cracked core for the limpets to scoop; mining tools aren't engineerable.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks and core fissures; held at class 3 so it doesn't swamp the small power budget, and scanners carry no blueprint.",
            "TinyHardpoint2": "One Heavy-Duty booster roughly doubles the small bi-weave's raw MJ — the cheapest survivability gain on the hull.",
            "PowerPlant": "A-rate it to run the laser, seismic launcher and limpet swarm together; Low Emissions + Thermal Spread keep heat down through long sessions.",
            "MainEngines": "A-rated thrusters with Dirty Drive Tuning + Drag Drives so the light hull can boost clear of interdictions it can't win.",
            "FrameShiftDrive": "Increased Range + Mass Manager stretch every jump so the short-legged Cobra reaches distant rings and hauls ore home in fewer hops.",
            "LifeSupport": "D-rated and Lightweight — life support is mass to shed on a small frame, and it has no experimental effect.",
            "PowerDistributor": "A-rate the class-3 distributor or the tools and limpets brown out together; Engine Focused at G3 feeds the boost you escape pirates with.",
            "Radar": "Dropped to D and Lightweight — a miner needs no sensor range, so save the mass; sensors have no experimental effect.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Bi-weave regenerates fast under fire; Reinforced + Fast Charge maximise MJ while keeping the quick recharge — a buffer for the exposed minutes of cracking a core, not a pirate fight.",
            "Slot04_Size2": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot05_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
