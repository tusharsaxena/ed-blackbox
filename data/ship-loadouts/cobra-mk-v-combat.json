  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A five-gun shield-tank combat fit. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern. The deep optionals let it tank harder than any small rival.",
          "callout": {
            "label": "Tank like a medium",
            "text": "Nine optionals let the Mk V carry a real shield-and-reinforcement stack no other small ship can match. Shield-tank it with a bi-weave, cell banks and Heavy-Duty reinforcement — it'll survive fights that destroy lighter fighters."
          },
          "notes": {
            "MediumHardpoint1": "Primary medium multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint3": "Medium beam for shield-stripping; Thermal Vent keeps it running cold under sustained fire.",
            "SmallHardpoint1": "Buy a cheap multi-cannon, swap to an Efficient pulse once A-rated for cool, distributor-light shield work.",
            "SmallHardpoint2": "Second small pulse adds chip damage; Efficient + Thermal Vent keeps it cool on a class-4 power budget.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large tank gain.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more shield strength before utilities turn to defence.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Class-4 plant runs five guns, a big shield and cells; Overcharged adds the headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the speed and agility that define the small hull.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — five guns plus boost drain the class-4 distributor faster than anything else.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Bi-weave regenerates fast under fire for a brawler that re-engages; Reinforced maximises its MJ and Fast Charge speeds regen.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size4": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Slot04_Size4": "Second Heavy-Duty HRP — armour stacks linearly, so two size-4 plates push effective hull past 1,400.",
            "Slot05_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size3": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot07_Size3": "More Heavy-Duty hull where the slot allows.",
            "Slot08_Size2": "Module Reinforcement protects the cores that keep you flying; not engineerable.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
