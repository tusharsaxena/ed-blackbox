  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A fast, aggressive interceptor fit. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern, leaning on speed since defences are thin.",
          "callout": {
            "label": "Speed is the defence",
            "text": "With thin armour and only two utilities, the Viper Mk III survives by speed and aggression, not tanking — run a bi-weave buffer and the military-slot HRP, but win fights fast and disengage if shields fall."
          },
          "notes": {
            "MediumHardpoint1": "Primary medium gun; the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so its DPS never pauses.",
            "SmallHardpoint1": "Pulse laser for shield-stripping; Efficient slashes draw and heat on the small plant, Thermal Vent runs it cold.",
            "SmallHardpoint2": "Second Efficient pulse; matched experimental keeps both small mounts heat-free under sustained fire.",
            "TinyHardpoint1": "Only shield booster the ship can spare a mount for; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "PowerPlant": "Class-3 plant runs four guns and a shield with no margin; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate FIRST — speed is the Viper's whole identity; Dirty Drives + Drag Drives push boost well past 480 m/s.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; only G3 range — a brawler needs no jump monster.",
            "LifeSupport": "D-rate to save mass on a speed hull, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate early — four guns plus boost drain the class-3 distributor fast; Super Conduits deepen the WEP reservoir.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass for speed.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the size-3 military slot is the cheapest large multiplier on the thin armour.",
            "Slot01_Size3": "Bi-weave regenerates fast between passes — the right buffer for a hit-and-run hull; Reinforced maximises MJ, Fast Charge restores its regen edge.",
            "Slot02_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size2": "Second Heavy-Duty hull reinforcement stacks linearly on effective armour.",
            "Slot04_Size1": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot05_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size1": "Last size-1 slot takes more Heavy-Duty hull where it fits."
          },
          "engineeringPlan": [
            {
              "module": "Thrusters",
              "size": 3,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
