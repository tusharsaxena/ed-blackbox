    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A mobile medium gunship: an Overcharged multi-cannon pair on the large mounts with Corrosive Shell, a gimballed medium multi-cannon and an Efficient beam with Thermal Vent for shield-stripping and heat control. Initial is buy-only cores; A-Rated adds the weapons, a bi-weave and hull tank; Engineered turns it into a fast, evasive brawler. The Phantom fights on the move — strip shields with the beam, chew hull with corrosive multi-cannons, and boost out when pressed.",
          "callout": {
            "label": "Strip with the beam, chew with corrosives, stay mobile",
            "text": "Two large multi-cannons with Corrosive Shell shred hull; the Efficient beam with Thermal Vent drops shields while dumping your own heat. With only two large mounts and a lighter tank than the Mk II, the Phantom wins by out-turning and out-running trouble — keep the bi-weave up, boost to reset engagements, and pick fights you can leave."
          },
          "notes": {
            "LargeHardpoint1": "Primary hull-breaker. Gimballed large multi-cannon, Overcharged for raw damage; Corrosive Shell raises every other weapon's hull damage — the pair's force multiplier.",
            "LargeHardpoint2": "Second Overcharged large multi-cannon with Auto Loader for near-continuous fire; together the pair is the Phantom's sustained hull DPS.",
            "MediumHardpoint1": "Efficient gimballed beam laser strips shields and, with Thermal Vent, vents your heat on every hit — the fit's heat valve as well as its shield-stripper.",
            "MediumHardpoint2": "Gimballed medium multi-cannon, Overcharged with Auto Loader; adds chip damage and keeps corrosive stacks topped while the larges reload.",
            "TinyHardpoint1": "Shield Booster grows the bi-weave; Heavy Duty for maximum raw boost.",
            "TinyHardpoint2": "Second Shield Booster; stacked boosters are the cheapest big shield multiplier on a medium.",
            "TinyHardpoint3": "Chaff throws off gimbal and turret tracking — the Phantom's evasion tool against other players and hard-tracking NPCs.",
            "TinyHardpoint4": "Heat Sink Launcher dumps heat for silent running and cools spikes from the beam and Overcharged plant.",
            "PowerPlant": "A-rate first — Overcharged weapons are power-hungry; Overcharged plant adds headroom and Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives is the Phantom's whole case: out-run and out-turn heavier combat mediums.",
            "FrameShiftDrive": "A-rated; Increased Range + Mass Manager keep the premium jump so it doubles as a fast traveller between fights.",
            "LifeSupport": "A-rated for a long oxygen timer after a canopy breach; Lightweight trims mass; no experimental effect.",
            "PowerDistributor": "Charge Enhanced + Super Conduits feed the weapon capacitor so the multi-cannon pair and beam keep firing.",
            "Radar": "D-rated and Lightweight — save the mass for speed; combat needs no sensor range.",
            "FuelTank": "Stock size-5 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-Weave regenerates fast under fire; Reinforced + Fast Charge suits a mobile brawler that resets engagements.",
            "Slot02_Size5": "Shield Cell Bank restores the shield in a burst; Specialised keeps thermal load low.",
            "Slot03_Size5": "Hull Reinforcement — Heavy Duty + Deep Plating stacks effective armour for when the shield drops.",
            "Slot04_Size5": "More Heavy Duty hull reinforcement; effective armour stacks linearly and covers the lighter Phantom frame.",
            "Slot05_Size3": "Second Shield Cell Bank for a longer fight; Specialised for the low heat cost.",
            "Slot06_Size3": "Additional Hull Reinforcement tops up the tank the Phantom lacks against the Mk II.",
            "Slot07_Size3": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot08_Size2": "More Module Reinforcement protects the cores that keep you flying; no blueprint available.",
            "Slot09_Size1": "A small Module Reinforcement fills the last slot; not engineerable."
          },
          "engineeringPlan": [
            { "module": "Multi-Cannon (Large ×2 · Medium ×1)", "grade": "G5", "blueprint": "Overcharged", "experimental": "Corrosive Shell / Auto Loader", "engineer": "Tod McQuinn" },
            { "module": "Beam Laser", "size": 2, "grade": "G5", "blueprint": "Efficient", "experimental": "Thermal Vent", "engineer": "Broo Tarquin" },
            { "module": "Power Plant", "size": 7, "grade": "G5", "blueprint": "Overcharged", "experimental": "Thermal Spread", "engineer": "Hera Tani" },
            { "module": "Thrusters", "size": 6, "grade": "G5", "blueprint": "Dirty Drive Tuning", "experimental": "Drag Drives", "engineer": "Professor Palin / Mel Brandon" },
            { "module": "Frame Shift Drive", "size": 5, "grade": "G5", "blueprint": "Increased Range", "experimental": "Mass Manager", "engineer": "Felicity Farseer" },
            { "module": "Power Distributor", "size": 7, "grade": "G5", "blueprint": "Charge Enhanced", "experimental": "Super Conduits", "engineer": "The Dweller" },
            { "module": "Bi-Weave Shield", "size": 6, "grade": "G5", "blueprint": "Reinforced", "experimental": "Fast Charge", "engineer": "Lei Cheung" },
            { "module": "Shield Booster", "grade": "G5", "blueprint": "Heavy Duty", "experimental": "Super Capacitors", "engineer": "Didi Vatermann" },
            { "module": "Hull Reinforcement", "grade": "G5", "blueprint": "Heavy Duty", "experimental": "Deep Plating", "engineer": "Selene Jean" },
            { "module": "Bulkheads", "blueprint": "Heavy Duty", "grade": "G5", "engineer": "Selene Jean", "experimental": "Deep Plating" }
          ]
        }
