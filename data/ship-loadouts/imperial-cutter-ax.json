  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "An AX attrition fit built around the game's best shields: four Gauss cannons on the mediums, AX multi-cannons and a Guardian shard on the large and huge mounts, a prismatic shield, and Guardian reinforcement in the military and optional slots. Initial is buy-only; A-Rated adds the kit; Engineered hardens the shield, mobility and survival.",
          "callout": {
            "label": "Tank first, Gauss the mediums",
            "text": "The Cutter's AX identity is its shield-and-hull wall — prismatic generator, Guardian reinforcement in both military slots and across the optionals, and cell banks to ride out the strikes you can't dodge. Four Gauss cannons on the mediums are the kill suite; the large and huge mounts add an AX multi-cannon and a shard. The huge slot can only take a large AX weapon, so accept it runs under-class. Manage heat hard — Gauss runs hot."
          },
          "notes": {
            "HugeHardpoint1": "No AX weapon comes in huge, so a large gimballed Enhanced AX Multi-Cannon under-fills this mount; Long Range stretches its falloff to reach Interceptors at standoff.",
            "LargeHardpoint1": "Second Enhanced AX Multi-Cannon for sustained anti-xeno DPS; Long Range keeps full damage out to the Gauss engagement band.",
            "LargeHardpoint2": "Guardian Shard Cannon adds heavy close-range burst against hearts and hull; Long Range widens its usable falloff on this short-range weapon.",
            "MediumHardpoint1": "Fixed Guardian Gauss Cannon — the primary heart-killer; Long Range is the one worthwhile blueprint, raising damage at range.",
            "MediumHardpoint2": "Second Gauss; the four-gun battery is the kill suite that ends Interceptor fights.",
            "MediumHardpoint3": "Third Gauss; stagger fire-groups to spread the heavy thermal load.",
            "MediumHardpoint4": "Fourth Gauss completes the Gauss wall on the mediums.",
            "TinyHardpoint1": "Enhanced Xeno Scanner reads Interceptor heart count and subsystems; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Shield Booster on Thermal Resistant — the cheapest large gain against Thargoid thermal strikes.",
            "TinyHardpoint6": "Second Thermal-Resistant booster stacks more resisted MJ onto the prismatic wall.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Feeds power-hungry Gauss, a class-8 prismatic and the cell-bank draw; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recovers what mobility a 1,100t hull can manage between damage windows.",
            "FrameShiftDrive": "A-rated to relocate a heavy hull between AX sites; Increased Range with Mass Manager offsets the deep reinforcement mass.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — four Gauss draw hard on the WEP capacitor; Charge Enhanced plus Super Conduits sustains the volley rate.",
            "Radar": "Drop to D and go Lightweight; AX combat is close-range, so trade sensor reach for mass.",
            "FuelTank": "Stock class-6 tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement shields the internals from penetrating Thargoid hits; Guardian reinforcement is not engineerable.",
            "Military02": "Second Guardian MRP — the deepest module hardening of any AX hull; not engineerable.",
            "Slot01_Size8": "Class-8 prismatic — the best raw shield in the game; Thermal Resistant plus Hi-Cap tunes it against Thargoid thermal damage.",
            "Slot02_Size8": "Guardian Hull Reinforcement caps at size 5, so a 5D GHRP under-fills this size-8 slot; Guardian HRP adds innate caustic resist and cannot be engineered.",
            "Slot03_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot04_Size6": "Second size-5 Guardian HRP under-filling a size-6 slot; armour and caustic resist stack linearly.",
            "Slot05_Size6": "Guardian Shield Reinforcement adds flat shield HP with caustic resist; not engineerable.",
            "Slot06_Size5": "Decontamination Limpet Controller scrubs caustic from the hull mid-fight; limpet controllers carry no blueprint.",
            "Slot07_Size5": "Third size-5 Guardian HRP fills this military-class optional for more effective armour.",
            "Slot08_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot09_Size3": "Size-3 Guardian HRP — more caustic-resistant armour where the slot allows.",
            "Slot10_Size1": "Size-1 Guardian HRP tops off the hull stack in the last small optional."
          },
          "engineeringPlan": [
            {
