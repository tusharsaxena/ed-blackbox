  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multipurpose fit — capable in a RES, able to carry meaningful cargo, and survivable. Re-role by swapping the optional internals: cargo racks for hauling, a passenger cabin for missions, mining tools plus a refinery for ore, or exploration modules for the black. Initial is buy-only; A-rated gets the cores to A so the ship is good at everything; Engineered applies one balanced pass that serves every role.",
          "callout": {
            "label": "Re-role by the optionals",
            "text": "The cores stay fixed; the optional internals define the job. Cargo racks for trading, a class-4/5 passenger cabin for missions, mining laser + refinery + collectors for ore, or scanners + AFMU + fuel scoop for exploration — same hull, four ships."
          },
          "notes": {
            "MediumHardpoint1": "Gimballed multi-cannon for sustained kinetic DPS; Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second gimballed multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint3": "Buy a cheap multi-cannon, swap to a gimballed beam once A-rated — Thermal Vent makes it shed heat while it strips shields.",
            "SmallHardpoint1": "Small gimballed pulse for cheap, low-heat shield-stripping; Phasing Sequence leaks damage through shields.",
            "SmallHardpoint2": "Second small pulse; Efficient cuts power and heat so the whole battery stays in the green.",
            "TinyHardpoint1": "Shield booster multiplies the bi-weave's raw MJ; Heavy Duty is the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Long Range extends scan reach. Reveals bounties for higher payouts.",
            "PowerPlant": "Overcharged adds the headroom to run guns, shields and utilities together; Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives give the speed and agility a multipurpose hull needs for combat and quick missions.",
            "FrameShiftDrive": "A-rate early — range matters across every role; Mass Manager squeezes extra jump from the small hull.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate FIRST — it feeds both weapons and boost, the foundation of every role; Super Conduits speed weapon recharge.",
            "Radar": "Drop to D and go Lightweight; no role here needs sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Bi-weave regenerates fast under fire — balanced defence for mixed-threat play; Reinforced maxes its MJ, Fast Charge keeps its quick-regen identity.",
            "Slot02_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size4": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Slot05_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size3": "Second Heavy-Duty hull reinforcement; armour stacks linearly.",
            "Slot07_Size3": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot08_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot09_Size1": "Second Module Reinforcement protects the cores that keep you flying; not engineerable."
          },
          "engineeringPlan": [
