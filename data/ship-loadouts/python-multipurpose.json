      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit — real guns, a strong shield, cargo room and decent range, ready to re-tune. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it excellent across the board.",
          "callout": {
            "label": "Re-tune for the job",
            "text": "One balanced configuration — the Python's strength is swapping at a station: strip guns and HRPs for a fuel scoop, SRV and cargo to explore; fill with cargo to trade; add a mining suite (lasers, refinery, limpets) to mine. Keep role module sets in storage."
          },
          "notes": {
            "LargeHardpoint1": "Primary large mount; one Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so DPS never pauses.",
            "LargeHardpoint3": "Large beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "MediumHardpoint1": "Medium pulse fill-in; Efficient keeps it cool and power-cheap, Thermal Vent dumps heat.",
            "MediumHardpoint2": "Second medium pulse rounds out the battery; same Efficient + Thermal-Vent pattern.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for cheap.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers guns, shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives keep the Python agile for combat and quick docking.",
            "FrameShiftDrive": "A-rated + Increased Range with Mass Manager gives the all-rounder respectable jump legs.",
            "LifeSupport": "A-rated for long emergency oxygen; Lightweight trims mass; no experimental effect.",
            "PowerDistributor": "A-rate for sustained weapon and boost draw; Charge Enhanced + Super Conduits keep WEP and ENG full.",
            "Radar": "Drop to D and go Lightweight; multirole needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size4": "Heavy-Duty hull reinforcement — the cheapest large multiplier on effective armour.",
            "Slot07_Size3": "Second Heavy-Duty HRP stacks more effective armour for combat work.",
            "Slot08_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
