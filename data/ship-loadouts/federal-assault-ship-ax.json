  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "ax-combat",
          "intro": "An agile AX brawler: enhanced AX multi-cannons on the large mounts for shields and scouts, Guardian Gauss Cannons on the mediums for heart damage, both military slots filled with Guardian reinforcement, and a tight four-utility AX kit. Initial is buy-only; A-Rated adds the unlocked AX kit; Engineered hardens hull, shield buffer and — above all — mobility.",
          "callout": {
            "label": "Dodge first, harden second",
            "text": "The FAS has no fighter bay and only four utilities, so the AX kit is tight: Xeno scanner, caustic sink and heat sink take three mounts, leaving one shield booster. Fill both military slots and a couple of optionals with Guardian reinforcement, run a bi-weave purely as a regenerating buffer over the armour tank, and rely on the flight model to roll out of the lightning. Put Gauss on the mediums for heart damage and AX multi-cannons on the large mounts."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX multi-cannon, gimballed for the agile striker — strips Thargoid shields and clears scouts; AX guns carry no player engineering.",
            "LargeHardpoint2": "Second large enhanced AX multi-cannon doubles the anti-shield and anti-scout output; not engineerable.",
            "MediumHardpoint1": "Guardian Gauss Cannon, fixed — the FAS's heart-killer; pre-engineered, no player blueprints.",
            "MediumHardpoint2": "Second Gauss doubles heart DPS but drains the distributor fast — manage charge between shots.",
            "TinyHardpoint1": "Xeno Scanner exposes Interceptor hearts and subsystems; scanners cannot be engineered.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "The one shield booster the four-utility kit allows; Thermal Resistant hardens the thin buffer against Thargoid thermals.",
            "PowerPlant": "6A powers Gauss, the AX guns and the utility kit; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the dodge that is the FAS's whole AX case.",
            "FrameShiftDrive": "A-rated to reach the fight; only G3 range — AX combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate FIRST — twin Gauss empty the capacitor faster than anything; Charge Enhanced + Super Conduits keep it firing.",
            "Radar": "Drop to D and go Lightweight; AX needs no sensor range, so save the mass.",
            "FuelTank": "Stock 4C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement hardens internals against the lightning; Guardian modules carry no blueprints.",
            "Military02": "Second Guardian MRP — the FAS's two military slots are its key AX hardening.",
            "Slot01_Size5": "Bi-weave runs as a fast-regenerating buffer over the armour tank; Thermal Resistant + Hi-Cap fit it for Thargoid thermals.",
            "Slot02_Size5": "Guardian Hull Reinforcement adds armour and caustic resistance; not engineerable.",
            "Slot03_Size4": "More Guardian HRP layering — armour and caustic resist where the slot allows.",
            "Slot04_Size3": "Decontamination Limpet Controller scrubs caustic clouds off the hull mid-fight; limpet controllers have no blueprint.",
            "Slot05_Size2": "Third Guardian Module Reinforcement spreads more module protection; not engineerable.",
            "Slot06_Size2": "Standard Hull Reinforcement — Heavy Duty + Deep Plating is the cheapest large multiplier on effective armour.",
            "Slot07_Size1": "Size-1 Guardian Hull Reinforcement tops up armour and caustic resistance in the last slot; not engineerable."
          },
