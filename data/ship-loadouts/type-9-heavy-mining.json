  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A high-volume laser-mining barge that also carries the core- and surface-mining toolkit. Initial is a buy-only starter; A-rated is the productive baseline; Engineered focuses on the cores that matter for a barge — thrusters and FSD for transit, a survivable shield, and mass-managed range. Mining tools themselves cannot be engineered.",
          "callout": {
            "label": "Limpets do the work",
            "text": "Fit several collector controllers (each runs multiple limpets) so the ore flows in while you keep cutting, and one or two prospector controllers to boost yield per rock. The class-8 slots are pure cargo — never waste them on anything else."
          },
          "notes": {
            "MediumHardpoint1": "Primary mining laser — a sustained beam fractures asteroids into fragments for the collectors.",
            "MediumHardpoint2": "Second mining laser doubles cutting rate; mining lasers carry no blueprint, so they stay stock.",
            "MediumHardpoint3": "Seismic Charge Launcher cracks deep-core motherlodes; it is a size-2 tool, so it must sit on a medium mount.",
            "SmallHardpoint1": "Abrasion Blaster knocks surface deposits off rocks; it is a size-1 tool and only fits a small mount.",
            "SmallHardpoint2": "Sub-surface Displacement Missile extracts sub-surface deposits; the small variant frees the mediums for lasers.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up core- and surface-deposit rocks across the ring; not engineerable.",
            "TinyHardpoint2": "Heavy-Duty shield booster multiplies the bi-weave's raw MJ against pirate interdictions.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Second Heavy-Duty booster — the cheapest large gain in shield strength for a soft barge.",
            "PowerPlant": "A-rated for the limpet-fleet load; Low Emissions keeps heat & signature down and Thermal Spread bleeds the rest.",
            "MainEngines": "A-rated + Dirty Drives claw back what agility an 850t barge can have in the ring.",
            "FrameShiftDrive": "A-rated with Increased Range and Mass Manager to get laden cargo to market in fewer jumps.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rated so the lasers & limpets never starve; Charge Enhanced G3 is enough for mining draw.",
            "Radar": "Drop to D and go Lightweight — mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size4": "Bi-weave regenerates fast under fire; Reinforced maximises MJ and Fast Charge keeps it recovering between hits.",
            "Slot08_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot09_Size3": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot10_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot11_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets."
          },
          "engineeringPlan": [
            {
              "module": "Thrusters",
              "size": 7,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Frame Shift Drive",
              "size": 6,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Power Plant",
              "size": 6,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Power Distributor",
              "size": 6,
              "grade": "G3",
              "blueprint": "Charge Enhanced",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 4,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Bulkheads",
