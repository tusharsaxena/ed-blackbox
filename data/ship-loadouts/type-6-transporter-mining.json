  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete laser-mining fit on a budget, with a small shield to survive a pirate long enough to flee. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on range, mobility and a tougher shield — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "A laser suite plus a small shield",
            "text": "Two small hardpoints fit a mining laser and an abrasion blaster — a clean laser-mining setup. A Pulse Wave Analyser finds the rocks, a refinery and prospector/collector limpets work the loop, and a class-3 bi-weave keeps a small shield up. Core mining is possible by swapping a seismic launcher in, but with only two mounts you give up another tool to do it."
          },
          "notes": {
            "SmallHardpoint1": "Primary mining laser fractures the rock; mining lasers come in one rating only and aren't worth engineering.",
            "SmallHardpoint2": "Abrasion Blaster knocks surface deposits loose for the collectors; left stock like all mining tools.",
            "TinyHardpoint1": "A-rated Pulse Wave Analyser highlights mineral-rich rocks across the ring; analysers carry no blueprint.",
            "TinyHardpoint2": "Heavy Duty booster multiplies the small bi-weave's MJ — the cheapest survivability gain on the hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rated class-3 plant runs lasers, limpets and a shield together; Low Emissions keeps it cool and quiet through long sessions.",
            "MainEngines": "A-rated thrusters with Dirty Drives give the speed to reposition on rocks and flee an interdiction.",
            "FrameShiftDrive": "A-rated FSD with Increased Range reaches distant pristine hotspots and hauls the ore home.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate this first — lasers and limpets are power-hungry; Engine Focused keeps the boost charged for escapes.",
            "Radar": "Drop to D and go Lightweight; mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-4 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot04_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot05_Size3": "Class-3 bi-weave regenerates fast under fire; Reinforced maxes its MJ and Fast Charge speeds the recharge.",
            "Slot06_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot07_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
