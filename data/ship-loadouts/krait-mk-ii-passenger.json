  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A converted-combat-medium passenger fit: a mixed economy/first/luxury board behind a real bi-weave shield, with the FSD and thrusters engineered to claw back range from a heavy airframe. Initial is buy-only; A-rated is the tourist baseline; Engineered maximises what range this hull can reach. With no size-7 slot, the shield eats a size-6 bay, and the class-6 ceiling caps premium fit at a single luxury suite.",
          "callout": {
            "label": "A combat hull doing a liner's job",
            "text": "Nothing about the Krait Mk II is built for tourists — the fighter bay, the three large hardpoints and the 320t airframe are dead weight in passenger service, and its lighter Phantom sibling flies the same medium-pad routes with more range for less money. Fit it for passengers only if it is the medium you already own; otherwise the Phantom or a dedicated liner earns more per run. Strip cabins for a scoop or cargo the moment the week turns."
          },
          "notes": {
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for cheap passenger safety.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running.",
            "PowerPlant": "An unarmed liner needs little power, so Low Emissions trims heat and mass; Thermal Spread bleeds the rest for cool, quiet cruises.",
            "MainEngines": "A-rated + Dirty Drives keep the heavy loaded hull manoeuvrable in and out of stations and away from interdictions.",
            "FrameShiftDrive": "A-rate FIRST — G5 Increased Range plus Mass Manager is the only way to lift this heavy airframe's laden jump to a usable figure.",
            "LifeSupport": "A-rate for emergency-oxygen duration with passengers aboard; Lightweight trims mass and has no experimental effect.",
            "PowerDistributor": "Engine Focused biases the class-7 distributor toward boosting away from danger; Cluster Capacitors deepens the reservoir.",
            "Radar": "Drop to D and go Lightweight — a liner needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered. Pair with a scoop for long scenic legs.",
            "Slot01_Size6": "Bi-weave shield in a size-6 bay (no size-7 slot to relocate it); Reinforced maximises MJ and Fast Charge restores the quick recovery.",
            "Slot02_Size6": "Luxury Cabin 6 is the premium VIP suite — the largest cabin grade this class-6 ceiling accepts; swap to economy for bulk headcount.",
            "Slot03_Size5": "Economy Cabin 5 carries the volume; swap class to suit the board.",
            "Slot04_Size5": "First-Class Cabin 5 for higher-paying fares; cabins are never engineered.",
            "Slot05_Size4": "Economy Cabin 4 — bulk economy capacity for group transport fares.",
            "Slot06_Size3": "Economy Cabin 3 tops up headcount; swap to Business here for a mid-tier premium fare.",
            "Slot07_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot08_Size2": "Size-2 slot takes only an economy cabin (business/first/luxury start at size 3+); a couple of extra seats.",
            "Slot09_Size1": "Optional — Supercruise Assist eases the long sightseeing hops; the size-1 slot takes no passenger cabin (economy cabins start at size 2). Not engineerable."
          },
          "engineeringPlan": [
