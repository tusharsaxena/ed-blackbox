  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit — real firepower, strong shields, cargo room and good range, ready to re-tune for any role. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it excellent across the board.",
          "callout": {
            "label": "Built to re-tune",
            "text": "This is one balanced configuration; the Anaconda's strength is swapping module sets at a station — strip the guns and HRPs for a fuel scoop, SRV and cargo to explore; fill with cargo racks to haul; add a mining suite to mine. Keep role-specific module sets in storage and switch as the week demands."
          },
          "notes": {
            "HugeHardpoint1": "The single huge mount carries the build's alpha; Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint1": "Gimballed beam for shield-stripping; Thermal Vent keeps it cold under sustained fire.",
            "LargeHardpoint2": "Large multi-cannon for sustained kinetic DPS; Auto Loader removes reloads.",
            "LargeHardpoint3": "Large pulse adds efficient laser damage; Efficient + Thermal Vent runs it cool.",
            "MediumHardpoint1": "Medium multi-cannon fills the kinetic battery; Auto Loader keeps it firing.",
            "MediumHardpoint2": "Medium pulse rounds out the laser side; cheap on power and heat.",
            "SmallHardpoint1": "Small multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Small pulse fills the last hardpoint; swap freely when re-roling.",
            "TinyHardpoint1": "First shield-booster; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster before utilities turn to defence.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "Powers eight guns, a big shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover agility on a 400t capital hull.",
            "FrameShiftDrive": "A-rated with Increased Range and Mass Manager — the all-rounder needs the jump for explorer and trade roles.",
            "LifeSupport": "A-rated for endurance; Lightweight trims mass — life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — guns plus boost drain the class-8 distributor; Charge Enhanced + Super Conduits keep WEP and ENG full.",
            "Radar": "Drop to D and go Lightweight; multirole needs no sensor range, so save the mass for jump.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot is the cheapest large multiplier on effective armour.",
            "Slot01_Size7": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more — the survivable all-round choice.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size5": "Hull reinforcement caps at size 5, so a 5D HRP fully fills this slot for max effective armour.",
            "Slot06_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size4": "Heavy-Duty hull reinforcement (a 4D HRP) where the slot allows; armour stacks linearly.",
            "Slot09_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot10_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot11_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
