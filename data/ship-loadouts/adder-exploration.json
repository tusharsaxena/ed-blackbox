        "edbb": {
          "role": "exploration",
          "intro": "A cheap, versatile explorer fit that keeps a little cargo room. Initial is buy-only; A-rated is the expedition baseline; Engineered maximises range within the small frame.",
          "callout": {
            "label": "Explore, with room to haul",
            "text": "The Adder's seven optionals fit a scoop, Guardian booster, scanner, small SRV bay and AFMU — with a slot or two left for cargo. That flexibility is the point: the same cheap hull explores or hauls as the trip demands."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Heavy Duty multiplies raw shield strength.",
            "PowerPlant": "D-rate to save mass; Low Emissions runs the plant cool so you can sit deep in a star's corona and scoop.",
            "MainEngines": "D-rated thrusters are plenty for a 35t hull; Clean Drive Tuning trims heat and Stripped Down sheds mass for range.",
            "FrameShiftDrive": "A-rate this FIRST and max Increased Range with Mass Manager — jump range is the whole point of the build.",
            "LifeSupport": "D-rate and Lightweight to save every kilo; life support has no experimental effect.",
            "PowerDistributor": "D-rate is enough with no guns to feed; Engine Focused keeps the boost charging for fast scooping turns.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Class-3 (32t) tank balances scoop interval against mass; fuel capacity cannot be engineered.",
            "Slot01_Size3": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size3": "Guardian FSD Booster adds a flat jump-range bonus on top of the engineered drive; Guardian tech carries no blueprint.",
            "Slot03_Size2": "SRV Hangar (the lighter 2G) opens surface prospecting and exobiology; hangars are not engineerable.",
            "Slot04_Size2": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot06_Size1": "Enhanced Low Power keeps the shield light and low-draw for the long haul.",
            "Slot07_Size1": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable."
