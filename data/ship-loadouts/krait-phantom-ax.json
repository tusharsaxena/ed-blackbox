  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A fast, mobile anti-Xeno fit: a Guardian Gauss pair on the large mounts, AX/Guardian support on the mediums, and Guardian hull reinforcement (no military slots, so hardening goes in the optionals). Initial is buy-only cores; A-Rated adds the AX kit; Engineered hardens mobility, heat and survival. The AX/Guardian weapons take no engineering — the gains are in flying and the ship modules.",
          "callout": {
            "label": "Place shots, kite, harden in optionals",
            "text": "With only two large mounts and no fighter, the Phantom leans on flying: line up clean Gauss volleys on exposed hearts, then boost out of the lightning. Guardian hull and module reinforcement lives in the optionals (no military slots), so keep the mass light and the FSD strong — reaching the fight is half the build. Manage heat hard between Gauss volleys."
          },
          "notes": {
            "LargeHardpoint1": "Primary heart-cracker. Guardian Gauss is the best AX penetrator but caps at size 2, so it under-fills the large mount — no large Gauss exists. Not engineerable.",
            "LargeHardpoint2": "Second Gauss completes the pair; fire in short bursts to manage the heavy heat. AX/Guardian weapons carry no blueprint.",
            "MediumHardpoint1": "Enhanced AX Multi-Cannon, gimballed for hit-and-run chip damage and Scout clearing; ammo-efficient. Not engineerable.",
            "MediumHardpoint2": "Guardian Shard Cannon adds close-range burst on exposed hearts; fixed for full damage. Not engineerable.",
            "TinyHardpoint1": "Xeno Scanner reveals Interceptor hearts and subsystems — essential for target priority; no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Shield Booster grows the bi-weave; Thermal Resistant tilts it toward Thargoid thermal damage.",
            "PowerPlant": "A-rate first — Gauss and Guardian guns are power-hungry; Overcharged adds headroom and Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives is the Phantom's whole case: out-run and out-turn Thargoid lightning.",
            "FrameShiftDrive": "A-rated; Increased Range + Mass Manager keep the premium jump that self-lifts to distant Maelstroms.",
            "LifeSupport": "A-rated for a long oxygen timer after a canopy breach; Lightweight trims mass; no experimental effect.",
            "PowerDistributor": "Charge Enhanced + Super Conduits feed the Gauss capacitor so the pair keeps firing.",
            "Radar": "D-rated and Lightweight — AX needs no sensor range, so save the mass for speed.",
            "FuelTank": "Stock size-5 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-Weave regenerates fast under fire; Thermal Resistant + Fast Charge suit sustained Thargoid thermal damage.",
            "Slot02_Size5": "Guardian Hull Reinforcement — caustic-resistant armour, the Phantom's hardening with no military slots; not engineerable.",
            "Slot03_Size5": "Guardian Module Reinforcement spreads penetrating-hit damage across internals; caustic-resistant, no blueprint.",
            "Slot04_Size5": "Decontamination Limpet Controller strips caustic off the hull mid-fight; limpet drones carry no engineering.",
            "Slot05_Size3": "More Guardian hull reinforcement; effective armour stacks linearly. Not engineerable.",
            "Slot06_Size3": "Module Reinforcement protects the cores that keep you flying; no blueprint available.",
            "Slot07_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot08_Size2": "A small Guardian HRP tops up effective armour where the slot allows; not engineerable.",
            "Slot09_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
          },
