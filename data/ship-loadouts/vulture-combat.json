      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "An agile duelling fit built around two large guns and careful power management. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern with an emphasis on efficient power.",
          "callout": {
            "label": "Power is the whole problem",
            "text": "The Vulture's class-4 plant can't run two large guns, shields and boost flat-out — Overcharge it, choose efficient weapons (one beam, one efficient multi-cannon), and set sensible power priorities so nothing critical drops mid-fight."
          },
          "notes": {
            "LargeHardpoint1": "Primary large mount; Overcharged multi-cannon with Corrosive Shell strips armour resistance so both guns hit harder.",
            "LargeHardpoint2": "Second large mount; an Efficient beam with Thermal Vent strips shields while bleeding heat and easing the power load.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster; diminishing returns set in but it still pays on a two-utility hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "The Vulture's chronic bottleneck — Overcharge it FIRST; Thermal Spread bleeds the extra heat the boost generates.",
            "MainEngines": "A-rated + Dirty Drives + Drag Drives preserve and sharpen the class-leading agility that wins the duel.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate this second; Charge Enhanced + Super Conduits sustain two large guns plus boost without browning out.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot is the cheapest large multiplier on effective armour.",
            "Slot01_Size5": "Bi-weave regenerates fast for a duellist that re-engages; Reinforced maximises MJ and Fast Charge keeps regen quick.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size2": "More Heavy-Duty hull reinforcement; armour stacks linearly.",
            "Slot04_Size1": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot05_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size1": "Last Heavy-Duty hull reinforcement where the slot allows.",
            "Slot07_Size1": "Second Module Reinforcement protects the cores that keep you flying; not engineerable."
          },
