  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A three-state combat fit. Initial is buy-only on a budget; A-rated is the all-A combat-ready baseline; Engineered is the end-state with the house combat pattern — Overcharged plant, Dirty drives, a Corrosive multi-cannon, Thermal-Vent pulse lasers, and Heavy-Duty defences. The two mediums are the main guns; the two smalls do shield-stripping.",
          "callout": {
            "label": "Spend the military slot wisely",
            "text": "The size-3 military slot is best spent on a Heavy-Duty hull reinforcement — it is the cheapest large gain in survivability the Mk IV has, and it stacks with the optional-slot HRPs."
          },
          "notes": {
            "MediumHardpoint1": "Main gun; the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint1": "Gimballed pulse for shield-stripping; Efficient + Thermal Vent runs it cold and power-cheap.",
            "SmallHardpoint2": "Second pulse doubles the shield-stripping; Thermal Vent vents heat instead of building it.",
            "TinyHardpoint1": "Only utility weapon slot worth a booster; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "PowerPlant": "Small size-4 plant runs four guns plus shields on a tight budget; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives push boost past 430 m/s — speed is this hull's main defence.",
            "FrameShiftDrive": "A-rated to move between RES sites and bounty turn-ins; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — weapon and boost endurance is the single most-felt upgrade on a fighter.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot — the cheapest large multiplier on effective armour.",
            "Slot01_Size4": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more total shield.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size3": "Second Heavy-Duty HRP; armour stacks linearly, so every HRP pays.",
            "Slot04_Size2": "Third Heavy-Duty HRP keeps the paper-thin Mk IV alive when shields drop.",
            "Slot05_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot06_Size1": "Fourth small Heavy-Duty HRP rounds out the armour stack.",
            "Slot07_Size1": "Second Module Reinforcement protects the cores; not engineerable.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
