  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A durable, cool-running skirmisher fit that uses the four utilities. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern, leaning on the Scout's low heat and toughness.",
          "callout": {
            "label": "Lean on heat and toughness",
            "text": "The Scout's edge is low heat and durability, not firepower — run silent on approach, use the four utilities for boosters and a heat sink, and tank with shield plus a couple of reinforcements. Win by surviving and skirmishing, not by out-damaging."
          },
          "notes": {
            "MediumHardpoint1": "Primary medium multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint1": "Small pulse laser; Efficient + Thermal Vent strips shields and dumps heat on every hit.",
            "SmallHardpoint2": "Second Thermal-Vent pulse keeps the Scout running cold — its whole identity under sustained fire.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ on a hull with little base shield.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength on a small hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate it; Overcharged adds headroom for guns, shields and utilities, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives keep the nimble Scout fast enough to dictate the fight.",
            "FrameShiftDrive": "A-rated to reposition between fights; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — the class-3 distributor is the smallest core and sets your weapon and boost sustain.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ, Fast Charge speeds the reform.",
            "Slot02_Size3": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Slot03_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot04_Size2": "Second Heavy-Duty HRP — armour stacks linearly, so every plate counts on a light hull.",
            "Slot05_Size1": "Module Reinforcement spreads penetrating-hit damage across the cores; not engineerable.",
            "Slot06_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
