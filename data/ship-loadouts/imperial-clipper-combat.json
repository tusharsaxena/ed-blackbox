  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A fast skirmisher fit that leans on speed and a bi-weave buffer. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern weighted to speed and shields.",
          "callout": {
            "label": "Speed is the defence",
            "text": "With no military slots and modest shields, the Clipper survives by not getting hit — build a bi-weave buffer and a couple of reinforcements, but lean on speed and repositioning rather than trying to tank a stand-up fight."
          },
          "notes": {
            "LargeHardpoint1": "Primary large mount; Overcharged multi-cannon carries the battery's single Corrosive Shell to strip armour resistance for every gun.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so the main battery never stops firing.",
            "MediumHardpoint1": "Gimballed beam for shield-stripping; Thermal Vent keeps it cold through fast passes.",
            "MediumHardpoint2": "Medium multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large gain on the bi-weave's raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster rounds out a modest shield stack.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Class-6 plant runs four guns, the bi-weave and the cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives with Drag Drives — speed is the Clipper's whole game, so engineer thrusters first.",
            "FrameShiftDrive": "A-rated with only G3 range plus Mass Manager — enough to reach fights and Imperial-rank turn-ins without bloating mass.",
            "LifeSupport": "D-rate to save mass and Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "Class-6 distributor A-rated then Charge Enhanced + Super Conduits to sustain two large guns plus boost.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "A size-6 bi-weave under-fills the size-7 slot to save mass; Reinforced maxes its MJ and Fast Charge speeds the regen for hit-and-run.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size4": "Heavy-Duty hull reinforcement — the cheapest large multiplier on effective armour.",
            "Slot04_Size4": "Second Heavy-Duty HRP; armour stacks linearly.",
            "Slot05_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size3": "Module Reinforcement spreads penetrating-hit damage across the internals; not engineerable.",
            "Slot07_Size2": "Second Module Reinforcement protects the cores; not engineerable.",
            "Slot08_Size2": "More Heavy-Duty hull where the small slot allows.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
