  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A turret-saturation armour-tank fit using both military slots and all eight utilities. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern weighted to turrets and armour. An AX variant swaps the turrets for Guardian/AX weapons.",
          "callout": {
            "label": "All turrets, all armour",
            "text": "The Type-10 can't aim fixed guns at agile targets, so go full turret — it saturates everything in range while you focus on staying alive. Stack armour and hull reinforcement; the feeble shields are a buffer, not the tank."
          },
          "notes": {
            "LargeHardpoint1": "Lead large multi-cannon turret; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large MC turret; Auto Loader removes reloads so it tracks and fires nonstop.",
            "LargeHardpoint3": "Large beam turret for shield-stripping; Thermal Vent keeps it cold under sustained fire.",
            "LargeHardpoint4": "Second large beam turret; paired Thermal-Vent beams hold targets shieldless while the MCs work the hull.",
            "MediumHardpoint1": "Medium MC turret adds sustained kinetic DPS; Auto Loader keeps it uninterrupted.",
            "MediumHardpoint2": "Second medium MC turret; turrets let the fortress fight while you manage position.",
            "MediumHardpoint3": "Medium beam turret; Thermal Vent vents heat so the laser battery runs heat-free.",
            "SmallHardpoint1": "Small MC turret fills the firing arcs; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Second small MC turret completes nine-mount saturation coverage.",
            "TinyHardpoint1": "First Heavy-Duty shield booster; multiplies the bi-weave's raw MJ buffer.",
            "TinyHardpoint2": "Second Heavy-Duty booster — cheap shield-buffer gain over the armour.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint8": "Third Heavy-Duty booster rounds out the shield buffer.",
            "PowerPlant": "Powers nine turrets, an SLF and eight utilities; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover the barest mobility a 1,200t hull allows.",
            "FrameShiftDrive": "A-rated to relocate the fortress between fights; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate to feed nine turrets without throttling; Charge Enhanced widens the weapon capacitor.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size8": "Bi-weave regenerates fast under fire; Reinforced maximises the MJ buffer, Fast Charge keeps regen high.",
            "Slot02_Size7": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-7 slot for max effective armour.",
            "Slot03_Size6": "SLF bay adds a second gun platform that draws fire; hangars are not engineerable.",
            "Slot04_Size5": "Another Heavy-Duty 5D HRP — armour stacks linearly across the optionals.",
            "Slot05_Size4": "Module Reinforcement protects the cores that keep the fortress flying; not engineerable.",
            "Slot06_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size3": "More Heavy-Duty hull where the slot allows.",
            "Slot08_Size3": "More internal protection for the modules; not engineerable.",
            "Slot09_Size2": "Last module reinforcement tops up penetrating-hit protection; not engineerable.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 8,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 7,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
