  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A converted Imperial combat medium doing passenger work — a deep cabin suite behind a real bi-weave shield, with a pair of deterrent guns the liners can't carry. Initial is buy-only; A-rated is the passenger baseline; Engineered keeps the manifest safe and stretches the modest laden range. The Corsair has no military slots, so the shield, cell bank and cabins all share its ten optionals.",
          "callout": {
            "label": "Capacity and a shield, not comfort",
            "text": "Fit the cabin mix the board demands — economy for bulk sightseeing, first-class for VIP fares — behind a bi-weave shield and point defence. As a Gutamaya hull the Corsair earns no liner comfort bonus, so its case is capacity, safety and medium-pad reach, not per-seat pay; keep two deterrent multi-cannons on the medium mounts and it runs boards the unarmed liners avoid."
          },
          "notes": {
            "MediumHardpoint1": "Gimballed multi-cannon for self-defence; Overcharged with Auto Loader lets the Corsair deter an interdictor without reloading mid-scuffle.",
            "MediumHardpoint2": "Second self-defence multi-cannon; the three large mounts are left empty to keep the laden hull light and cool.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in passenger survivability.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more shield strength to ride out an interdiction with the manifest aboard.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rated to power the shield, cabins and guns; Low Emissions plus Thermal Spread run the laden hull cool and quiet.",
            "MainEngines": "A-rated then Dirty Drive Tuning so the loaded Corsair can still boost clear of an interdiction; Drag Drives sharpens boost.",
            "FrameShiftDrive": "A-rated and Increased Range (G5) with Mass Manager to stretch the modest laden jump; pair with a Guardian booster.",
            "LifeSupport": "Kept A-rated for endurance; Lightweight trims mass — life support has no experimental effect.",
            "PowerDistributor": "A-rated and Engine Focused so the boost capacitor refills fast for repeated escapes; Super Conduits speeds every recharge.",
            "Radar": "Dropped to D and made Lightweight — passenger work needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Economy cabin in the largest slot — bulk berths for ordinary tourist boards.",
            "Slot02_Size6": "Bi-weave shield generator, the Corsair's passenger safety net; Reinforced maximises MJ and Fast Charge speeds the regen.",
            "Slot03_Size6": "First-class cabin in the second size-6 slot for high-value VIP fares; swap to luxury for the richest boards.",
            "Slot04_Size5": "Economy cabin adds more bulk berths for mixed manifests.",
            "Slot05_Size5": "Second economy cabin — the bulk of the headcount rides here.",
            "Slot06_Size5": "First-class cabin for extra VIP seating alongside the economy bulk.",
            "Slot07_Size4": "Economy cabin fills the mid slot; trade up to business if the board pays better.",
            "Slot08_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot09_Size2": "Small economy cabin tops up the berth count.",
            "Slot10_Size1": "Optional / low-priority — a Shielded AFMU self-repairs modules on long sightseeing hauls."
          },
