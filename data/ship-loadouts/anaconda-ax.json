  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A heavy anti-Xeno fit: Enhanced AX Multi-Cannons and a Guardian Shard on the huge and large mounts, a four-gun Gauss battery on the medium and small mounts, a fighter for decoy, and deep Guardian hull/module reinforcement across the military slot and twelve optionals. Initial is buy-only; A-Rated adds the full AX kit; Engineered hardens mobility, heat and survival. No AX or Guardian weapon comes in a huge size, so the huge mount carries the largest gun available — a size-3 Enhanced AX Multi-Cannon.",
          "callout": {
            "label": "Tank, decoy, pour on fire",
            "text": "With a military slot plus twelve optionals, the Anaconda hardens deeper than any medium — Guardian hull and module reinforcement everywhere, plus shields and caustic kit. The SLF splits Thargoid attention while four Gauss mounts melt the hearts. Manage heat hard with Gauss; you cannot dodge, so reinforcement and heat discipline are your survival.",
            "tone": "warn"
          },
          "notes": {
            "HugeHardpoint1": "No AX/Guardian weapon exists at huge — the largest available, an Enhanced AX Multi-Cannon (size 3, gimballed), under-fills the slot for the biggest sustained AX gun; weapons take unlocks, not blueprints.",
            "LargeHardpoint1": "Enhanced AX Multi-Cannon (large, gimballed) — reliable sustained anti-Xeno DPS that is easy to keep on target; not engineerable.",
            "LargeHardpoint2": "Second Enhanced AX Multi-Cannon for steady hull damage between Gauss volleys; not engineerable.",
            "LargeHardpoint3": "Guardian Shard Cannon (large, fixed) — shotgun burst that strips Interceptor hearts at close range; not engineerable.",
            "MediumHardpoint1": "Guardian Gauss Cannon (medium, fixed) — the premier heart-killer; Gauss tops out at size 2, so the mediums carry the heavy Gauss; not engineerable.",
            "MediumHardpoint2": "Second medium Gauss; charge-and-release fixed fire demands trigger discipline but melts hearts; not engineerable.",
            "SmallHardpoint1": "Guardian Gauss Cannon (small, fixed) adds a third Gauss to the heart-stripping volley; not engineerable.",
            "SmallHardpoint2": "Fourth Gauss completes the battery — four Gauss is all the heat budget allows; not engineerable.",
            "TinyHardpoint1": "Xeno Scanner reads Thargoid type and lights the hearts to target; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Shield booster, Thermal Resistant + Thermo Block — Thargoid damage is largely thermal, so resistance beats raw MJ.",
            "TinyHardpoint6": "Second Thermal-Resistant booster stacks thermal resistance against the lightning.",
            "TinyHardpoint7": "One Heavy-Duty booster with Super Capacitors adds raw MJ to balance the resistance stack.",
            "TinyHardpoint8": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "Overcharged + Thermal Spread — four Gauss, four AX guns, a fighter and a big shield draw enormous power; Thermal Spread bleeds the extra heat.",
            "MainEngines": "Dirty Drives + Drag Drives recover what agility a 400t hull allows; you cannot dodge the lightning but every degree of turn helps.",
            "FrameShiftDrive": "Increased Range + Mass Manager so a heavy hull still reaches the Maelstrom and repositions between fights.",
            "LifeSupport": "D-rate and Lightweight to save mass; life support has no experimental effect.",
            "PowerDistributor": "A-rate first and Charge Enhanced + Super Conduits — the class-8 distributor must feed power-hungry Gauss and a capital shield.",
            "Radar": "Drop to D and go Lightweight; AX combat is close-range, so trade sensor range for mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement in the military slot spreads penetrating-hit and caustic damage across internals; Guardian modules are not engineerable.",
            "Slot01_Size7": "Bi-Weave regenerates fast under sustained fire; Thermal Resistant + Fast Charge tune it against Thargoid thermal damage.",
            "Slot02_Size6": "Fighter Hangar launches an SLF decoy that splits Thargoid attention; hangars are not engineerable.",
            "Slot03_Size6": "Guardian Hull Reinforcement (size 5, the cap) under-fills this size-6 slot — the best caustic-resistant armour available; not engineerable.",
            "Slot04_Size6": "Guardian Module Reinforcement (size-5 cap) under-fills a size-6 slot to protect cores from penetrating hits; not engineerable.",
            "Slot05_Size5": "Guardian Hull Reinforcement 5 — Guardian armour stacks caustic resistance the standard HRP can't; not engineerable.",
            "Slot06_Size5": "Guardian Module Reinforcement 5 spreads more module damage; not engineerable.",
            "Slot07_Size5": "Decontamination Limpet Controller scrubs caustic corrosion off the hull mid-fight; limpet controllers are not engineerable.",
            "Slot08_Size4": "Guardian Hull Reinforcement 4 adds more caustic-resistant armour; not engineerable.",
            "Slot09_Size4": "Standard Hull Reinforcement, Heavy Duty + Deep Plating — the only reinforcement here that takes a blueprint, for raw armour multiplier.",
            "Slot10_Size4": "Standard Module Reinforcement protects internals; module reinforcement has no blueprint.",
            "Slot11_Size2": "Guardian Hull Reinforcement 2 fills the small slot with more caustic-resistant armour; not engineerable.",
            "Slot12_Size1": "Guardian Module Reinforcement 1 tops off internal protection in the last optional; not engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 8,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani / Marsha Hicks"
