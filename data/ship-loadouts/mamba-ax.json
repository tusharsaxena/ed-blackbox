              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Thermal Resistant / Heavy Duty",
              "experimental": "Thermo Block / Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
