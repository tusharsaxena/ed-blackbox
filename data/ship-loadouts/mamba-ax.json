  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A fast Gauss skirmisher: two Guardian Gauss cannons on the small mounts for heart damage, AX multi-cannons in the huge and large mounts (no huge AX gun exists) and a Guardian Shard for swarm work, with module hardening squeezed from the optionals since there is no military slot. Initial is buy-only (cores only — every AX/Guardian gun needs an unlock); A-Rated adds the unlocked kit; Engineered leans into speed, shields and heat, because AX/Guardian weapons and Guardian reinforcement carry no blueprints at all.",
          "callout": {
            "label": "Kite the fight, harden what you can",
            "text": "With no military slot, the Mamba's module hardening has to come from its optionals — a Guardian MRP or two competing with the shield, hull and decon controller for six small bays. Run Gauss on the smalls, AX multi-cannons in the big mounts (no huge AX gun exists), and lean on speed: control range, alpha the heart on a pass, and pull clear of clouds and swarms rather than absorbing them."
          },
          "notes": {
            "HugeHardpoint1": "Largest AX gun is Large, so an Enhanced AX Multi-Cannon under-fills the huge mount; gimballed for tracking. No AX/Guardian weapon can be engineered.",
            "LargeHardpoint1": "Second Enhanced AX Multi-Cannon for sustained anti-Interceptor DPS; carries no blueprint.",
            "LargeHardpoint2": "Guardian Shard Cannon for shredding Scouts, Thargons and exposed hearts; not engineerable.",
            "SmallHardpoint1": "Guardian Gauss Cannon — the heart-damage gun; fixed-only and carries no engineering blueprint.",
            "SmallHardpoint2": "Second Gauss for a heavier heart-phase alpha on the pass; not engineerable.",
            "TinyHardpoint1": "Xeno Scanner exposes Interceptor hearts and subsystems; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Thermal Resistant booster, Thermo Block stacked, hardens the bi-weave against Thargoid thermal fire.",
            "TinyHardpoint6": "Heavy Duty booster with Super Capacitors for the raw MJ a small shield badly needs.",
            "PowerPlant": "A-rate it to feed Gauss, the bi-weave and boost on a 250t hull; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rate FIRST — speed is the Mamba's only real defence; Dirty Drives + Drag Drives push boost toward ~490 m/s.",
            "FrameShiftDrive": "A-rate to relocate between hot zones; only G3 range — an AX skirmisher needs no jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate to sustain Gauss capacitor draw and boost; Charge Enhanced + Super Conduits keep the WEP pool deep.",
            "Radar": "Drop to D and go Lightweight; AX combat is close-range, so trade sensor reach for mass.",
            "FuelTank": "Stock 3C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Largest bi-weave the class-5 bay allows; Thermal Resistant + Hi-Cap is the AX shield against thermal lightning.",
            "Slot02_Size4": "Guardian Hull Reinforcement adds armour AND caustic resistance standard HRP lacks; Guardian kit carries no blueprint.",
            "Slot03_Size3": "Decontamination Limpet Controller scrubs caustic stacks off the hull; limpet controllers are not engineerable.",
            "Slot04_Size2": "Guardian Module Reinforcement protects internals from penetrating Thargoid hits; not engineerable.",
            "Slot05_Size2": "Second Guardian HRP for more armour and caustic resistance from the scarce optionals; no blueprint.",
            "Slot06_Size1": "Last small bay takes a Guardian MRP for a little more module hardening; not engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
