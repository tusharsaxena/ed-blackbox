  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A budget do-a-bit-of-everything fit — a self-defence gun pair, a useful hold, a small shield and a fair jump on the cheapest medium hull in the game. Initial is buy-only; A-rated is the all-round baseline; Engineered leans into range and mobility since the Type-6 lives on running, not fighting. Re-role by swapping the optional internals: more cargo for trading, mining tools plus a refinery for ore, or a fuel scoop and scanners for exploration.",
          "callout": {
            "label": "Re-role by the optionals, flee by the thrusters",
            "text": "Cores stay fixed; the eight optional internals define the job — cargo racks for trading, mining laser plus refinery and collectors for ore, or a scoop and DSS for exploration. But two small guns and a ~90 MJ base shield mean the plan against trouble is always the same: high-wake out. Engineer the FSD and thrusters first."
          },
          "notes": {
            "SmallHardpoint1": "Gimballed small multi-cannon is the easy self-defence pick; Overcharged with the one Corrosive Shell to strip armour resistance off anything you must fight.",
            "SmallHardpoint2": "Gimballed small pulse adds thermal shield damage; Efficient keeps heat and power low on a hull with a small plant and distributor.",
            "TinyHardpoint1": "One shield booster is the cheapest large gain to the small bi-weave; Heavy Duty multiplies its raw MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire so a laden hull can break away.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat to mask a silent-running high-wake escape.",
            "PowerPlant": "Small class-3 plant runs the two guns, shield and utilities together; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate plus Dirty Drives lift a slow hull's speed — the difference between escaping an interdiction and dying to it.",
            "FrameShiftDrive": "A-rate first — a light hull on a size-4 FSD jumps well; Increased Range plus Mass Manager keeps the laden range respectable across every role.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate for weapon and boost recharge; Charge Enhanced plus Super Conduits keeps the guns and the escape boost fed.",
            "Radar": "Drop to D and go Lightweight; a generalist needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-4 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional — cargo for trading; the two size-5 racks are the bulk of the hold. Cargo racks aren't engineerable.",
            "Slot02_Size5": "Optional — cargo for trading; swap for mining tools or a passenger cabin to re-role. Cargo racks aren't engineerable.",
            "Slot03_Size4": "Size-4 bi-weave (fast-charge) for a small shield that regenerates under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot04_Size4": "Optional — more cargo, or swap for a fuel scoop when exploring. Cargo racks aren't engineerable.",
            "Slot05_Size3": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stack it on a lightly-built hull.",
            "Slot06_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing to buy seconds for an escape.",
            "Slot07_Size2": "Module Reinforcement spreads penetrating-hit damage across the internals; not engineerable.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
