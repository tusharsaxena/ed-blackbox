  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "An exploration fit that uses the Beluga's vast internals for a complete, redundant expedition. Initial is buy-only; A-rated is the expedition baseline; Engineered squeezes every light-year from a heavy hull while carrying full kit. Hardpoints stay empty and the cabins come out — mass is the enemy here.",
          "callout": {
            "label": "Capacity without the range",
            "text": "The Beluga carries a complete, redundant expedition all at once — the largest scoop it takes, a multi-SRV bay, twin AFMUs, a repair-limpet controller, scanner and a comfort cabin. The catch is that even stripped and engineered it still only jumps ~40 LY, so every destination is many more jumps away than on a proper explorer."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "A light shield booster pads the landing shield; Heavy Duty maximises its raw MJ for botched touchdowns.",
            "PowerPlant": "D-rated to save mass on a 950 t hull; Low Emissions keeps heat low while scooping and Thermal Spread bleeds the rest.",
            "MainEngines": "D-rated for mass; Clean Drive Tuning runs cool and Stripped Down sheds weight for range.",
            "FrameShiftDrive": "A-rated and the heart of the build; Increased Range plus Mass Manager drives the ~40 LY jump out of a heavy liner.",
            "LifeSupport": "The class-8 life support is the single biggest mass target — D-rate and go Lightweight; it has no experimental effect.",
            "PowerDistributor": "D-rated; Engine Focused keeps the engine pip charged for boosting and high-wake escapes.",
            "Radar": "D-rated and Lightweight — exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size6": "Guardian FSD Booster size 5 is the largest flat jump-range bonus available — vital on a short-legged hull; it under-fills the size-6 slot and carries no blueprint.",
            "Slot03_Size6": "Multi-SRV Planetary Vehicle Hangar for surface science and exobiology; hangars carry no blueprint.",
            "Slot04_Size6": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size5": "A light bi-weave for landing safety; Enhanced Low Power plus Stripped Down keep its mass and power draw minimal.",
            "Slot06_Size5": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size4": "Repair Limpet Controller patches hull the AFMU can't touch; the largest variant is size 3, so it under-fills this size-4 slot and carries no blueprint.",
            "Slot08_Size3": "Flex slot — a single economy cabin for a sightseeing tour, or swap for science or storage per trip; cabins aren't engineerable.",
            "Slot09_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot10_Size3": "A modest extra fuel tank extends the gap between scoopable stars; fuel tanks aren't engineerable.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
