      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A flagship expedition fit using the vast internals — everything an expedition could want, with redundancy. Initial is buy-only; A-rated is the expedition baseline; Engineered maximises jump range while carrying full kit.",
          "callout": {
            "label": "Carry everything, twice",
            "text": "The Caspian's fourteen optional internals let it field the biggest scoop, a multi-SRV bay, three AFMUs, science or passenger fittings and full comforts simultaneously — redundancy and capacity no other explorer can match, while still jumping ~78 LY."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "Light shield booster stiffens the optional landing shield for surface ops; Heavy Duty multiplies its raw MJ.",
            "PowerPlant": "D-rated to save mass; Low Emissions cuts heat and signature, Thermal Spread bleeds the rest for cool scooping.",
            "MainEngines": "D-rated for mass; Clean Drive Tuning runs cool and efficient, Stripped Down trims more weight for range.",
            "FrameShiftDrive": "The A-rated class-8 SCO drive is the whole ship; Increased Range + Mass Manager push the jump ceiling as far as it goes.",
            "LifeSupport": "D-rate and go Lightweight to shed mass from the big hull; life support has no experimental effect.",
            "PowerDistributor": "D-rated; Engine Focused fills the engine capacitor to boost clear of gravity wells, Stripped Down saves mass.",
            "Radar": "D-rate and Lightweight — exploration needs no sensor range, so spend the mass on jumps; no experimental effect.",
            "FuelTank": "Standard class-7 tank for long legs between scoopable stars; fuel capacity cannot be engineered.",
            "Slot01_Size7": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size6": "Multi-SRV bay for thorough surface science and exobiology; SRV hangars are not engineerable.",
            "Slot03_Size6": "Guardian FSD Booster adds the biggest flat jump bonus there is; it caps at size 5, under-filling this size-6 slot, and is not engineerable.",
            "Slot04_Size5": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size5": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot06_Size5": "Optional bi-weave shield for safe planetary landings; Enhanced Low Power + Stripped Down keep it light and easy on power.",
            "Slot07_Size5": "Repair Limpet Controller patches hull damage from hard landings; limpet controllers are not engineerable.",
            "Slot08_Size4": "Economy cabin for passenger runs or a science fit on the flagship; cabins carry no blueprint.",
            "Slot09_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot10_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot11_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
