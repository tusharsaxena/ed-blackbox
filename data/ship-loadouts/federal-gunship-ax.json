  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "ax",
          "intro": "A hardened AX tank fit: a wide AX weapon mix fed by the class-7 distributor, Guardian module reinforcement in the three military slots, and caustic/heat kit in the utilities. Initial is buy-only (AX & Guardian weapons need unlocks, so the hull starts bare); A-Rated adds the Guardian/AX kit; Engineered hardens mobility, heat and shield.",
          "callout": {
            "label": "Distributor first, then harden the modules",
            "text": "Gauss and shard cannons drain the weapon capacitor brutally — A-rate the class-7 distributor before anything else or the guns stutter. Then fill the military slots with Guardian Module Reinforcement: it is the difference between losing a thruster to Thargoid lightning and shrugging it off. Manage heat hard."
          },
          "notes": {
            "LargeHardpoint1": "Largest mount takes an Enhanced AX Multi-Cannon; gimballed so the clumsy hull can still land rounds on a weaving Interceptor.",
            "MediumHardpoint1": "Enhanced AX Multi-Cannon, gimballed — sustained anti-Xeno DPS that needs no precise tracking.",
            "MediumHardpoint2": "Second gimballed Enhanced AX Multi-Cannon doubles the medium AX battery.",
            "MediumHardpoint3": "Guardian Shard Cannon — close-range burst against exposed hearts; fixed, fired when anchored in close.",
            "MediumHardpoint4": "Second Guardian Shard Cannon stacks the heart-burst damage.",
            "SmallHardpoint1": "Guardian Gauss Cannon — the AX meta weapon; fixed-only, charged onto an exposed heart.",
            "SmallHardpoint2": "Second Guardian Gauss for paired heart strikes; both small mounts go to Gauss.",
            "TinyHardpoint1": "Advanced Xeno Scanner reads Thargoid type and heart count; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Shield Booster; the Thermal Resistant blueprint hardens the buffer against Thargoid thermal fire.",
            "PowerPlant": "Powers the wall of guns and SLF; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives claws back what little agility the heavy hull allows.",
            "FrameShiftDrive": "A-rated with Increased Range to reach distant Maelstroms; Mass Manager offsets the heavy fit.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate the class-7 unit FIRST — Gauss and shard drain the weapon capacitor brutally; Charge Enhanced + Super Conduits keep it fed.",
            "Radar": "Drop to D and go Lightweight; AX needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement — the signature anti-lightning hardening; Guardian kit is not engineerable.",
            "Military02": "Second Guardian Module Reinforcement; stacking spreads more penetrating lightning across the modules.",
            "Military03": "Guardian Hull Reinforcement adds caustic-resistant effective armour; not engineerable.",
            "Slot01_Size6": "Bi-Weave regenerates fast under fire; Thermal Resistant + Fast Charge tune it for Thargoid thermal damage.",
            "Slot02_Size6": "SLF bay adds a remote gun and a decoy to split Thargoid attention; hangars are not engineerable.",
            "Slot03_Size5": "Largest Guardian Hull Reinforcement for caustic-resistant armour; not engineerable.",
            "Slot04_Size2": "Decontamination Limpet Controller scrubs caustic damage between heat-sink purges; limpet controllers carry no blueprint.",
            "Slot05_Size2": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot06_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
          },
