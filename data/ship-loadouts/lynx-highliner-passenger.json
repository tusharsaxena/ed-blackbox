  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "The Lynx is a pre-built Saud Kruger medium liner. Initial is its stock fit — E-rated cores, a size-5 shield and four economy cabins (~48 passengers). A-Rated lifts the cores to A and fills the optional slots with a bi-weave shield and a mixed economy/business/first/luxury cabin suite; Engineered adds the range, mobility and shield blueprints. Engineer the stock cores in place via the remote workshop to keep the pre-built free rebuy rather than selling them.",
          "callout": {
            "label": "Engineer in place, fill the open slots",
            "text": "Initial is the Lynx as delivered — stock E modules, four economy cabins, ~48 passengers. Built up it carries a mixed VIP cabin suite behind a bi-weave shield, cores engineered in place for range & cool running. Mix first & luxury cabins for high-value Robigo VIP fares and economy for volume."
          },
          "notes": {
            "MediumHardpoint1": "Efficient runs cool; Thermal Vent vents heat.",
            "MediumHardpoint2": "Efficient runs cool; Thermal Vent vents heat.",
            "TinyHardpoint1": "Shield booster multiplies the bi-weave's raw MJ; Heavy Duty is the cheapest large gain in passenger safety.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate for headroom to run shield and cabins; Low Emissions keeps it cool and Thermal Spread bleeds the rest.",
            "MainEngines": "A-rated + Dirty Drive Tuning give a heavy liner the speed to boost clear of trouble.",
            "FrameShiftDrive": "A-rated SCO drive; Increased Range + Mass Manager stretch every jump to reach the Robigo beacons.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate then Engine Focused + Super Conduits to keep the boost charged for fast getaways.",
            "Radar": "Drop to D and go Lightweight; a liner needs no sensor range, so save the mass.",
            "FuelTank": "Stock 32t tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-Weave in the size-6 slot regenerates fast under fire; Reinforced maximises MJ and Fast Charge speeds recovery — passenger safety first.",
            "Slot02_Size5": "First-class cabin for premium VIP fares; cabins themselves are not engineerable.",
            "Slot03_Size5": "Luxury cabin earns the top Robigo VIP rates — fewest seats, highest profit per head.",
            "Slot04_Size5": "Economy cabin fills the volume seats, cheap headcount alongside the VIP suites.",
            "Slot05_Size4": "Business cabin balances comfort and headcount in the size-4 slot.",
            "Slot06_Size2": "Supercruise Assist eases the long Robigo cruises; navigation aids carry no blueprint.",
            "Slot07_Size1": "Advanced Docking Computer for hands-free dock and launch; not engineerable."
          },
