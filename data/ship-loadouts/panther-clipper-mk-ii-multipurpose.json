  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit on the game's largest freighter — a real gun battery, a deep shield, an enormous cargo hold and re-tunable internals. Initial is buy-only; A-rated is the multirole baseline; Engineered lifts defence and mobility. It does every job at capital scale except jump far, and it costs a fortune to re-fit.",
          "callout": {
            "label": "A freighter that fights, not a warship that hauls",
            "text": "The Panther's multirole case is its cargo: twelve optional internals — two of them class 8 — swallow any role's kit with ore racks to spare. It arms every hardpoint and tanks behind a heavy shield, but it is glacially slow, jumps poorly and is the priciest hull in the game — re-role it at a station only if you already own one to haul."
          },
          "notes": {
            "LargeHardpoint1": "Primary large mount; one Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Large beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "MediumHardpoint1": "Medium multi-cannon for sustained kinetic DPS; Auto Loader removes reloads.",
            "MediumHardpoint2": "Second medium multi-cannon fills the kinetic battery; Auto Loader keeps it firing.",
            "MediumHardpoint3": "Medium pulse rounds out the laser side; Efficient + Thermal Vent runs it cool and power-cheap.",
            "MediumHardpoint4": "Second medium pulse; same Efficient + Thermal-Vent pattern.",
            "SmallHardpoint1": "Small multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Second small multi-cannon; Auto Loader keeps the battery uninterrupted.",
            "SmallHardpoint3": "Small pulse fills a mount; swap freely when re-roling.",
            "SmallHardpoint4": "Last small mount; leave stock or strip when hauling.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth Heavy-Duty booster rounds out the shield stack.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers ten guns, a big shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "8A + Dirty Drives recover what agility a 1,200t hull can — it stays slow no matter what.",
            "FrameShiftDrive": "7A with Increased Range + Mass Manager claws jump range back on the heavy hull; even engineered it is a poor jumper.",
            "LifeSupport": "A-rated for endurance; Lightweight trims mass — life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — the gun battery plus boost drain the class-7 distributor; Charge Enhanced + Super Conduits keep WEP and ENG full.",
            "Radar": "Drop to D and go Lightweight; multirole needs no sensor range, so save the mass.",
            "FuelTank": "Stock 7C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size8": "Optional — the class-8 rack is the reason to fly this hull; swap for a role module set when not hauling. Cargo racks aren't engineerable.",
            "Slot02_Size8": "Optional — second class-8 rack; enormous cargo, or storage for a swapped role kit. Cargo racks aren't engineerable.",
            "Slot03_Size7": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size7": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more — the survivable all-round choice.",
            "Slot05_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size6": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-6 slot for max effective armour.",
            "Slot08_Size5": "Second 5D HRP (HRP's largest) fully fills this slot — armour stacks linearly.",
            "Slot09_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot10_Size4": "Heavy-Duty hull reinforcement (a 4D HRP) where the slot allows.",
            "Slot11_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
