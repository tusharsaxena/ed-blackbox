  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A do-everything-but-fight fit built on the Caspian's vast internals. The hull carries no weapon hardpoints, so 'multipurpose' here means explore, haul, ferry passengers and run surface science from one airframe — never combat. Initial is buy-only; A-rated is the all-round baseline; Engineered layers the class-8 FSD's signature range on top. Re-role by swapping the optional internals: more cargo racks for trading, passenger cabins for tourism, or scoop plus SRV bay and scanners for exploration.",
          "callout": {
            "label": "Everything except a gun",
            "text": "Fourteen optional internals and a class-8 FSD let one Caspian trade, explore, run surface science and ferry passengers in flagship comfort. What it can never do is fight — there is not a single weapon mount on the hull, only six utility slots for defensive kit. Plan every job around slipping away, not shooting back."
          },
          "notes": {
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in survivability on a gunless hull.",
            "TinyHardpoint2": "Second Heavy-Duty booster stiffens the shield for planetary landings and interdiction escapes.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but the shield is your only defence, so it still pays.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and cool scooping.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils an interdictor's gimballed fire so you can jump clear.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles while you run.",
            "PowerPlant": "Powers the shield, cell bank and utilities together; Overcharged adds headroom, Thermal Spread bleeds the extra heat for cool scooping.",
            "MainEngines": "A-rated plus Dirty Drives lift a 950t hull's modest agility for docking and shaking interdictions.",
            "FrameShiftDrive": "The class-8 SCO drive is the ship's calling card; Increased Range + Mass Manager push the laden jump toward the top of the field.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate for shield and boost recharge; Charge Enhanced plus Super Conduits sustain the SYS and ENG capacitors on a heavy hull.",
            "Radar": "Drop to D and go Lightweight; a generalist needs no sensor range, so save the mass for jumps.",
            "FuelTank": "Stock class-7 tank for long legs between scoopable stars; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Largest cargo rack — the trading half of the multirole; swap it for a passenger cabin or exploration kit per job. Cargo racks aren't engineerable.",
            "Slot02_Size6": "Bi-weave shield (6C) for fast regen and forgiving landings; Reinforced maximises its MJ and Hi-Cap adds more — the hull's primary defence.",
            "Slot03_Size6": "Second big cargo rack for hauling runs; drop to a fuel scoop or cabin when re-roling. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Fuel scoop for self-sufficiency on long legs; keeps the ship independent of stations between jobs. Scoop rate is fixed.",
            "Slot05_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing when an escape goes wrong.",
            "Slot06_Size5": "AFMU repairs modules on long solo trips; a second one fits the spare cargo slot when running deep. AFMUs aren't engineerable.",
            "Slot07_Size5": "Planetary Vehicle Hangar for surface science and exobiology; SRV hangars are not engineerable.",
            "Slot08_Size4": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stack it on a hull with no military slots.",
            "Slot09_Size4": "Optional — cargo space for trading, or a passenger cabin for tourism. Cargo racks aren't engineerable.",
            "Slot10_Size3": "More Heavy-Duty hull reinforcement where the slot allows; armour stacks linearly.",
            "Slot11_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot12_Size1": "Detailed Surface Scanner maps planets for cartographic payouts; Expanded Probe Scanning widens probe coverage.",
            "Slot13_Size1": "Small Heavy-Duty hull reinforcement rounds out the armour stack.",
            "Slot14_Size1": "Optional — a last cargo rack or a spare limpet controller. Cargo racks aren't engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 8,
