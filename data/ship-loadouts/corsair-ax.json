  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A fast AX skirmisher: triple Guardian Gauss on the medium mounts for heart damage, two Enhanced AX multi-cannons and a Guardian Plasma Charger on the large mounts for sustained hull damage, and the deep optionals carrying a bi-weave shield, Guardian module hardening and Guardian hull reinforcement to make up for the absent military slots. Initial is buy-only; A-Rated adds the unlocked AX/Guardian kit; Engineered hardens shields, hull, heat and mobility — the AX and Guardian weapons themselves cannot be engineered.",
          "callout": {
            "label": "Harden from the optionals, not military bays",
            "text": "The Corsair has no military slots, so its Guardian Module Reinforcement and hull hardening come out of the ten optionals — budget two Guardian MRP and three Guardian HRP before chasing more shield. Put all three Gauss on the mediums, the AX multi-cannons and a Plasma Charger on the larges, and lean on Imperial speed to dodge what you cannot soak."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced (V2) AX multi-cannon, gimballed to track Interceptor drift; sustained anti-hull DPS — AX weapons carry no engineering blueprint.",
            "LargeHardpoint2": "Second gimballed Enhanced AX multi-cannon doubles the sustained hull pressure between exertion phases; not engineerable.",
            "LargeHardpoint3": "Guardian Plasma Charger adds a charge-up burst that hits hearts and hull hard; Guardian weapons cannot be engineered.",
            "MediumHardpoint1": "Guardian Gauss Cannon — the primary heart-cracker; fixed-only, immensely capacitor-hungry, and carries no engineering blueprint.",
            "MediumHardpoint2": "Second fixed Gauss; three together crack an exerted heart in one window — manage WEP pips between shots.",
            "MediumHardpoint3": "Third fixed Gauss completes the heart battery; Gauss is the reason the distributor is A-rated first.",
            "TinyHardpoint1": "Advanced Xeno Scanner reads Thargoid type and live heart count; scanners have no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Shield Booster — Thermal Resistant against Thargoid thermal and caustic damage; the only engineered utility.",
            "PowerPlant": "A-rate to power Gauss, Plasma Charger, shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate + Dirty Drives — Imperial speed is this hull's survivability, so protect and extend it.",
            "FrameShiftDrive": "A-rated to reach AX zones and Maelstroms; Increased Range with Mass Manager offsets the heavy defensive fit.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — triple Gauss drains the class-7 weapons capacitor faster than anything else on the ship.",
            "Radar": "Drop to D and go Lightweight; AX fights are close-range, so trade sensor range for mass.",
            "FuelTank": "Stock class-5 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under Thargoid fire; Thermal Resistant blunts their thermal damage and Hi-Cap adds raw MJ.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size6": "Guardian HRP (caps at size 5) under-fills this size-6 slot — Guardian armour resists caustic and is unlock-only, not engineerable.",
            "Slot04_Size5": "Guardian Module Reinforcement protects the cores from penetrating hits — the hardening the missing military slots would have given; not engineerable.",
            "Slot05_Size5": "Second Guardian MRP spreads internal damage further; Guardian tech carries no blueprint.",
            "Slot06_Size5": "Second size-5 Guardian HRP — the bulk of the caustic-resistant effective armour; unlock-only.",
            "Slot07_Size4": "Decontamination Limpet Controller cleans caustic off the hull; the controller maxes at size 3, so it under-fills this size-4 slot, and limpet controllers have no blueprint.",
            "Slot08_Size3": "Size-3 Guardian HRP adds more caustic-resistant armour from the mid optionals; not engineerable.",
            "Slot09_Size2": "Standard Hull Reinforcement — the one reinforcement that CAN be engineered: Heavy Duty + Deep Plating.",
            "Slot10_Size1": "Smallest optional — a size-1 Guardian HRP squeezes a last sliver of caustic-resistant armour; unlock-only."
          },
