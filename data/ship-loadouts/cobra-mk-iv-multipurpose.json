  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A practical, capacious multirole fit. Initial is buy-only; A-rated is the multirole baseline; Engineered makes a sturdy, well-armed little do-everything ship.",
          "callout": {
            "label": "More room than the Mk III",
            "text": "The Mk IV's ten optionals and five guns give it more cargo and firepower than the Mk III — re-tune with a fuel scoop and SRV to explore, cargo to trade, or all guns for combat. It just won't move as fast doing any of it."
          },
          "notes": {
            "MediumHardpoint1": "Medium gimballed multi-cannon is the main kinetic gun; Overcharged adds DPS and one Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Medium gimballed pulse for shield work; Efficient keeps heat and draw low, Thermal Vent runs it cold.",
            "SmallHardpoint1": "Small gimballed multi-cannon fills out the kinetic side; Auto Loader keeps it firing without reload pauses.",
            "SmallHardpoint2": "Small gimballed pulse adds laser pressure on shields; Efficient + Thermal Vent keeps it cool and cheap on the distributor.",
            "SmallHardpoint3": "Second small multi-cannon for sustained chip damage; Auto Loader removes the reload gap.",
            "TinyHardpoint1": "Single shield booster on the bi-weave; Heavy Duty is the cheapest large multiplier on raw shield MJ.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate to power five guns, the bi-weave and a cell bank; Overcharged adds headroom and Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated thrusters with Dirty Drives recover some of the pace this heavier-than-Mk-III hull gives up; Drag Drives lifts top speed.",
            "FrameShiftDrive": "A-rate and max Increased Range so the all-rounder still jumps well for travel and light exploration; Mass Manager squeezes out more.",
            "LifeSupport": "D-rate to save mass — capacity is identical; Lightweight trims more and life support takes no experimental.",
            "PowerDistributor": "A-rate the size-3 distributor so guns and boost stay fed; Engine Focused + Super Conduits favour mobility for a jack-of-all-trades.",
            "Radar": "D-rate and go Lightweight; a multirole hull needs no sensor range, so save the mass.",
            "FuelTank": "Stock 4C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size4": "Bi-weave generator regenerates fast under fire for survivability across every role; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size2": "Hull reinforcement for armour insurance across roles; Heavy Duty + Deep Plating is the cheapest effective-armour gain.",
            "Slot08_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 4,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 4,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
