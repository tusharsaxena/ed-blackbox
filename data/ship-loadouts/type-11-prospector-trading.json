      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defended medium-pad trade fit built on the Type-11's speed and shields. Initial is a buy-only starter with a shield from day one; A-Rated is the trade baseline; Engineered maximises protected cargo and laden pace. The catch is structural — two of its size-5 internals are locked to a limpet controller and fighter bay, so cargo tops out near ~256 t behind a shield.",
          "callout": {
            "label": "Shield, fill with cargo — and accept the locked slots",
            "text": "Drop a bi-weave into one size-5 internal, stack two Heavy-Duty boosters, then pack every unrestricted slot with cargo. This trade fit skips deterrent guns — four hardpoints are mining-locked, the other four left empty — and two size-5 optionals only accept a limpet controller or a fighter bay, so the Type-11 hauls less than its hull size suggests — its trade case is speed and reach, not raw tonnage."
          },
          "notes": {
            "TinyHardpoint1": "First Heavy-Duty shield booster — multiplies the bi-weave's MJ so an interdicting pirate can't crack the hold before you boost clear.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength for a defended hauler.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and to shed interdiction heat.",
            "PowerPlant": "A-rate to run the shield, boosters and distributor; Low Emissions keeps the signature low so you draw less attention on trade routes.",
            "MainEngines": "Speed is the trader's main defence — A-rated + Dirty Drives keep a laden hull fast enough to boost clear of interdiction.",
            "FrameShiftDrive": "A-rate and max Increased Range first — the Type-11's short laden range is its weakest trading trait; Mass Manager stretches every jump.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "The class-7 distributor is already oversized — Engine Focused biases it to the engines so a laden hull keeps boosting away from trouble.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass for cargo and range.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot02_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot03_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size5": "One size-5 internal becomes a bi-weave shield — it regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot08_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot10_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
