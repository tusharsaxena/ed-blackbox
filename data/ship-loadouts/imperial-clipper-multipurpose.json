  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit — a couple of guns, a bi-weave buffer, cargo room and a usable range, ready to re-tune for any role. Initial is buy-only; A-rated is the multirole baseline; Engineered weights the house pattern toward speed and shields.",
          "callout": {
            "label": "Built to re-tune",
            "text": "This is one balanced configuration; the Clipper's flexibility is swapping module sets at a station — strip guns and reinforcement for a fuel scoop, SRV and a DSS to explore; fill the slots with cargo racks to haul; lean back into shields and guns for combat. Keep role-specific sets in storage and switch as the week demands — just remember its room and range are smaller than a true generalist's."
          },
          "notes": {
            "LargeHardpoint1": "Large gimballed multi-cannon as the main gun; Overcharged for damage and the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Large gimballed beam for shield-stripping; Efficient runs it cool and Thermal Vent vents heat under sustained fire.",
            "MediumHardpoint1": "Medium gimballed multi-cannon fills out the broadside; Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so the battery never stops firing.",
            "TinyHardpoint1": "Shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more buffer before utilities turn to defence.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers four guns, a bi-weave and boost; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives with Drag Drives — speed is the Clipper's whole edge, so protect it first.",
            "FrameShiftDrive": "A-rated + Increased Range with Mass Manager to lift the Clipper's modest jump range for travel and errands.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate + Charge Enhanced with Super Conduits so weapons and boost share one fast-charging class-6 distributor.",
            "Radar": "Drop to D and go Lightweight; a multirole hull needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Fast Charge speeds recovery for combat, hauling and mining alike.",
            "Slot03_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size4": "Heavy-Duty hull reinforcement with Deep Plating is the cheapest large multiplier on effective armour.",
            "Slot05_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size2": "Second Heavy-Duty HRP with Deep Plating; armour stacks linearly.",
            "Slot08_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
