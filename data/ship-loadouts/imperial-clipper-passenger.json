  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A fast passenger fit — a cabin suite, a defensive bi-weave and high-rated drives, with the hardpoints left clean. Initial is buy-only; A-rated is the passenger baseline; Engineered preserves the Clipper's signature speed so it outruns interdiction with the manifest intact.",
          "callout": {
            "label": "Cabins for the board, speed for the run",
            "text": "Fit the cabin mix the board demands — economy for bulk tourist loops, a first or luxury suite for VIP fares — and lean on the Clipper's pace to turn runs over fast and dodge interdiction. Keep a real bi-weave and point defence: the Clipper survives by leaving, not by tanking, so A-rate and engineer the thrusters so it simply boosts away."
          },
          "notes": {
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large multiplier on the bi-weave's buffer.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more raw MJ for the seconds before you escape.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rated for cabins, shield and modules; Low Emissions keeps the heat and signature down on a soft hull.",
            "MainEngines": "A-rate FIRST — speed is the Clipper's whole edge and its defence; Dirty Drives + Drag Drives maximise top end.",
            "FrameShiftDrive": "A-rated with Increased Range to chain tourist beacons; Mass Manager offsets the cabin and shield mass.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rated, Engine Focused + Super Conduits to feed the boost the escape relies on.",
            "Radar": "Drop to D and go Lightweight; passenger runs need no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Largest cabin slot; a size-6 cabin (the max) under-fills it — economy for bulk fares, business for higher-paying loops.",
            "Slot02_Size6": "VIP suite — a First Class size-6 cabin for premium boards; swap to Luxury when the VIP fare demands it.",
            "Slot03_Size4": "Real bi-weave buffer; Reinforced maximises MJ and Fast Charge regenerates it quickly between boosts.",
            "Slot04_Size4": "Mid economy cabin to pad bulk-tourist headcount; cabins are not engineerable.",
            "Slot05_Size3": "Economy cabin filling out the bulk manifest; not engineerable.",
            "Slot06_Size3": "Business cabin for higher-value VIP groups; not engineerable.",
            "Slot07_Size2": "Smallest economy cabin tops up the headcount; not engineerable.",
            "Slot08_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Thrusters",
              "size": 6,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Power Plant",
              "size": 6,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 4,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Power Distributor",
              "size": 6,
              "grade": "G5",
              "blueprint": "Engine Focused",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Life Support / Sensors",
              "grade": "G5",
