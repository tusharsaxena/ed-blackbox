  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A dedicated mining fit built around sustained tool output and survivability. Initial is a working laser-mining starter; A-Rated is the efficient all-method baseline; Engineered tunes the cores and shield. The mining tools themselves carry no blueprints, but the class-7 distributor lets them run flat-out.",
          "callout": {
            "label": "Sustain is the whole point",
            "text": "The class-7 distributor means you never throttle the tools — fit the full mining suite and run it continuously. Balance collector controllers (throughput) against a couple of prospectors (yield), and keep the bi-weave for working hot rings."
          },
          "notes": {
            "LargeHardpoint1": "The Type-11's signature large mining tool — primary continuous laser-mining output; mining tools carry no engineering.",
            "MediumHardpoint1": "Medium mining laser for added sustained laser extraction; not engineerable.",
            "MediumHardpoint2": "Seismic Charge Launcher cracks motherlode rocks for core mining; no blueprint exists.",
            "MediumHardpoint3": "Sub-surface Displacement Missile pulls embedded deposits; mining tools aren't engineered.",
            "SmallHardpoint1": "Abrasion Blaster strips surface deposits off rocks; not engineerable.",
            "SmallHardpoint2": "Small sub-surface missile adds a second extraction mount; no blueprint.",
            "TinyHardpoint1": "A-rated Pulse Wave Analyser lights up mineable and core-bearing rocks at a glance.",
            "TinyHardpoint2": "Heavy-Duty shield booster multiplies the bi-weave's MJ to tank pirate fire while you escape.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Second Heavy-Duty booster — a cheap, large gain in shield strength for hot rings.",
            "PowerPlant": "A-rated for the tool, limpet, refinery and shield load; Low Emissions keeps the signature low at busy rings.",
            "MainEngines": "A-rated + Dirty Drives for the speed to work a ring and outrun pirates.",
            "FrameShiftDrive": "A-rated + Increased Range shortens laden runs to the best market.",
            "LifeSupport": "D-rated to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "The class-7 heart — A-rate it so the tools never throttle; Charge Enhanced refills the reservoir faster.",
            "Radar": "D-rated and Lightweight; mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size5": "Bi-weave regenerates fast under fire — Reinforced + Hi-Cap to work hot rings safely.",
            "Slot06_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot08_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot09_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot10_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot11_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Distributor",
