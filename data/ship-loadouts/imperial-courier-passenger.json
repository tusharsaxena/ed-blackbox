  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A featherweight short-haul passenger fit: a small mixed cabin board — one Business-class cabin plus economy seating — behind a bi-weave shield, with the range and speed a 35t hull gives for free. Initial is buy-only; A-rated is the working baseline; Engineered maximises range and keeps the passengers safe. The Courier is tiny for the role — ~11 seats, no cabin bigger than Business — so it is a boutique VIP runabout, not a volume liner.",
          "callout": {
            "label": "Tiny board, real reach",
            "text": "The Courier's optional internals top out at size 3, so it can never fit a First- or Luxury-class cabin and carries only ~11 seats fully loaded. What it does bring is a very light hull: strong jump range, blistering speed for safety, and small-pad access to any outpost. Fly it for short high-value or Business-class fares, not for bulk tourist volume."
          },
          "notes": {
            "TinyHardpoint1": "A-rated shield booster; Heavy Duty multiplies the small bi-weave's raw MJ — cheap passenger safety on a light hull.",
            "TinyHardpoint2": "Second Heavy-Duty booster; stacking is the cheapest way to a shield that survives an interdiction.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes aimed at a fragile passenger hull.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire so you can boost clear.",
            "PowerPlant": "Low Emissions keeps the plant cool and quiet for a comfortable, low-signature run; Thermal Spread bleeds the last of the heat.",
            "MainEngines": "A-rated with Dirty Drives for the speed to shake an interdiction — the Courier's real safety is never being caught; Drag Drives sharpens boost.",
            "FrameShiftDrive": "A-rated and Increased Range at G5 with Mass Manager — the point of so light a hull is reach; the Courier jumps well for a passenger ship.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more to stretch jump range. Life support has no experimental effect.",
            "PowerDistributor": "Engine Focused biases the class-3 distributor toward boosting away from danger; Cluster Capacitors deepens the reservoir.",
            "Radar": "Drop to D and go Lightweight — a liner needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock class-C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Business-Class Cabin 3 (3 seats) is the premium fare this hull can carry — its size-3 slots can't take First or Luxury cabins, so Business is the ceiling.",
            "Slot02_Size3": "Economy Cabin 3 (4 seats) carries the bulk of the headcount; swap to a second Business cabin for an all-premium board at the cost of two seats.",
            "Slot03_Size2": "Economy Cabin 2 (2 seats) — size-2 slots only accept economy cabins, so no premium fits here.",
            "Slot04_Size2": "Second Economy Cabin 2 (2 seats) tops up the small board.",
            "Slot05_Size2": "Bi-weave shield regenerates fast under fire for passenger safety; Reinforced maximises MJ and Fast Charge speeds the recharge — sized to the light hull.",
            "Slot06_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size1": "Advanced Docking Computer auto-docks for a smooth arrival — a small comfort touch; docking computers aren't engineerable.",
            "Slot08_Size1": "Fuel scoop lets you top up on scenic routes so the small tank never strands a fare; scoops aren't engineerable."
          },
          "engineeringPlan": [
            {
