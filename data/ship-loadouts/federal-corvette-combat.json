  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "An apex combat fit: two huge main guns, deep shields and reinforcement, eight utilities and an SLF bay. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern at battleship scale.",
          "callout": {
            "label": "Two huge guns define it",
            "text": "The Corvette's identity is its pair of huge hardpoints — huge multi-cannons (one Corrosive) deliver alpha nothing else can. Build the rest of the ship to keep those two guns firing and on target."
          },
          "notes": {
            "HugeHardpoint1": "Primary huge mount; the single Corrosive Shell strips armour resistance for the whole battery.",
            "HugeHardpoint2": "Second huge mount; Auto Loader removes reloads so it never stops firing.",
            "LargeHardpoint1": "Beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "MediumHardpoint1": "Fill-in multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint2": "Buy a cheap pulse, swap to a Thermal-Vent beam once A-rated for heat-free shield work.",
            "SmallHardpoint1": "Small multi-cannon adds chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Left empty on the buy-only fit; add an Efficient pulse once the hull is paid off.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth booster rounds out the shield stack before utilities turn to defence.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Fifth Heavy-Duty booster in the last utility once credits allow.",
            "PowerPlant": "Powers eight guns, SLF, a big shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the capital agility that defines the Corvette.",
            "FrameShiftDrive": "A-rated to move a 900t hull between fights; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — two huge guns plus boost drain the class-8 distributor faster than anything else.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size7": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size7": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size7": "SLF bay adds a second gun platform that draws fire; hangars are not engineerable.",
            "Slot04_Size6": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-6 slot for max effective armour.",
            "Slot05_Size6": "Second 5D HRP (HRP's largest) under-filling a size-6 slot — armour stacks linearly.",
            "Slot06_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size5": "Module Reinforcement protects the cores; not engineerable.",
            "Slot08_Size4": "More Heavy-Duty hull where the slot allows.",
            "Slot09_Size4": "More internal protection for the modules that keep you flying.",
            "Slot10_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot11_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 8,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
