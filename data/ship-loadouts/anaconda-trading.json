  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defensible trade fit that keeps a bi-weave shield, a booster suite and a single deterrent gun, then fills every remaining slot with cargo. Initial is cheapest buy-only with a shield from day one; A-rated is the trade baseline; Engineered maximises laden range and protected cargo.",
          "callout": {
            "label": "Shield first, then fill with cargo",
            "text": "The Anaconda's trade edge over a Type-9 is that it survives and fights back — keep the bi-weave shield, the booster stack and one deterrent multi-cannon, then fill the rest with cargo racks. Strip the shield and guns and it carries more, but then a Type-9 simply does it cheaper and bigger."
          },
          "notes": {
            "HugeHardpoint1": "One huge gimballed multi-cannon as a deterrent; Overcharged for damage and Corrosive Shell so the single gun still bites through armour.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ to protect the cargo.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth Heavy-Duty booster rounds out the shield stack before the utilities turn to countermeasures.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Fifth Heavy-Duty booster in the last utility pair once credits allow.",
            "TinyHardpoint8": "Sixth Heavy-Duty booster completes the protective shield stack.",
            "PowerPlant": "Low Emissions keeps the plant cool and quiet for a low signature on contested routes; Thermal Spread bleeds the remaining heat.",
            "MainEngines": "A-rated + Dirty Drives keep the ponderous 400t hull as mobile as it can be when laden.",
            "FrameShiftDrive": "A-rated G5 Increased Range is the Anaconda's standout trading asset; Mass Manager extends the laden jump on long loops.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "Engine Focused sustains boost to escape interdictions; Super Conduits enlarges the engine capacitor.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass for cargo and range.",
            "FuelTank": "Stock C tank sized to the long laden jumps; fuel capacity cannot be engineered.",
            "Military01": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot01_Size7": "Bi-weave regenerates fast under fire — the right shield for surviving a hit and running; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot10_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot11_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
