  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "An exploration fit wrung out of a small combat hull. Initial is a jump-capable buy-only starter; A-Rated is the best buy-only expedition fit; Engineered is the long-range end state — everything trimmed for mass around a size-4 SCO drive and a Guardian booster. Plans and costs follow in the sections below.",
          "callout": {
            "label": "A combat hull pressed into exploration",
            "text": "The Kestrel jumps around ~48 LY engineered — short for the price, because a size-4 FSD dragging a 190 t combat hull can't match a dedicated explorer. The Guardian FSD Booster (a flat range gain) and the class-5 fuel scoop are the two modules that make it viable; the single military slot is dead weight for an explorer, so treat the module reinforcement there as optional."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets on a warm combat plant.",
            "TinyHardpoint2": "Second heat-sink launcher; the Kestrel's combat plant runs warmer than a dedicated explorer, so extra heat charges earn their slot.",
            "TinyHardpoint3": "One light booster cheaply multiplies the bi-weave's raw MJ for safer landings; Heavy Duty + Super Capacitors is the biggest gain per tonne.",
            "PowerPlant": "5D keeps mass down — with no guns to feed, output is not the limit; Low Emissions cuts heat and draw on a hot combat plant, Thermal Spread bleeds more.",
            "MainEngines": "5D thrusters; Clean Drive Tuning runs cool for safe planetary work, Drag Drives adds boost speed to climb out of gravity wells.",
            "FrameShiftDrive": "The whole build — a 4A SCO drive for maximum range and fast in-system travel; Increased Range + Mass Manager is the single biggest roll in exploration, but a size-4 drive caps the ceiling.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "5D is plenty without weapons; Engine Focused + Cluster Capacitors gives engine-capacitor headroom for repeated boosts on landing approaches — optional.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock 4C tank; fuel capacity is fixed and cannot be engineered, and the size-4 tank means shorter jump chains than a dedicated explorer.",
            "Military01": "The lone military slot cannot take a scoop, booster or scanner, so it is wasted mass for an explorer; a light Module Reinforcement protects internals on rough exobiology landings, or leave it empty for a little more range.",
            "Slot01_Size5": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. A class-5 scoop is the biggest this hull's largest optional takes.",
            "Slot02_Size4": "The Guardian FSD Booster (size 4) — a flat jump-range gain unlocked at a Guardian site, not bought; non-negotiable and not engineerable.",
            "Slot03_Size3": "A light size-3 bi-weave for a fast-regenerating landing buffer; Enhanced Low Power + Lo-Draw keeps its draw minimal (bi-weaves are C-rated only).",
            "Slot04_Size2": "A size-2 AFMU repairs modules on the long haul; Shielded hardens it.",
            "Slot05_Size2": "A light size-2 SRV hangar (1 bay) for exobiology and Guardian-site runs; hangars carry no blueprint.",
            "Slot06_Size2": "A second AFMU for redundancy so each can repair the other; Shielded hardens it.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
