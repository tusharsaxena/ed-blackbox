  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A fully equipped expedition fit using the Phantom's deep, weight-light internals. Initial is a jump-capable buy-only starter; A-Rated is the expedition baseline; Engineered maximises range while keeping full kit and redundancy aboard. Plans and costs follow in the sections below.",
          "callout": {
            "label": "Full kit, no compromise",
            "text": "The Phantom's nine optionals carry a class-6 scoop, the class-5 Guardian booster, an SRV bay, dual AFMUs and a scanner all at once — a fully self-sufficient expedition ship that still jumps ~75 LY. Few explorers carry this much without losing range. Mind that the scoop tops out at class 6, so refuel a touch earlier than a capital would."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "One light booster cheaply multiplies the bi-weave's raw MJ for safer landings; Heavy Duty + Super Capacitors is the biggest gain per tonne.",
            "PowerPlant": "7D keeps mass down — with no guns to feed, output is not the limit; Low Emissions cuts heat and draw, Thermal Spread bleeds more.",
            "MainEngines": "6D thrusters; Clean Drive Tuning runs cool for safe planetary work, Drag Drives adds boost speed to climb out of gravity wells.",
            "FrameShiftDrive": "The whole build — a 5A SCO drive for maximum range and fast in-system travel; Increased Range + Mass Manager is the single biggest roll in exploration.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "7D is plenty without weapons; Engine Focused + Cluster Capacitors gives engine-capacitor headroom for repeated boosts on landing approaches.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size5": "The Guardian FSD Booster — a flat jump-range gain unlocked at a Guardian site, not bought; size 5 is the largest and it is non-negotiable and not engineerable.",
            "Slot03_Size5": "A size-4 multi-SRV hangar for exobiology and Guardian-site runs (it under-fills this size-5 bay); hangars carry no blueprint.",
            "Slot04_Size5": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size3": "A light size-3 bi-weave for a fast-regenerating landing buffer; Enhanced Low Power + Lo-Draw keeps its draw minimal (bi-weaves are C-rated only).",
            "Slot06_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size3": "A repair limpet controller for hull repairs the AFMU cannot reach; swap for extra fuel if you prefer, and it carries no blueprint.",
            "Slot08_Size2": "A size-2 economy cabin for tourist legs, or swap for a science/utility module; passenger cabins are not engineerable.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
