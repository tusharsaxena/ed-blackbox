        "edbb": {
          "role": "trading",
          "intro": "A high-capacity medium-pad trade fit that keeps a shield. Initial is buy-only; A-rated is the trade baseline; Engineered maximises protected cargo and laden range.",
          "callout": {
            "label": "Big hold, real shield",
            "text": "The Type-8's depth lets it carry more than 330 tonnes while keeping a class-6 bi-weave and a booster suite — far more defensible than a stripped Type-9. Run it shielded; the medium pad means you can reach safer high-margin stations anyway."
          },
          "notes": {
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ to protect the hold.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength for a hauler.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "5A covers shield, cells and modules; Low Emissions runs cold and quiet, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives give the speed to escape the interdictions the big haulers can't.",
            "FrameShiftDrive": "A-rated with Increased Range + Mass Manager for laden jump range across trade routes.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "The Type-8's weak class-4 distributor; A-rate and Engine Focused so it sustains the boosts that escape trouble.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-5 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
