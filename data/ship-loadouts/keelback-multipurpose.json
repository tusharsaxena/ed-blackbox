  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced budget multirole fit — light guns, a bi-weave shield, cargo room, a scanner and the fighter bay — ready to re-tune for any one job. Initial is buy-only; A-rated is the multirole baseline; Engineered targets mobility, range and a little defence so the mods carry across role swaps.",
          "callout": {
            "label": "Built to re-tune",
            "text": "This is one balanced configuration; the Keelback's strength is swapping cheap module sets at a station — fill with cargo racks to haul, drop in a refinery and limpets to mine, add a fuel scoop and scanner to scout, or keep the fighter bay for backup. Engineer the cores once and they carry their mods between every role."
          },
          "notes": {
            "MediumHardpoint1": "Primary gimballed multi-cannon; Overcharged for DPS and a single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Gimballed pulse for shield work; Efficient + Thermal Vent runs it cold on a heat-tight hull.",
            "SmallHardpoint1": "Small gimballed multi-cannon adds chip damage; Auto Loader keeps it firing without reloads.",
            "SmallHardpoint2": "Flexible small mount — gimballed pulse here for the combat baseline; swap to a mining laser or limpet controller when the role changes.",
            "TinyHardpoint1": "Lone utility booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large shield gain.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate to power guns, shield and the SLF; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives lift a sluggish hull to a usable pace across every role.",
            "FrameShiftDrive": "A-rate then max Increased Range — jump is the stat that helps trade legs and scouting most; Mass Manager squeezes out more.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate for weapon and engine pips; Charge Enhanced + Super Conduits keep the small class-3 distributor from starving the guns.",
            "Radar": "Drop to D and go Lightweight; a budget all-rounder needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size5": "The Keelback's party trick — a size-5 fighter bay for a second gun platform that draws fire; hangars are not engineerable.",
            "Slot03_Size4": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Fast Charge speeds the recharge — survivability across every job.",
            "Slot04_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size2": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour; Deep Plating adds raw HP.",
            "Slot06_Size2": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
