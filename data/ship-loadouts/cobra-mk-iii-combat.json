  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A versatile budget combat fit. Initial is buy-only and keeps cargo room; A-rated is the combat-ready baseline; Engineered applies the house combat pattern — leaning on speed and a bi-weave since the shields are thin and the guns small-class.",
          "callout": {
            "label": "Fight, then re-role",
            "text": "The Cobra Mk III's charm is flexibility — keep a bi-weave and light reinforcement for combat, but its deep optionals can swap to cargo racks in minutes to turn the fighter into a hauler or explorer."
          },
          "notes": {
            "MediumHardpoint1": "Primary medium multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint1": "Gimballed pulse for shield-stripping; Efficient cuts heat and draw, Thermal Vent runs it cold.",
            "SmallHardpoint2": "Left empty on the buy-only fit; a second Efficient pulse once the hull is paid off doubles the laser output.",
            "TinyHardpoint1": "One of only two utilities — a Heavy-Duty booster multiplies the thin bi-weave's raw MJ for the cheapest tank gain.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "PowerPlant": "A-rate to power four guns, a shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate FIRST — speed lets the Cobra dictate range and escape; Dirty Drives push the boost that defines it.",
            "FrameShiftDrive": "A-rated for range across the Cobra's many roles; only G3 Increased Range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate early — four guns plus boost drain the small class-3 distributor fast; Charge Enhanced restores the WEP pool.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size4": "Bi-weave regenerates fast under fire — the right shield for a thin-hulled brawler; Reinforced maximises its MJ, Fast Charge speeds the rebuild.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size4": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stacks integrity.",
            "Slot04_Size2": "Second Heavy-Duty hull reinforcement — armour stacks linearly across the optionals.",
            "Slot05_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size2": "Module Reinforcement spreads penetrating-hit damage across the internals; not engineerable.",
            "Slot07_Size1": "Class-1 slot takes a small Heavy-Duty HRP for a little more effective armour.",
            "Slot08_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies."
          },
          "engineeringPlan": [
            {
              "module": "Thrusters",
              "size": 4,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Power Plant",
              "size": 4,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
