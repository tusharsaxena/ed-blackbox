  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A warship pressed into hauling: keep a bi-weave shield, a booster stack and one deterrent huge gun, then fill every remaining optional with cargo. Initial is buy-only with a shield from day one; A-rated is the trade baseline; Engineered maximises laden range and protected cargo behind the toughest hull in the trade field.",
          "callout": {
            "label": "The most survivable hold there is",
            "text": "The Corvette's trade case is protection, not economy — eight utilities, two military slots and a huge deterrent gun make it the single hardest-to-rob hauler in the game. It carries ~490 t behind a full shield, but it costs ~183M Cr, needs Federal Rear Admiral, and crawls at 260 m/s boost. Fly it only if you already earned it."
          },
          "notes": {
            "HugeHardpoint1": "One huge gimballed multi-cannon as a deterrent; Overcharged for damage and Corrosive Shell so the single gun still bites through armour when a pirate presses.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ to protect the cargo.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth Heavy-Duty booster rounds out the front of the shield stack.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running to slip past a threat.",
            "TinyHardpoint7": "Fifth Heavy-Duty booster in the last utility pair once credits allow.",
            "TinyHardpoint8": "Sixth Heavy-Duty booster completes the protective shield stack.",
            "PowerPlant": "Low Emissions keeps the plant cool and quiet for a low signature on contested routes; Thermal Spread bleeds the remaining heat.",
            "MainEngines": "A-rated + Dirty Drives keep the ponderous 900t hull as mobile as it can be when laden.",
            "FrameShiftDrive": "A-rated G5 Increased Range is the only lever on the Corvette's poor laden jump; Mass Manager extends it further on long loops.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "Engine Focused sustains boost to escape interdictions; Super Conduits enlarges the engine capacitor.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass for cargo and range.",
            "FuelTank": "Stock C tank; fuel capacity cannot be engineered.",
            "Military01": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size7": "Bi-weave regenerates fast under fire — the right shield for surviving a hit and running; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size7": "Optional — a class-7 rack, the largest single block of cargo. Cargo racks aren't engineerable.",
            "Slot03_Size7": "Optional — second class-7 rack. Cargo racks aren't engineerable.",
            "Slot04_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot07_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot08_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot10_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot11_Size1": "Optional — the small size-1 rack tops off the hold. Cargo racks aren't engineerable."
          },
          "engineeringPlan": [
