  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A high-capacity liner fit: a vast mixed cabin suite, a fast-charging bi-weave for passenger safety, and a long-range FSD on a 950t hull. Initial is buy-only (two economy cabins to start earning); A-Rated is the liner baseline; Engineered trades mass for range and hardens the shield. Cabin classes are swap-to-suit — pack economy for bulk tourist runs, first/luxury for VIP fares.",
          "callout": {
            "label": "Match cabins to the board",
            "text": "The Beluga's edge is filling the largest cabin suite in the game to suit demand — economy for volume, first/business/luxury for VIPs that pay far more per seat. Luxury cabins only fit size-5+ slots and first-class size-4+, so keep the big internals for premium berths. Keep the bi-weave and point defence for threatened routes; the liner comfort bonus applies to every fare."
          },
          "notes": {
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large multiplier on the bi-weave's MJ to keep VIPs safe.",
            "TinyHardpoint2": "Second Heavy-Duty booster; stacking is the bulk of a liner's shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Third Heavy-Duty booster rounds out the shield stack; sixth utility left free as a spare.",
            "PowerPlant": "6A powers cabins, shields and modules; Low Emissions runs cool and quiet so the liner draws less heat on busy routes.",
            "MainEngines": "7A + Dirty Drives give the heavy 950t hull the speed to escape interdiction with passengers aboard.",
            "FrameShiftDrive": "7A is the single most important module — Increased Range + Mass Manager reaches the scenic spots that pay.",
            "LifeSupport": "D-rate to shed mass for range; Lightweight trims more — life support only needs to outlast an emergency, not be A-rated.",
            "PowerDistributor": "6A holds the ENG capacitor for boosting; Engine Focused biases it to engines so the heavy hull boosts free of interdiction.",
            "Radar": "D-rate and go Lightweight — a liner needs no sensor range, so the mass saving buys jump range.",
            "FuelTank": "7C stock tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Economy Cabin 6 — 32 seats; bulk of the passenger payload for high-volume tourist runs.",
            "Slot02_Size6": "Second Economy Cabin 6 — maximum economy volume where the board wants headcount.",
            "Slot03_Size6": "First Class Cabin 6 for premium fares; first-class needs a size-4+ slot, so a big internal earns it.",
            "Slot04_Size6": "Bi-Weave 6 (its mass limit covers the 950t hull); Reinforced maxes MJ, Fast Charge restores the bi-weave's quick regen.",
            "Slot05_Size5": "Economy Cabin 5 — 16 more seats; swap to business when the board pays for comfort.",
            "Slot06_Size5": "Luxury Cabin 5 for top-tier VIP sightseeing — luxury only fits size-5 and up, so this is the smallest luxury berth.",
            "Slot07_Size4": "Economy Cabin 4 — 8 seats; swap to first-class (size-4 minimum) for a premium berth.",
            "Slot08_Size3": "Economy Cabin 3 — 4 seats of flexible economy volume.",
            "Slot09_Size3": "Economy Cabin 3 — more economy headcount; size-3 slots can't take first/luxury.",
            "Slot10_Size3": "Business Cabin 3 — the best premium class that fits a size-3 slot (first/luxury need larger).",
            "Slot11_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
