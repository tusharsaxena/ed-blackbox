        "edbb": {
          "role": "exploration",
          "intro": "A capital expedition fit using the vast internals. Initial is buy-only; A-rated is the expedition baseline; Engineered maximises range while carrying full kit and redundancy. Hardpoints stay empty — an explorer runs clean.",
          "callout": {
            "label": "Capital capacity and redundancy",
            "text": "The Anaconda carries the biggest scoop, a multi-SRV bay, two or three AFMUs (one in the protected military slot), scanner, comforts and extra fuel all at once — capital-scale self-sufficiency, while still jumping ~78 LY."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "A light shield booster pads the landing shield; Heavy Duty maximises its raw MJ for botched touchdowns.",
            "PowerPlant": "D-rated to save mass; Low Emissions keeps heat low while scooping and Thermal Spread bleeds the rest.",
            "MainEngines": "D-rated for mass; Clean Drive Tuning runs cool and Stripped Down sheds weight for range.",
            "FrameShiftDrive": "A-rated and the heart of the build; Increased Range plus Mass Manager drives the ~78 LY jump.",
            "LifeSupport": "D-rated and Lightweight to trim mass; life support has no experimental effect.",
            "PowerDistributor": "D-rated; Engine Focused keeps the engine pip charged for boosting and high-wake escapes.",
            "Radar": "D-rated and Lightweight — exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot01_Size7": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size6": "Guardian FSD Booster size 5 is the largest flat jump-range bonus available; it under-fills the size-6 slot and carries no blueprint.",
            "Slot03_Size6": "Multi-SRV Planetary Vehicle Hangar for surface science and exobiology; hangars carry no blueprint.",
            "Slot04_Size6": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size5": "A light bi-weave for landing safety; Enhanced Low Power plus Stripped Down keep its mass and power draw minimal.",
            "Slot06_Size5": "Repair Limpet Controller patches hull damage the AFMU can't touch; limpet controllers carry no blueprint.",
            "Slot07_Size5": "Flex slot — an economy cabin for tourism, or swap for science or extra storage per trip; cabins aren't engineerable.",
            "Slot08_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
