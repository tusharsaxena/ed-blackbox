      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A fast, agile dogfighting fit built around the medium gun. Initial is buy-only; A-rated is the combat-ready baseline; Engineered maximises agility, speed and the thin shield.",
          "callout": {
            "label": "Speed and agility carry it",
            "text": "Like the base Eagle, the Imperial version survives by not being hit — engineer thrusters and a bi-weave, lead with the medium gun, and stay on the enemy's blind side. The extra speed helps you disengage; the thin hull still punishes mistakes."
          },
          "notes": {
            "MediumHardpoint1": "The ship's main gun — buy a cheap pulse, swap to a gimballed multi-cannon once A-rated; Overcharged + Corrosive Shell makes it the alpha source.",
            "SmallHardpoint1": "Supporting small pulse; Efficient + Thermal Vent keeps it firing cold on the thin power budget.",
            "SmallHardpoint2": "Second small pulse; Efficient + Thermal Vent for sustained heat-free chip damage.",
            "TinyHardpoint1": "The only utility mount — a shield booster; Heavy Duty multiplies the thin bi-weave's raw MJ.",
            "PowerPlant": "Only a class-3 plant, so Overcharged buys the headroom for three guns, shield and booster; Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate and engineer FIRST — speed and agility are this hull's only real defence; Dirty Drives + Drag Drives maximise both.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; G3 Increased Range is enough — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate early — sustaining three guns plus boost on a class-2 distributor is tight; Charge Enhanced + Super Conduits fix it.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass on a featherweight hull.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in the military slot is the cheapest large multiplier on a paper-thin hull.",
            "Slot01_Size3": "Bi-weave shield generator — the thin shield needs fast regen; Reinforced raises its MJ and Fast Charge speeds the recharge.",
            "Slot02_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size1": "Small hull reinforcement; Heavy Duty for a little more effective armour on the thin hull.",
            "Slot04_Size1": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot05_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot06_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies."
          },
