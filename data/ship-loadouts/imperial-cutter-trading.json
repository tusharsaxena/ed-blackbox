        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defensible bulk-trade fit built around the game's best shields. Initial is buy-only; A-rated is the trade baseline; Engineered maximises protected cargo and laden range.",
          "callout": {
            "label": "Prismatic shield, then cargo",
            "text": "The Cutter's edge is protection — fit a prismatic generator in a class-8 slot and a full booster suite, then fill the rest with cargo. You lose some tonnage versus a stripped Type-9, but your fortune is genuinely safe and you can outrun what you can't out-tank."
          },
          "notes": {
            "TinyHardpoint1": "First Heavy-Duty shield booster; multiplies the prismatic's raw MJ — the cheapest big gain in protection.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more shield strength around the cargo.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Fourth Heavy-Duty booster continues the shield stack.",
            "TinyHardpoint7": "Fifth Heavy-Duty booster pushes the prismatic past what a pirate can break quickly.",
            "TinyHardpoint8": "Sixth Heavy-Duty booster maxes the utility shield stack.",
            "PowerPlant": "A-rated for headroom; Low Emissions keeps heat and signature low for smuggling, Thermal Spread bleeds the rest.",
            "MainEngines": "A-rated + Dirty Drives preserve the speed that lets a laden Cutter outrun pirates.",
            "FrameShiftDrive": "A-rated for laden range; Increased Range + Mass Manager soften the cargo-mass penalty on jumps.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rated; Engine Focused + Super Conduits sustain the repeated boosts that break interdiction.",
            "Radar": "Drop to D and go Lightweight; a hauler needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Military02": "Module Reinforcement in the second Military slot shields internals from penetrating hits; not engineerable.",
            "Slot01_Size8": "Prismatic generator in the largest slot — the strongest shield in the game; Reinforced + Hi-Cap maximise raw MJ.",
            "Slot02_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
