  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete mining fit for laser and core work that relies on speed, not guns, for safety — the full tool kit uses all four hardpoints, leaving none for a weapon. Initial is a working buy-only miner; A-rated is the mining baseline; Engineered focuses on speed, shield and heat — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "Tools fill every mount",
            "text": "A complete miner: a laser plus the three core tools take all four hardpoints, a Pulse Wave Analyser finds rocks, and a refinery, prospector and collector controllers work the field. There's no slot left for a gun — so the bi-weave buffer plus the Clipper's speed cover the escape when a pirate arrives."
          },
          "notes": {
            "LargeHardpoint1": "Size-2 mining laser is the laser-mining workhorse; mining lasers carry no blueprint, so it stays stock.",
            "LargeHardpoint2": "Abrasion Blaster knocks surface deposits off cores; small-only, fitted on the large mount, and not engineerable.",
            "MediumHardpoint1": "Seismic Charge Launcher cracks high-value cores; no blueprint exists for it.",
            "MediumHardpoint2": "Sub-surface Displacement Missile pulls deep deposits from cracked cores; not engineerable.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineable rocks and core hotspots across the ring; scanners carry no blueprint.",
            "TinyHardpoint2": "First shield booster; Heavy Duty multiplies the bi-weave buffer that buys your escape.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more raw MJ before utilities run out.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate to run lasers, limpets and shield together; Low Emissions keeps heat down across long sessions, Thermal Spread bleeds more.",
            "MainEngines": "Speed is the Clipper's only defence with its hardpoints full of tools — A-rate, then Dirty Drives for maximum boost.",
            "FrameShiftDrive": "A-rate to relocate between rings and reach distant sell markets; Increased Range stretches the legs, Mass Manager offsets the ore.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate so lasers, limpets and boost never brown out; Engine Focused biases the capacitor toward the boost that gets you clear.",
            "Radar": "Drop to D and go Lightweight; a miner needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Bi-weave buffer for the seconds before you boost clear; Reinforced maximises MJ, Fast Charge restores the bi-weave's quick regen.",
            "Slot04_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot05_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot07_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot08_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Thrusters",
              "size": 6,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Power Distributor",
              "size": 6,
              "grade": "G3",
              "blueprint": "Engine Focused",
              "engineer": "The Dweller"
            },
            {
              "module": "Power Plant",
              "size": 6,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 4,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Bulkheads",
              "blueprint": "Lightweight",
              "grade": "G5",
              "engineer": "Selene Jean"
            }
          ]
        }
      }
    },
