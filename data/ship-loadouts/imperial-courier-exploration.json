  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A fast, light touring-explorer fit. Initial is buy-only; A-Rated is the expedition baseline; Engineered maximises range and keeps the speed and shields that define it — almost entirely range and weight work on a featherweight hull, with Felicity Farseer doing most of it.",
          "callout": {
            "label": "Light and fast, not deep",
            "text": "The Courier's small optionals carry only modest kit — a class-3 scoop, Guardian booster, small SRV bay, scanner and one AFMU, with no redundancy. Lean on its speed and shields for in-system work; accept that the longest self-sufficient hauls suit a roomier ship."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "One light booster cheaply multiplies the shield's raw MJ for confident landings; Heavy Duty + Super Capacitors maximise that strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "4D keeps mass down — with no guns to feed, output is not the limit; Low Emissions cuts heat and draw, Thermal Spread bleeds more for cool scooping.",
            "MainEngines": "3D thrusters; Clean Drive Tuning runs cool for safe planetary work, Stripped Down sheds mass for more jump range and keeps the Courier's pace.",
            "FrameShiftDrive": "The whole build — a 3A drive for maximum range; Increased Range + Mass Manager on a 35t hull is what turns a class-3 FSD into ~55 LY.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "3D is plenty without weapons; Engine Focused adds boost-capacitor headroom so the speedy hull can boost repeatedly between bodies.",
            "Radar": "Drop to D and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock 3C tank; small, so scoop often on long chains — fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size3": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size3": "The Guardian FSD Booster — a flat jump-range gain unlocked at a Guardian site, not bought; non-negotiable and not engineerable.",
            "Slot03_Size2": "A light SRV hangar for exobiology and surface sites; under-fills the slot and carries no blueprint.",
            "Slot04_Size2": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size2": "A fast-regenerating bi-weave for confident skimming and landings; Reinforced + Hi-Cap rebuild the strength the Courier is known for.",
            "Slot06_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot07_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 3,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 3,
              "grade": "G5",
              "blueprint": "Clean Drive Tuning",
              "experimental": "Stripped Down",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Power Plant",
              "size": 4,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Life Support",
              "size": 1,
              "grade": "G5",
              "blueprint": "Lightweight",
              "experimental": "—",
              "engineer": "Etienne Dorn"
            },
            {
              "module": "Sensors",
              "size": 2,
              "grade": "G5",
              "blueprint": "Lightweight",
              "experimental": "—",
              "engineer": "Bill Turner / Juri Ishmaak"
            },
            {
              "module": "Power Distributor",
              "size": 3,
              "grade": "G3",
              "blueprint": "Engine Focused",
              "experimental": "—",
              "engineer": "The Dweller"
            },
            {
              "module": "Shield Generator",
              "size": 2,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Booster",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Bulkheads",
              "blueprint": "Lightweight",
              "grade": "G5",
              "engineer": "Selene Jean"
            }
          ]
        }
      }
