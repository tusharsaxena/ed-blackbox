  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A turret-saturation AX fortress: turreted Enhanced AX multi-cannons for no-aim swarm coverage, Guardian Shard and Gauss cannons for interceptor hearts, Guardian module and hull reinforcement in the military slots and optionals, and a deep caustic and heat utility suite. Initial is buy-only (AX and Guardian weapons are unlocks, so they appear at the A-rated state); A-rated is the combat-ready baseline; Engineered hardens the cores, mobility, heat and shield buffer — AX and Guardian weapons take no engineering.",
          "callout": {
            "label": "Turrets for the swarm, Guardian guns for the hearts",
            "text": "The Type-10 can't aim fixed guns at agile targets, so the bulk of its mounts go to turreted AX multi-cannons that saturate a whole scout swarm while you manage position. Reserve the two large fixed Shard Cannons and the small Gauss for interceptor hearts. Tank on armour and Guardian reinforcement — the feeble bi-weave is a buffer, not the tank — and feed the eight utilities a constant caustic-sink and heat-sink supply."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon turret — turreted so the sluggish hull saturates the scout swarm without aiming; AX weapons take no engineering.",
            "LargeHardpoint2": "Second large AX turret doubles the no-aim swarm fire that defines the build.",
            "LargeHardpoint3": "Guardian Shard Cannon (fixed) on a big mount for interceptor-heart damage; Guardian weapons can't be engineered.",
            "LargeHardpoint4": "Second large fixed Shard Cannon for the hearts when you can line them up.",
            "MediumHardpoint1": "Enhanced AX MC turret — more no-aim swarm coverage across the mid mounts.",
            "MediumHardpoint2": "Second medium AX turret keeps scout pressure constant.",
            "MediumHardpoint3": "Guardian Shard Cannon adds Guardian anti-heart punch from a medium mount.",
            "SmallHardpoint1": "Guardian Gauss Cannon — the hardest-hitting anti-heart gun that fits a small mount.",
            "SmallHardpoint2": "Second small Gauss completes the Guardian heart battery.",
            "TinyHardpoint1": "Xeno Scanner IDs the Thargoid and exposes heart timing; scanners aren't engineerable.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Shield Booster — Thermal Resistant hardens the bi-weave against Thargoid thermal damage.",
            "TinyHardpoint6": "Second Thermal-Resistant booster; Thermo Block stacks more thermal resist on the buffer.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "A-rate to feed nine weapons, the SLF and the utilities; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives claw back the little mobility a 1,200t hull allows.",
            "FrameShiftDrive": "A-rated + Increased Range so the heavy hull can still relocate between systems.",
            "LifeSupport": "A-rated for the longest canopy-breach oxygen timer; Lightweight trims mass and has no experimental.",
            "PowerDistributor": "A-rate this early — sustained fire and boost drain the class-7 distributor; Charge Enhanced + Super Conduits keep the guns up.",
            "Radar": "Drop to D and go Lightweight — combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement spreads penetrating-hit damage across internals and resists Thargoid lightning; Guardian modules aren't engineerable.",
            "Military02": "Guardian Hull Reinforcement adds armour plus caustic/thermal resist — the core of the AX tank.",
            "Slot01_Size8": "Bi-Weave 8 regenerates fast under fire; Thermal Resistant + Fast Charge suit Thargoid thermal — it is a buffer, not the tank.",
            "Slot02_Size7": "Fighter Hangar launches an SLF decoy to split Thargoid fire; hangars aren't engineerable.",
            "Slot03_Size6": "Guardian HRP caps at size 5, so a 5D under-fills this size-6 slot — still the biggest armour multiplier available.",
            "Slot04_Size5": "Second size-5 Guardian HRP; Guardian armour stacks linearly with caustic and thermal resist.",
            "Slot05_Size4": "Decontamination Limpet Controller strips caustic off the hull between passes; limpet controllers carry no blueprint.",
            "Slot06_Size4": "Guardian Module Reinforcement protects the cores against lightning; not engineerable.",
            "Slot07_Size3": "More Guardian hull where the slot allows.",
            "Slot08_Size3": "Standard Module Reinforcement fills the last internal-protection slot; regular MRP isn't engineerable.",
            "Slot09_Size2": "Small Guardian HRP squeezes a little more armour and resist from a size-2 slot.",
            "Slot10_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
          },
          "engineeringPlan": [
