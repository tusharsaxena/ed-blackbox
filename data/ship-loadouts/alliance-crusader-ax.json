  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A hardened AX gunboat: an Enhanced AX multi-cannon on the large mount, Guardian Gauss on the mediums for heart damage, Guardian shards on all three smalls, every military slot filled with Guardian Module Reinforcement, and a fighter-bay decoy. Initial is buy-only cores; A-Rated adds the unlocked AX kit; Engineered hardens the shield, hull, heat and mobility. The four utilities are the tight spot — Xeno scanner, caustic sink and heat sink leave one slot for a shield booster.",
          "callout": {
            "label": "Harden, then decoy",
            "text": "The Crusader's whole AX case is its three military slots — fill all three with Guardian Module Reinforcement so the lightning can't disable you. Put Gauss on the mediums for heart damage, an Enhanced AX multi-cannon on the large mount, and Guardian Hull Reinforcement across the optionals. The four utilities are tight: scanner, caustic and heat kit come first, then one shield booster. Run the SLF as a decoy when a swarm converges."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX multi-cannon, gimballed to track scouts and interceptors; AX/Guardian weapons take no engineering blueprint.",
            "MediumHardpoint1": "Guardian Gauss for raw heart damage — fixed-mount, the Crusader's main interceptor-killer; not engineerable.",
            "MediumHardpoint2": "Second Gauss doubles heart DPS; pace your fire, Gauss is heavy on heat and the capacitor.",
            "SmallHardpoint1": "Guardian Shard Cannon — a hitscan shotgun for scouts and topping hearts; the smalls are too small for any AX multi-cannon.",
            "SmallHardpoint2": "Second shard cannon for swarm and scout clearance; cheap on the distributor next to the Gauss.",
            "SmallHardpoint3": "Third shard cannon — there is no small AX multi-cannon in game (the smallest AX MC is medium), so the smalls run Guardian weapons.",
            "TinyHardpoint1": "Enhanced Xeno Scanner reveals interceptor hearts and subsystems; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "The one utility left after the AX kit — a shield booster, Thermal Resistant against Thargoid thermal fire.",
            "PowerPlant": "A-rate first — Gauss, a shield and the cells are power-hungry; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives recover what agility the heavy hull allows — the Crusader needs every bit to dodge lightning.",
            "FrameShiftDrive": "A-rated to move a 500t hull to the fight; Increased Range with Mass Manager keeps jump range usable.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more, and life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — fixed Gauss empties the WEP capacitor fast; Charge Enhanced + Super Conduits keep it firing.",
            "Radar": "Drop to D and go Lightweight; AX needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement — the Crusader's whole case; soaks the lightning that disables modules. Not engineerable.",
            "Military02": "Second Guardian MRP; three is the most of any medium hull.",
            "Military03": "Third Guardian MRP fills the last military slot — maximum module hardening.",
            "Slot01_Size6": "Bi-Weave regenerates fast under fire; Thermal Resistant + Hi-Cap counter Thargoid thermal damage.",
            "Slot02_Size5": "Fighter Hangar — deploy an SLF to split a swarm; hangars are not engineerable.",
            "Slot03_Size3": "Guardian Hull Reinforcement adds armour and caustic resistance; Guardian reinforcement takes no blueprint.",
            "Slot04_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size2": "More Guardian HRP — armour and caustic resist stack linearly.",
            "Slot06_Size2": "Second size-2 Guardian HRP for more effective armour.",
            "Slot07_Size1": "Last optional — a size-1 Guardian HRP tops off the caustic-resistant armour."
          },
          "engineeringPlan": [
            {
