  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A long-range passenger fit — a deep cabin suite, a protective shield and a high-range FSD, with hardpoints left clean. Initial is buy-only; A-rated is the passenger baseline; Engineered maximises range and keeps the cabins safe. The size-7 optional holds the shield (passenger cabins cap at size 6), freeing every size-6 slot for fares.",
          "callout": {
            "label": "Cabins for the board, range for the run",
            "text": "Fit the cabin mix the board demands — economy for bulk sightseeing, first & luxury for VIP fares — and lean on the Anaconda's reach to take boards that target distant beacons. Keep a real shield and point defence for threatened routes. With no liner bonus to lean on, range and capacity are what set the Anaconda apart; swap cabins for cargo racks when the week turns to hauling."
          },
          "notes": {
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ to keep VIPs safe.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns begin but it still pays on a fare run.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Fourth Heavy-Duty booster once credits allow.",
            "TinyHardpoint7": "Fifth booster continues to firm up the shield for safer passenger routes.",
            "TinyHardpoint8": "Sixth booster in the last utility; drop a couple if you want the lightest possible hull for range.",
            "PowerPlant": "An unarmed hull needs little power, so Low Emissions trims heat and mass; Thermal Spread bleeds the rest for cool, long cruises.",
            "MainEngines": "A-rated + Dirty Drives keep the heavy loaded hull manoeuvrable in and out of stations.",
            "FrameShiftDrive": "A-rate FIRST — G5 Increased Range plus Mass Manager is the build's identity, reaching boards no liner can.",
            "LifeSupport": "A-rate for emergency-oxygen duration with passengers aboard; Lightweight trims mass and has no experimental effect.",
            "PowerDistributor": "Engine Focused shifts capacity to ENG so the heavy hull can keep boosting; Super Conduits speeds the recharge.",
            "Radar": "Drop to D and go Lightweight; passenger runs need no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered. Pair with a fuel scoop for long sightseeing legs.",
            "Military01": "Lightweight hull reinforcement adds a little armour and resistance without the mass penalty of Heavy Duty — range stays intact.",
            "Slot01_Size7": "Bi-weave shield in the size-7 slot (no cabin fits here); Reinforced maximises MJ and Fast Charge restores the bi-weave's quick recovery.",
            "Slot02_Size6": "Economy cabin for bulk sightseeing fares; swap class to suit the board.",
            "Slot03_Size6": "First-class cabin for higher-paying fares; cabins are never engineered.",
            "Slot04_Size6": "Luxury cabin for VIP boards — the freed size-6 slot that the relocated shield opened up.",
            "Slot05_Size5": "Economy cabin — bulk capacity.",
            "Slot06_Size5": "First-class cabin for the mid-tier fares.",
            "Slot07_Size5": "Economy cabin; swap to business or cargo when the week turns to hauling.",
            "Slot08_Size4": "Economy cabin filling a smaller slot.",
            "Slot09_Size4": "Economy cabin; pull for a fuel scoop or repair limpet on remote tours.",
            "Slot10_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot11_Size2": "Size-2 slot takes only an economy cabin (business/first/luxury start at size 3+); a couple of extra seats.",
            "Slot12_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
