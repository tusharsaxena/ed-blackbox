  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A budget anti-Xeno skirmisher built on the Vulture's elite agility. The two large hardpoints carry the AX battery — an Enhanced AX Multi-Cannon for sustained fire and a large Guardian Shard Cannon for burst — but the hull has NO medium or small mounts, so it cannot fit a single Guardian Gauss Cannon, the role's heart-killer. Initial is the buy-only bare hull; A-Rated bolts on the Thargoid kit and Guardian reinforcement; Engineered hardens mobility, shields and survival — the AX and Guardian weapons themselves carry no engineering.",
          "callout": {
            "label": "Dodge and manage power — it can't out-tank or out-Gauss anything",
            "text": "The Vulture survives AX by out-flying the lightning, not soaking it. Dodge the Interceptor's attacks, clear caustic with the sink launcher and a heat-sink overheat, repair stripped modules with the AFMU, and watch the class-4 plant — two large AX guns plus the shield leave almost no power margin. With no Gauss mount and only two guns, heart damage is slow; this is a scout-clearing and light-Interceptor hull, not a Titan boat.",
            "tone": "warn"
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon (gimballed) — the large mounts are the only hardpoints the Vulture has, so both AX weapons ride here; gimbals make sustained anti-Thargoid DPS easy to land. No weapon engineering exists.",
            "LargeHardpoint2": "Guardian Shard Cannon (large, fixed) — thermal burst against exposed hearts and scouts; the Vulture's agility makes the fixed mount workable. No blueprint available. Gauss will not fit — the hull has no medium/small mount.",
            "TinyHardpoint1": "Xeno Scanner reads Thargoid type and exposed hearts; utility scanner, not engineerable.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage without needing a cargo-fed decontamination limpet.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and burns off caustic in a pinch.",
            "TinyHardpoint4": "Shield Booster — Thermal Resistant against Thargoid thermal fire, Super Capacitors adds raw MJ back; only one utility is left after scanner and the two sinks.",
            "PowerPlant": "The Vulture's chronic bottleneck — Overcharge it FIRST; two large AX guns plus the shield leave almost no margin. Thermal Spread bleeds the heat AX weapons and the Shard generate.",
            "MainEngines": "A-rated + Dirty Drive Tuning gives the agility that dodges Interceptor lightning — the single most important AX upgrade on this hull.",
            "FrameShiftDrive": "A-rated with Increased Range + Mass Manager to reach Thargoid airspace; pin Farseer's blueprint for remote application.",
            "LifeSupport": "A-rated for the longest oxygen duration when a Thargoid strips the canopy; Lightweight trims the mass. No experimental effect.",
            "PowerDistributor": "A-rate and Charge-Enhance it — the Shard Cannon and AX Multi-Cannon drain the WEP capacitor fast; Super Conduits stretches each charge.",
            "Radar": "Drop to D and go Lightweight; AX fights are close-range, so save the mass and power.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Hull Reinforcement in the class-5 military slot — a large caustic-resistant armour block, the single biggest survival gain the Vulture can make. Guardian tech is not engineerable.",
            "Slot01_Size5": "Bi-Weave Shield (5C fast variant) regenerates quickly under fire; Thermal Resistant + Fast Charge against thermal Thargoid attacks.",
            "Slot02_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules stripped by Thargoid lightning between passes.",
            "Slot03_Size2": "Guardian Hull Reinforcement 2 — caustic-resistant armour; Guardian modules cannot be engineered.",
            "Slot04_Size1": "Guardian Module Reinforcement spreads Thargoid module-stripping damage and adds caustic resistance; not engineerable.",
            "Slot05_Size1": "Guardian Hull Reinforcement 1 — small caustic-resistant armour block; armour stacks linearly so even a size-1 helps.",
            "Slot06_Size1": "Module Reinforcement Package protects the internals from penetrating hits; not engineerable.",
            "Slot07_Size1": "Hull Reinforcement Package, Heavy Duty + Deep Plating for the cheapest effective-armour multiplier."
          },
          "engineeringPlan": [
