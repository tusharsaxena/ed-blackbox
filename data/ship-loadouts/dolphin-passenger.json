    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A cheap dedicated-liner fit mixing economy seating with a premium first-class cabin, plus a bi-weave shield and a strong FSD. Initial is buy-only; A-rated is the liner baseline; Engineered maximises range and exploits the Dolphin's exceptional cool-running thermals.",
          "callout": {
            "label": "Small but comfortable",
            "text": "The Dolphin fits a modest cabin mix — a couple of economy cabins plus a premium first-class cabin for high-paying VIP fares — with a shield for safety. Its cool-running plant suits relaxed travel, and the liner comfort bonus means even its few seats earn well. Luxury cabins need a size-5 slot, so adding one means giving up the economy-5 cabin."
          },
          "notes": {
            "TinyHardpoint1": "A-rated shield booster; Heavy Duty multiplies the small bi-weave's raw MJ for cheap passenger safety.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Low Emissions deepens the Dolphin's class-leading cool running; Thermal Spread bleeds the last of the heat — a near-invisible signature.",
            "MainEngines": "A-rated thrusters with Dirty Drives for the speed to shake an interdiction; Drag Drives sharpens boost.",
            "FrameShiftDrive": "A-rated and Increased Range at G5 with Mass Manager — the whole point of a comfortable-range liner; reaches scenic destinations.",
            "LifeSupport": "A-rated for endurance; Lightweight trims mass to stretch jump range. Life support has no experimental effect.",
            "PowerDistributor": "Engine Focused biases the small class-3 distributor toward boosting away from danger; Cluster Capacitors deepens the reservoir.",
            "Radar": "Drop to D and go Lightweight — a liner needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock class-C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Economy Cabin 5 (16 seats) carries the volume; swap to First/Luxury here for an all-premium VIP run at the cost of headcount.",
            "Slot02_Size4": "Economy Cabin 4 (8 seats) — bulk economy capacity for group transport fares.",
            "Slot03_Size4": "First-Class Cabin 4 (3 seats) is the premium VIP cabin; first-class is the largest cabin grade this 140t hull's size-4 slots accept.",
            "Slot04_Size3": "Bi-weave shield regenerates fast under fire for passenger safety; Reinforced maximises MJ and Fast Charge speeds the recharge.",
            "Slot05_Size2": "Economy Cabin 2 (2 seats) tops up headcount in the smallest cabin slot.",
            "Slot06_Size2": "Second Economy Cabin 2 (2 seats); size-2 slots only accept economy cabins, so no luxury fits here.",
            "Slot07_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot09_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
          },
