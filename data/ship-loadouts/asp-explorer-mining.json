  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete mining fit for laser and core work that keeps a gun and a light shield for self-defence. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on range, mobility and what shield the hull will carry — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "Tools fit; ore room is tight",
            "text": "The Asp mounts a complete suite — lasers and a seismic launcher for both styles, a Pulse Wave Analyser to find rocks, a refinery and a small collector swarm, plus a gun and a light bi-weave to discourage casual pirates. The squeeze is the hold: with shield and suite fitted you're left around 72t of ore. Drop the shield for more racks only if you're confident the ring is quiet."
          },
          "notes": {
            "MediumHardpoint1": "The larger of two mining lasers; a fixed medium laser does the bulk of the surface-deposit cutting, and mining lasers carry no weapon blueprint.",
            "MediumHardpoint2": "Core mining's crack tool — lob a seismic charge into a fissure to split the rock; the medium fixed warhead is the largest the Asp mounts and mining tools aren't engineerable.",
            "SmallHardpoint1": "Abrasion Blaster shears surface deposits off a cracked core for the limpets to scoop; no blueprint applies to mining tools.",
            "SmallHardpoint2": "Sub-surface Displacement Missile reaches the deep deposits the blaster can't; mining missiles carry no blueprint.",
            "SmallHardpoint3": "A second, smaller mining laser doubles laser-mining throughput on a prospected rock; not engineerable.",
            "SmallHardpoint4": "Lone gimballed multi-cannon for pirate deterrence; Overcharged plus Corrosive Shell make the single gun bite hard enough to see off a chancer.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks and core fissures; held at class 3 to spare the power budget, and scanners carry no blueprint.",
            "TinyHardpoint2": "One Heavy-Duty booster roughly doubles the light bi-weave's raw MJ — the cheapest survivability gain on the hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate it to run lasers, the seismic launcher and the limpet swarm together; Low Emissions plus Thermal Spread hold heat down through long sessions.",
            "MainEngines": "A-rated thrusters with Dirty Drive Tuning plus Drag Drives so the hull can boost clear of an interdiction it can't out-fight.",
            "FrameShiftDrive": "An A-rated SCO drive — Increased Range plus Mass Manager stretch every jump so the Asp reaches distant rings other miners have to slog out to.",
            "LifeSupport": "D-rated and Lightweight — life support is mass to shed on a miner, and it has no experimental effect.",
            "PowerDistributor": "A-rate the class-4 distributor or lasers and limpets brown out together; Engine Focused at G3 feeds the boost you escape pirates with.",
            "Radar": "Dropped to D and Lightweight — a miner needs no sensor range, so save the mass; sensors have no experimental effect.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size5": "A size-5 bi-weave is the most shield the Asp will carry; Reinforced plus Fast Charge maximise MJ while keeping the quick recharge — enough to survive a clumsy rock, not a serious pirate.",
            "Slot03_Size3": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot04_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot07_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot08_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
