  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A hard-hitting, capacious multirole fit. Initial is a cheap buy-only build; A-rated is the multirole baseline; Engineered sharpens firepower and survivability while keeping a big hold and a usable jump range.",
          "callout": {
            "label": "Six guns and a big hold",
            "text": "The Corsair's six hardpoints make a brutal combat fit, and its hold out-carries the Python — so the same hull fights hard and trades or mines big. Re-tune at a station: drop the racks for a mining suite to mine, or stack cargo to haul. Its weak range keeps exploration off the table; leave that to other ships."
          },
          "notes": {
            "LargeHardpoint1": "Primary large multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "LargeHardpoint3": "Buy a cheap large pulse, swap to a Thermal-Vent beam once A-rated to strip shields heat-free.",
            "MediumHardpoint1": "Efficient pulse adds sustained energy DPS; Thermal Vent keeps it running cold.",
            "MediumHardpoint2": "Second Efficient pulse; paired Thermal-Vent lasers hold heat down across long fights.",
            "MediumHardpoint3": "Fill-in medium multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "TinyHardpoint1": "First Heavy-Duty shield booster multiplies the bi-weave's raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers six guns, a bi-weave and modules; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated 7A thrusters plus Dirty Drives give the Corsair its modern pace; Drag Drives lift boost speed.",
            "FrameShiftDrive": "Increased Range at G5 lifts a weak-jumping hull to a usable trade range; Mass Manager squeezes out more.",
            "LifeSupport": "A-rated for longer canopy-breach oxygen; Lightweight trims mass and life support has no experimental effect.",
            "PowerDistributor": "A-rate this with the plant — six guns plus boost drain the distributor; Charge Enhanced + Super Conduits keep WEP and ENG up.",
            "Radar": "Drop to D and go Lightweight; a multirole needs no sensor range, so save the mass.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot03_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot07_Size4": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Slot08_Size3": "Second Heavy-Duty HRP; armour stacks linearly across reinforcements.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
