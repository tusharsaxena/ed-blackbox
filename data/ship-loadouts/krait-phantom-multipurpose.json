  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A range-leaning multirole fit — great jump range, two guns for defence, cargo and a strong shield, ready to re-tune. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it a superb explorer and capable all-rounder.",
          "callout": {
            "label": "Range first, re-tune the rest",
            "text": "This balanced fit keeps a great jump range and self-defence; the Phantom's strength is swapping at a station — add a fuel scoop, Guardian booster, SRV and AFMU to explore deep; fill with cargo to trade; add a mining suite to mine. Keep role module sets in storage."
          },
          "notes": {
            "LargeHardpoint1": "Primary large gun; Overcharged multi-cannon with one Corrosive Shell to strip armour resistance for the battery.",
            "LargeHardpoint2": "Large beam for shield-stripping; Thermal Vent keeps it heat-free under sustained fire.",
            "MediumHardpoint1": "Gimballed pulse fills the medium mount; Efficient + Thermal Vent runs cool for self-defence.",
            "MediumHardpoint2": "Second gimballed pulse; same Efficient + Thermal Vent tune for low-heat firepower.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for survivability across all roles.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "PowerPlant": "A-rated, then Low Emissions for cool deep-space running; Thermal Spread bleeds heat further.",
            "MainEngines": "A-rated + Dirty Drives for the pace that lets the Phantom outrun trouble it can't out-gun.",
            "FrameShiftDrive": "A-rate FIRST — range is the Phantom's signature; Increased Range + Mass Manager push it to ~75 LY.",
            "LifeSupport": "A-rated for endurance on long expeditions; Lightweight trims mass; no experimental effect.",
            "PowerDistributor": "A-rated, Engine Focused for boost/escape capacity; Super Conduits speeds the recharge.",
            "Radar": "Drop to D and go Lightweight — a multirole needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more — survivability for every role.",
            "Slot02_Size5": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot03_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot06_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size3": "Hull reinforcement for survivability; Heavy Duty + Deep Plating is the cheapest large armour multiplier.",
            "Slot08_Size2": "Second Heavy-Duty HRP fills the size-2 slot with cheap effective armour.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
