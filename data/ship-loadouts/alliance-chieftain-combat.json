  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A hull-tank combat fit that leans on the three military slots. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern with heavy reinforcement. An AX variant swaps the weapons for Guardian/AX hardpoints.",
          "callout": {
            "label": "The military slots are the point",
            "text": "Three class-4 military slots filled with Heavy-Duty hull and module reinforcement are what make the Chieftain so durable. They don't compete with your shield or cargo, so the tank is almost free — use them."
          },
          "notes": {
            "LargeHardpoint1": "Primary large mount; one Overcharged multi-cannon carries Corrosive Shell to strip armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so the main battery never stops firing.",
            "MediumHardpoint1": "Gimballed beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "SmallHardpoint1": "Small multi-cannon adds kinetic chip damage; Auto Loader keeps it topped up.",
            "SmallHardpoint2": "Efficient pulse fills a small mount cheaply; Phasing Sequence leaks damage through shields.",
            "SmallHardpoint3": "Second Efficient pulse — low draw and low heat, holding fire while the mains carry the kill.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for the cheapest large gain.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Second Heavy-Duty shield booster fills the last utility — stacking is the cheapest shield strength on the hull.",
            "PowerPlant": "Overcharged adds the headroom for guns, shield and cells; Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the agility that defines the Chieftain — its whole edge.",
            "FrameShiftDrive": "A-rated to reach fights and turn-ins; only G3 range, since combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate to sustain two large guns plus boost; Charge Enhanced + Super Conduits keep WEP topped.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "First military slot — Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Military02": "Second Heavy-Duty HRP; the dedicated military bays don't cost you an optional slot, so armour stacks almost free.",
            "Military03": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire (max grade C at this size); Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size4": "More Heavy-Duty hull reinforcement in the optionals — armour stacks linearly.",
            "Slot04_Size2": "Module Reinforcement protects the cores in the smaller optional; not engineerable.",
            "Slot05_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
