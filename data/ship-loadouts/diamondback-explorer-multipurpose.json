  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multirole fit — light guns, a fast-recharge bi-weave, some cargo and a fuel scoop, with the FSD kept strong so it still roams. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it capable across the board for the size. The DBE's real strength is swapping its few optionals at a station, so engineer each module once and reuse it across role swaps.",
          "callout": {
            "label": "Built to re-tune",
            "text": "This is one balanced configuration; the DBE's strength as a generalist is swapping its few optionals — strip the guns and HRP for a bigger scoop, SRV and scanner to explore; fill with cargo racks for a courier loop; keep the shield and weapons for a light bounty session. Keep role-specific modules in storage and switch as the week demands."
          },
          "notes": {
            "LargeHardpoint1": "The only large mount; an Overcharged multi-cannon with the single Corrosive Shell strips resistance for the whole battery.",
            "MediumHardpoint1": "Gimballed pulse for hitscan shield work; Efficient + Thermal Vent keeps a small hull running cold.",
            "MediumHardpoint2": "Second multi-cannon; Auto Loader removes reloads so the kinetic pair never stops firing.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for the cheapest defensive gain.",
            "TinyHardpoint2": "Second Heavy-Duty booster rounds out a light but real shield for self-defence.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Class-4 plant runs guns, shield and scoop; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives keep the agility that makes the DBE a quick station turner.",
            "FrameShiftDrive": "A-rate first — range is this hull's signature; Increased Range + Mass Manager preserve the reach across every role.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rated + Charge Enhanced keeps weapons and boost fed; Super Conduits stretches the WEP reservoir.",
            "Radar": "Drop to D and go Lightweight; a generalist needs no sensor range, so save the mass for jump.",
            "FuelTank": "Stock class-C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size4": "Bi-weave regenerates fast under fire — ideal for a light hull; Reinforced maximises MJ and Hi-Cap adds more.",
            "Slot02_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot03_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size3": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot05_Size2": "Hull reinforcement for light combat survivability; Heavy Duty + Deep Plating is the cheapest armour multiplier.",
            "Slot06_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
