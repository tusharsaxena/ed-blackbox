  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A cheap economy-cabin fit that keeps a defensive shield. Initial is buy-only; A-Rated is the passenger baseline; Engineered maximises range and keeps the cabins safe. Hardpoints run clean — the four small mounts stay empty.",
          "callout": {
            "label": "Cabins for volume, one slot for a shield",
            "text": "Fill the optionals with economy cabins — that's the Type-7's whole point — but keep one class-6 slot for a bi-weave shield. The hull is lightly built, so a shield, boosters and point defence meaningfully improve a board's odds against interdiction. Swap a class-5 berth to first/luxury only when the board pays a VIP fare."
          },
          "notes": {
            "TinyHardpoint1": "First Heavy-Duty shield booster; the cheapest multiplier on a thin hull's small shield, Super Capacitors adds raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster once A-rated — stacks the bi-weave's strength so an interdictor can't drop you fast.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate for cabins, shield and modules; Low Emissions keeps the heat signature down so you draw fewer interdictions, Thermal Spread cools it further.",
            "MainEngines": "A-rated + Dirty Drives move the laden hull and shake interdictions; Drag Drives adds the top-end speed to outrun a pirate.",
            "FrameShiftDrive": "The payload mover — A-rated and Increased Range keep tourist loops efficient; Mass Manager offsets the cabin tonnage.",
            "LifeSupport": "A-rated for the longest emergency O2 (passengers aboard); Lightweight trims its mass with no experimental effect.",
            "PowerDistributor": "Engine Focused feeds the boost you need to escape; Cluster Capacitors banks extra boosts for the run to safety.",
            "Radar": "D-rate and go Lightweight — passenger loops need no sensor range, so save the mass; no experimental effect.",
            "FuelTank": "Stock class-5 tank for comfortable jump range between stops; fuel capacity cannot be engineered.",
            "Slot01_Size6": "Class-6 economy cabin — the bulk of the payload; passenger cabins are not engineerable.",
            "Slot02_Size6": "Second class-6 economy cabin for volume; swap to business/first only when a VIP board pays for it.",
            "Slot03_Size6": "Bi-weave shield in one class-6 slot — fast regen keeps a thin hull alive; Reinforced maxes its MJ, Fast Charge speeds the recovery.",
            "Slot04_Size5": "Class-5 economy cabin; more cheap berths.",
            "Slot05_Size5": "Second class-5 economy cabin once A-rated.",
            "Slot06_Size5": "First-class cabin in one class-5 slot to take the higher-paying VIP fares when they appear.",
            "Slot07_Size3": "Class-3 economy cabin tops up the seat count.",
            "Slot08_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot09_Size2": "Class-2 economy cabin fills the last small slot with seats.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Power Plant",
              "size": 5,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 6,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Power Distributor",
              "size": 4,
              "grade": "G5",
              "blueprint": "Engine Focused",
              "experimental": "Cluster Capacitors",
              "engineer": "The Dweller"
            },
            {
              "module": "Life Support / Sensors",
              "grade": "G5",
