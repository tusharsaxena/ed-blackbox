  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "ax",
          "intro": "A firepower-led AX medium working within the hard six-optional / zero-military constraint. Gauss on the two mediums for heart damage; four large mounts carry Guardian/AX guns; the six optionals split between a bi-weave shield and the Guardian reinforcement that has nowhere else to go. Initial is buy-only; A-Rated adds the unlocked AX kit; Engineered hardens the shield, cores and mobility — AX/Guardian weapons and Guardian reinforcement take no blueprints, so the gains come from the ship systems.",
          "callout": {
            "label": "Six bays, no military — harden where you can",
            "text": "With no military slots, Guardian Module Reinforcement has to live in the civilian optionals alongside the shield and hull kit. Put two Gauss on the mediums for heart damage, four large Guardian/AX guns on the big mounts (no huge AX gun exists), and run caustic and heat kit hard. Fly it to dodge — you cannot stack the module-tank a Corvette or Challenger can."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon (gimballed) — one of four large AX mounts; gimbals trade a little damage for tracking on a moving heart. AX/Guardian weapons carry no engineering.",
            "LargeHardpoint2": "Second gimballed Enhanced AX Multi-Cannon — sustained anti-Thargoid fire from the big mounts; not engineerable.",
            "LargeHardpoint3": "Guardian Plasma Charger (fixed large) — charged plasma bursts deal heavy heart and exotic damage; not engineerable.",
            "LargeHardpoint4": "Guardian Shard Cannon (fixed large) — close-range shard burst shreds hull and hearts; not engineerable.",
            "MediumHardpoint1": "Guardian Gauss Cannon (fixed medium) — the heart-killer; medium is its largest class, so the mediums carry the pair. Runs hot; not engineerable.",
            "MediumHardpoint2": "Second fixed Gauss — two on the mediums supply the heart damage that ends Interceptors; manage heat between charges.",
            "TinyHardpoint1": "Xeno Scanner exposes Thargoid hearts and subsystems; mandatory for Interceptor fights. No blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint5": "Thermal-Resistant shield booster stacks resistance against Thargoid thermal/caustic damage; Thermo Block adds more.",
            "TinyHardpoint6": "Heavy-Duty shield booster adds raw shield MJ; Super Capacitors squeezes out more.",
            "PowerPlant": "A-rate the class-6 plant to power six AX guns and a charged distributor; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives keep the 256/345 speed that lets it dodge lightning rather than soak it.",
            "FrameShiftDrive": "A-rated; Increased Range + Mass Manager give enough jump to reach the fight without bloating mass.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — six AX guns brown out anything less; Charge Enhanced + Super Conduits feed the capacitor.",
            "Radar": "Drop to D and go Lightweight; AX needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave shield regenerates fast under fire; Thermal Resistant + Hi-Cap harden it against caustic and thermal damage.",
            "Slot02_Size4": "Guardian Hull Reinforcement adds armour with built-in caustic resistance; Guardian kit carries no blueprint.",
            "Slot03_Size3": "Guardian Module Reinforcement protects internals from Thargoid lightning — the hardening that, with no military slots, has nowhere else to go; not engineerable.",
            "Slot04_Size2": "Second Guardian HRP fits more caustic-resistant armour into a small bay; not engineerable.",
            "Slot05_Size1": "Second Guardian MRP spreads more lightning protection across the cores; not engineerable.",
            "Slot06_Size1": "Decontamination Limpet Controller clears caustic corrosion mid-fight; limpet controllers carry no blueprint."
          },
          "engineeringPlan": [
            {
