  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete mining fit for laser and core work that keeps a gun, a strong shield and the option of a fighter for self-defence. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on defence, mobility and heat — the mining tools themselves are not meaningfully engineered.",
          "callout": {
            "label": "Tools, limpets, teeth",
            "text": "A complete miner: lasers and a seismic launcher for both mining styles, a Pulse Wave Analyser to find rocks, a refinery, prospector and several collector controllers to work fast, and — the Krait's signature — a gun, a strong bi-weave and an optional SLF so the pirate who interdicts you regrets it. The size-5 slot swaps an ore rack for a Fighter Hangar when you want the wingman."
          },
          "notes": {
            "LargeHardpoint1": "Medium mining laser on a large mount — the highest-yield laser the hull can carry; mining lasers take no engineering.",
            "LargeHardpoint2": "Seismic charge launcher cracks high-value cores; a core-mining staple with no useful blueprint.",
            "LargeHardpoint3": "The one real gun — Overcharged with Corrosive Shell strips pirate armour so a lone barrel still bites.",
            "MediumHardpoint1": "Sub-surface displacement missile pops the deep deposits inside a cracked core; left stock.",
            "MediumHardpoint2": "Abrasion blaster (small — the only size it comes in) shaves surface deposits off the rock; no blueprint exists.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks across the ring; scanners aren't engineerable.",
            "TinyHardpoint2": "Heavy-Duty booster multiplies the bi-weave's raw MJ — the cheapest big jump in shield strength.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more shield for the exposed minutes of cracking a core.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rated to run lasers, limpets, shield and a gun at once; Low Emissions with Thermal Spread holds heat down through long sessions.",
            "MainEngines": "A-rated thrusters with Dirty Drives to reposition on the rock and outrun pirates once the hold is full.",
            "FrameShiftDrive": "A-rated FSD — Increased Range plus Mass Manager reaches distant hotspots and hauls ore home.",
            "LifeSupport": "D-rated to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate first — lasers and limpets are power-hungry; Engine Focused feeds the boost that escapes interdiction.",
            "Radar": "Dropped to D and Lightweight; a miner needs no sensor range, so save the mass.",
            "FuelTank": "Stock 32t tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Bi-weave regenerates fast under fire; Reinforced plus Fast Charge survives the exposed core-cracking minutes.",
            "Slot03_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size5": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot05_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot08_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot09_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets."
          },
          "engineeringPlan": [
            {
