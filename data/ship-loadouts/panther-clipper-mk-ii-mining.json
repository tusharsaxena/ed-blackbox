  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete mining fit for laser and core work that keeps guns and a strong shield for self-defence. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on mobility, defence and heat — the mining tools themselves are not meaningfully engineered. The vast remaining internals fill with ore racks.",
          "callout": {
            "label": "Tools, limpets, defence — then ore, ore, ore",
            "text": "A complete miner: lasers and a seismic launcher for both styles, a Pulse Wave Analyser to find rocks, a deep refinery, prospector and multiple multi-collector controllers to work fast, and guns plus a heavy shield so the pirate who interdicts you fails. Everything else — including both class-8 slots — is ore. You will run out of rocks long before you run out of hold."
          },
          "notes": {
            "LargeHardpoint1": "Primary mining laser for surface laser mining; mining tools are left stock — engineering them adds little.",
            "LargeHardpoint2": "Gimballed large multi-cannon for pirate defence; Overcharged + Corrosive Shell ends the occasional fight fast.",
            "MediumHardpoint1": "Seismic Charge Launcher cracks deep-core asteroids; left stock.",
            "MediumHardpoint2": "Sub-surface Displacement Missile digs out sub-surface deposits; left stock.",
            "MediumHardpoint3": "Abrasion Blaster knocks surface deposits off rocks; left stock.",
            "MediumHardpoint4": "Second multi-cannon for self-defence; Overcharged + Auto Loader keeps it firing.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks across the ring; scanners carry no blueprint.",
            "TinyHardpoint2": "Heavy-Duty shield booster — the cheapest large boost to the defensive bi-weave.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more raw shield MJ.",
            "TinyHardpoint4": "Third Heavy-Duty booster rounds out the shield against interdictors.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "8A plant runs lasers, refinery and shield; Low Emissions + Thermal Spread keep heat down over long sessions.",
            "MainEngines": "8A thrusters + Dirty Drives move the heavy hull between rings and out of interdictions.",
            "FrameShiftDrive": "7A drive; Increased Range + Mass Manager claw back jump range on the loaded hull.",
            "LifeSupport": "D-rate and Lightweight to save mass; life support has no experimental effect.",
            "PowerDistributor": "7A distributor; Engine Focused fattens the ENG pool to boost the heavy hull around the ring.",
            "Radar": "D-rate and Lightweight — mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock 7C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size7": "Bi-weave shield for self-defence; Reinforced + Fast Charge survives and recovers from interdictions (Resistance Augmented is a booster blueprint, not a generator one).",
            "Slot05_Size6": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot06_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size6": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot08_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot09_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot10_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot11_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot12_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets."
          },
          "engineeringPlan": [
