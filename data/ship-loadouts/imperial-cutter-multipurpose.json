  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced top-end multirole fit built around apex prismatic shields. Initial is buy-only; A-rated is the multirole baseline; Engineered makes it excellent at combat and trade alike, then re-tunes the optionals to the job in front of you.",
          "callout": {
            "label": "Apex shield, then re-tune",
            "text": "Built around a prismatic shield for unmatched survivability; the rest re-tunes — fill the optionals with cargo to haul a fortune, swap in HRPs and more guns to fight, or a mining suite to mine. Keep role module sets in storage. It is a poor explorer — leave deep range to other ships."
          },
          "notes": {
            "HugeHardpoint1": "The single huge mount carries the alpha; Overcharged + Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint1": "Gimballed beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "LargeHardpoint2": "Second large as a multi-cannon for hull damage; Overcharged + Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint1": "Gimballed pulse fills the four mediums cheaply; Efficient + Thermal Vent makes it near heat-free — swap for cargo-friendly empties when trading.",
            "MediumHardpoint2": "Second medium pulse; Efficient keeps total weapon draw low so the distributor sustains the huge gun.",
            "MediumHardpoint3": "Third medium pulse rounds out the laser convergence for shield work.",
            "MediumHardpoint4": "Fourth medium pulse; flexible — drop the mediums entirely on a pure-trade swap.",
            "TinyHardpoint1": "First of the booster stack; Heavy Duty multiplies the prismatic's raw MJ.",
            "TinyHardpoint2": "Stacked Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint4": "Fourth booster rounds out the shield stack before utilities turn to defence.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint8": "Fifth Heavy-Duty booster in the last utility for more shield headroom.",
            "PowerPlant": "Powers eight guns, a big prismatic and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the surprising agility of a capital hull.",
            "FrameShiftDrive": "A-rated with G5 Increased Range + Mass Manager to soften the Cutter's weak jump; engineer once, reuse across role swaps.",
            "LifeSupport": "Kept A-rated for reliability on a luxury hull; Lightweight trims mass with no experimental effect.",
            "PowerDistributor": "A-rate and Charge Enhanced to sustain the huge gun and shield cells; Super Conduits deepens the weapon capacitor.",
            "Radar": "Drop to D and go Lightweight; multirole needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Military02": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size8": "The prismatic shield is the Cutter's identity — fit it first; Reinforced maximises its MJ and Hi-Cap adds more (Resistance Augmented is a booster blueprint, not valid here).",
            "Slot02_Size8": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size5": "Heavy-Duty hull reinforcement; HRP caps at size 5 so it exactly fills this slot.",
            "Slot07_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Prismatic Shield",
              "size": 8,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Power Plant",
              "size": 8,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 8,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Multi-Cannons",
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Corrosive Shell (one) / Auto Loader (rest)",
              "engineer": "Tod McQuinn"
            },
            {
              "module": "Beam & Pulse Lasers",
              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Thermal Vent",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Frame Shift Drive",
              "size": 7,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Power Distributor",
              "size": 7,
