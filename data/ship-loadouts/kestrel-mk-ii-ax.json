  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A small-pad anti-Xeno fit built on the Kestrel's speed: three large Enhanced AX Multi-Cannons for sustained fire, a Guardian Gauss pair on the two small mounts for heart damage, and Guardian reinforcement crammed into one military slot and shallow optionals. Initial is the buy-only bare hull; A-Rated bolts on the Thargoid kit and Guardian reinforcement; Engineered hardens mobility, shields and survival. The AX/Guardian weapons themselves carry no engineering — the gains are in flying and the ship modules.",
          "callout": {
            "label": "Kite, place Gauss, harden what you can",
            "text": "The Kestrel survives AX by speed, not tank: dodge Interceptor lightning, line the two small Gauss on exposed hearts and let the three large AX guns hold sustained fire. Hardening is thin — one military slot plus a few Guardian blocks in the optionals — so manage heat hard on a light hull and disengage before the shallow armour matters.",
            "tone": "tip"
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon (gimballed) — the three large mounts are the Kestrel's AX main battery; gimbals make sustained anti-Thargoid DPS easy to land. No weapon engineering exists.",
            "LargeHardpoint2": "Second large Enhanced AX Multi-Cannon for sustained kinetic AX damage on hearts and exertions; not engineerable.",
            "LargeHardpoint3": "Third large Enhanced AX Multi-Cannon — a heavy sustained-fire array for a small hull, but they run hot together; not engineerable.",
            "SmallHardpoint1": "Guardian Gauss Cannon (small, fixed) — the heart-killer. Gauss caps at medium and the Kestrel's only spare mounts are small, so heart damage rides two small Gauss. No blueprint.",
            "SmallHardpoint2": "Second small Guardian Gauss Cannon completes the pair; fire in short bursts to manage heat and the WEP capacitor. Not engineerable.",
            "TinyHardpoint1": "Xeno Scanner reveals Interceptor type and exposed hearts — essential for target priority; utility scanner, not engineerable.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running on a hot-running small hull.",
            "TinyHardpoint4": "Shield Booster grows the bi-weave; Thermal Resistant tilts it toward Thargoid thermal damage.",
            "PowerPlant": "A-rate first — the class-5 plant feeds three large AX guns, two Gauss and the shield; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives is the Kestrel's whole AX case: out-run and out-turn Thargoid lightning on a light hull.",
            "FrameShiftDrive": "A-rated; Increased Range + Mass Manager reach Thargoid airspace and Maelstroms; only a size-4 drive, so range is modest.",
            "LifeSupport": "A-rated for a long oxygen timer after a canopy breach; Lightweight trims the size-1 module's mass; no experimental effect.",
            "PowerDistributor": "Charge Enhanced + Super Conduits feed the Gauss capacitor so the pair keeps firing; the class-5 distributor is the tightest system on the hull.",
            "Radar": "D-rated and Lightweight — AX fights are close-range, so save the mass for speed.",
            "FuelTank": "Stock size-4 tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement in the single military slot — spreads Thargoid module-stripping damage and adds caustic resistance; Guardian tech is not engineerable.",
            "Slot01_Size5": "Bi-Weave Shield regenerates fast under fire; Thermal Resistant + Fast Charge suit sustained Thargoid thermal damage. The largest optional caps the shield at size 5.",
            "Slot02_Size4": "Guardian Hull Reinforcement — caustic-resistant armour, the biggest single hardening block on a thin-armour hull; not engineerable.",
            "Slot03_Size3": "Decontamination Limpet Controller strips caustic off the hull mid-fight; limpet drones carry no engineering.",
            "Slot04_Size2": "More Guardian hull reinforcement; effective armour stacks linearly and this hull needs every point. Not engineerable.",
            "Slot05_Size2": "Guardian Module Reinforcement spreads penetrating-hit damage across the internals; caustic-resistant, no blueprint.",
            "Slot06_Size2": "Optional / low-priority — Shielded hardens the AFMU. Repairs stripped modules between fights.",
            "Slot07_Size1": "A small Guardian HRP tops up effective armour where the last optional allows; not engineerable."
          },
          "engineeringPlan": [
