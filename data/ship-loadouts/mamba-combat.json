  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A firing-pass alpha fit. Initial is buy-only; A-rated is the combat-ready baseline; Engineered leans into speed and fixed-weapon alpha. The pattern swaps the learner gimbals for fixed plasma, beams and rails and tightens convergence around the Mamba's straight-line speed.",
          "callout": {
            "label": "Build for the pass, not the circle",
            "text": "Fixed plasma and rail guns reward the Mamba's straight-line speed and tight convergence. Line the target up, alpha it on the pass, boost out, and come around — don't try to hold a turning fight the hull can't win."
          },
          "notes": {
            "HugeHardpoint1": "The signature huge mount; an Efficient plasma accelerator delivers the alpha that defines the firing pass while running cool enough to sustain.",
            "LargeHardpoint1": "Beam laser for shield-stripping; Thermal Vent keeps it cold so heat never forces you off the trigger.",
            "LargeHardpoint2": "Second beam doubles shield-strip throughput; Thermal Vent vents heat on every hit.",
            "SmallHardpoint1": "Fixed rail gun for ranged shield and module sniping; Long Range removes drop-off so the Mamba's speed sets the engagement range.",
            "SmallHardpoint2": "Paired rail gun stacks ranged burst; Feedback Cascade collapses enemy shield-cell heals.",
            "TinyHardpoint1": "First Heavy-Duty shield booster; raw MJ is the cheapest way to pad a hull that can't out-turn return fire.",
            "TinyHardpoint2": "Second Heavy-Duty booster; stacking multiplies the bi-weave's base strength.",
            "TinyHardpoint3": "Third Heavy-Duty booster rounds out the shield stack before utilities turn to countermeasures.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate for the headroom heavy fixed weapons, shields and boost demand; Overcharged adds output and Thermal Spread bleeds the extra heat.",
            "MainEngines": "Speed is the Mamba's primary weapon and defence — A-rate, then Dirty Drives + Drag Drives for maximum boost.",
            "FrameShiftDrive": "A-rate to soften a short jump range; only G3 Increased Range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more, and life support has no experimental effect.",
            "PowerDistributor": "A-rate to feed distributor-hungry rails and plasma; Charge Enhanced + Super Conduits sustain the weapon and boost draw.",
            "Radar": "Drop to D and go Lightweight — combat needs no sensor range, so bank the mass for speed.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Bi-weave regenerates fast under fire, padding the agility-light frame; Reinforced maximises MJ and Fast Charge speeds recovery.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size3": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour; Deep Plating adds more.",
            "Slot04_Size2": "Second Heavy-Duty HRP; armour stacks linearly so every plate counts.",
            "Slot05_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot06_Size1": "Class-1 Module Reinforcement protects the cores in the last slot; not engineerable."
          },
          "engineeringPlan": [
