  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A cool-running budget combat fit: a Large multi-cannon main gun, two support lasers, a full booster suite and a shield/cell/hull tank in the optionals. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies a heat-light combat pattern.",
          "callout": {
            "label": "Run cool, hit clean",
            "text": "The DBE's combat identity is heat. Pair a Large overcharged multi-cannon (one Corrosive) with thermal-vent beams and the ship stays cold enough to fire continuously and silent-run when pressed. Build the optionals as a layered shield-plus-hull tank to make up for the light base armour."
          },
          "notes": {
            "LargeHardpoint1": "Primary Large mount; an Overcharged multi-cannon with the single Corrosive Shell is the ship's real damage and strips armour resistance for the whole battery.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a Thermal-Vent beam once A-rated — it vents heat so the already-cool hull runs colder still.",
            "MediumHardpoint2": "Support multi-cannon; Overcharged with Auto Loader keeps its DPS uninterrupted.",
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large gain in shield strength on a light hull.",
            "TinyHardpoint2": "Second Heavy-Duty booster deepens the bi-weave before utilities turn to defence.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate for gun, shield and booster headroom; Overcharged adds power and Thermal Spread keeps the cool hull cool.",
            "MainEngines": "A-rated + Dirty Drives preserve the agility that holds the Large mount on target and dictates range.",
            "FrameShiftDrive": "A-rated to move between fights; only G3 range — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — the class-4 distributor feeds both weapon fire and boost on a power-tight hull.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size4": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more — the first tank layer on thin armour.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size3": "Heavy-Duty hull reinforcement is the cheapest large multiplier on the DBE's light effective armour.",
            "Slot04_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size2": "More Heavy-Duty hull where the slot allows; armour stacks linearly.",
            "Slot06_Size2": "Module Reinforcement spreads penetrating-hit damage across the cores; not engineerable.",
            "Slot07_Size1": "Last Heavy-Duty HRP tops off the armour layer in the smallest slot.",
            "Slot08_Size1": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 4,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 4,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin"
            },
            {
              "module": "Multi-Cannons",
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Corrosive Shell (Large) / Auto Loader (Medium)",
              "engineer": "Tod McQuinn"
            },
            {
              "module": "Beam Laser",
              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Thermal Vent",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Power Distributor",
              "size": 4,
              "grade": "G5",
              "blueprint": "Charge Enhanced",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Shield Generator",
              "size": 4,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Bulkheads",
              "blueprint": "Heavy Duty",
              "grade": "G5",
              "engineer": "Selene Jean",
              "experimental": "Deep Plating"
            },
            {
