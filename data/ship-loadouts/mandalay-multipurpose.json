  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced multipurpose fit that keeps the Mandalay's range advantage while giving it real teeth and a useful bay. Initial is buy-only; A-Rated is the all-rounder baseline; Engineered applies the house pattern with range and sustain prioritised. Re-role by swapping the optional internals — cargo racks for trading, a passenger cabin, mining kit, or scanners + AFMU + fuel scoop for the deep black.",
          "callout": {
            "label": "Protect the range",
            "text": "The Mandalay's whole identity is range and speed — keep the stock SCO drive, A-rate the FSD and thrusters first, and the light frame means even a cargo or combat fit keeps far more reach than a Python or Krait would. That is its defining all-rounder advantage."
          },
          "notes": {
            "MediumHardpoint1": "Primary gimballed multi-cannon; Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint3": "The laser slot — buy a cheap pulse, swap to a gimballed beam at A-rated; Thermal Vent runs it cold for shield-stripping.",
            "MediumHardpoint4": "Third medium multi-cannon; Auto Loader keeps its DPS uninterrupted.",
            "SmallHardpoint1": "Small pulse adds heat-free shield chip; Efficient + Thermal Vent keeps it cool.",
            "SmallHardpoint2": "Second small pulse rounds out the battery; Efficient trims power and heat.",
            "TinyHardpoint1": "Lone shield booster; Heavy Duty multiplies the bi-weave's raw MJ on a light frame.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Long Range extends scan reach. Reveals bounties for higher payouts.",
            "PowerPlant": "A-rate for headroom across guns, shield and utilities; Overcharged adds margin, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives preserve the speed and agility that define the hull.",
            "FrameShiftDrive": "The Mandalay's signature — keep the stock SCO drive and engineer Increased Range; Mass Manager claws back jump range under load.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate to feed four mediums and boost together; Charge Enhanced + Super Conduits keep the weapon capacitor full.",
            "Radar": "Drop to D and go Lightweight; an all-rounder needs no sensor range, so save the mass for jumps.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave (a class-5 module under-fills this size-6 slot to save mass) regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size4": "Hull reinforcement caps at size 5, so a size-4 HRP fills this slot; Heavy Duty + Deep Plating is the cheapest large armour multiplier.",
            "Slot05_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size2": "Planetary Vehicle Hangar (size-2 SRV bay, the smallest that exists) for opportunistic exploration and exobio; hangars are not engineerable.",
            "Slot08_Size1": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot10_Size1": "Second Module Reinforcement protects the cores; not engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive (SCO)",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer / Elvira Martuuk"
            },
            {
