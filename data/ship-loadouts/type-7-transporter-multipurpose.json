  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A defended budget hauler that jumps and re-roles by the optionals. Initial is the cheapest buy-only suite with one gun and a basic shield; A-rated is the all-round baseline — four small guns, a bi-weave, a fuel scoop and a big hold; Engineered targets the ship's reach, escape speed and shield so it survives the pirates that hunt laden freighters. Re-role by swapping the optional internals: all cargo racks for trading, a passenger cabin for tourists, or mining tools plus a refinery for ore.",
          "callout": {
            "label": "Re-role by the optionals",
            "text": "Cores stay fixed; the optional internals define the job. Fill the size-6 and size-5 slots with cargo racks to run a ~310 t freighter, drop in a class-6 cabin for passengers, or a mining laser plus refinery and collector controllers for ore. Its four small hardpoints are self-defence only — this hull flees, it does not trade blows."
          },
          "notes": {
            "Armour": "Lightweight bulkhead trims hull mass to protect the modest laden jump; Deep Plating adds a little raw hardness for the dash back to supercruise.",
            "SmallHardpoint1": "Gimballed small multi-cannon for self-defence; Overcharged with the one Corrosive Shell strips resistance off whatever is chasing you.",
            "SmallHardpoint2": "Second small multi-cannon; Overcharged plus Auto Loader keeps it firing without reloads.",
            "SmallHardpoint3": "Gimballed pulse laser for shield-stripping; Efficient keeps heat and power low on a weak class-4 distributor.",
            "SmallHardpoint4": "Second Efficient pulse rounds out the four-gun self-defence battery.",
            "TinyHardpoint1": "One shield booster is the cheapest large gain to the bi-weave; Heavy Duty multiplies its raw MJ.",
            "TinyHardpoint2": "Second Heavy Duty booster — the cheapest way to lift the shield you flee behind.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils the gimballed fire of a pursuing pirate.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running.",
            "PowerPlant": "Overcharged adds headroom for the guns, shield and utilities together; Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated plus Dirty Drives give the burst speed to break interdiction when laden — the point of a fleeing hauler.",
            "FrameShiftDrive": "Increased Range first — reach quieter, distant markets and hotspots; Mass Manager extends the laden jump further.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rated for sustained weapon and boost power on a weak class-4 unit; Charge Enhanced plus Super Conduits feeds the guns and the escape boost.",
            "Radar": "Drop to D and go Lightweight; a hauler needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises MJ and Fast Charge speeds the recharge for escape.",
            "Slot02_Size6": "Optional — adds cargo space; swap for a cabin or mining rack to re-role. Cargo racks aren't engineerable.",
            "Slot03_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size5": "Fuel scoop for long legs to distant markets; fuel scoops cannot be engineered.",
            "Slot06_Size5": "Optional / low-priority — a shield cell bank for burst healing; swap for more cargo on a pure freighter run.",
            "Slot07_Size3": "Hull reinforcement is the cheapest large multiplier on effective armour; Heavy Duty plus Deep Plating stack it.",
            "Slot08_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot10_Size1": "Optional / low-priority — Detailed Surface Scanner maps planets for exploration income on the side."
          },
          "engineeringPlan": [
