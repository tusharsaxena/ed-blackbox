        "edbb": {
          "role": "exploration",
          "intro": "A tidy medium-pad explorer fit. Initial is buy-only; A-rated is the expedition baseline; Engineered maximises range within the Scout's modest frame.",
          "callout": {
            "label": "Complete, if modest",
            "text": "The Scout's seven optionals carry a class-5 scoop, Guardian booster, SRV bay, AFMU and scanner — a full expedition kit, just with less range and redundancy than the Asp Explorer. Tidy and sufficient for cost-conscious trips."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional landing shield booster — Heavy Duty adds raw MJ so a hard touchdown won't breach the light bi-weave.",
            "PowerPlant": "D-rated to save mass; Low Emissions runs it cold for safe scooping close to a star.",
            "MainEngines": "D-rated for mass; Clean Drive Tuning keeps the thrusters cool and efficient on the long haul.",
            "FrameShiftDrive": "A-rate this first — Increased Range plus Mass Manager is the whole jump-range case for the Scout.",
            "LifeSupport": "D-rate and go Lightweight to shed mass; life support has no experimental effect.",
            "PowerDistributor": "D-rated; Engine Focused gives enough engine cap to boost, Stripped Down trims the mass.",
            "Radar": "Drop to D and go Lightweight — exploration needs no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock class-4 tank — a couple of jumps between scoops; fuel capacity cannot be engineered.",
            "Slot01_Size5": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size4": "Guardian FSD Booster adds a flat range bonus to every jump; needs a Guardian-site run and cannot be engineered.",
            "Slot03_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot04_Size3": "Planetary Vehicle Hangar — a size-2 SRV bay under-fills the size-3 slot for surface mapping and exobiology.",
            "Slot05_Size2": "Light bi-weave for landings only; Enhanced Low Power with Lo-Draw keeps mass and power minimal.",
