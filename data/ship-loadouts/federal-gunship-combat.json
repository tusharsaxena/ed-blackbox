  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A turret-saturation tank fit using all three military slots and the class-7 distributor. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern weighted to turrets and hull.",
          "callout": {
            "label": "Turrets and the class-7 distributor",
            "text": "Turret weapons let the Gunship fire on everything around it while you focus on staying alive — and the oversized distributor feeds them all without throttling. Lean into the saturation identity; don't fit it like a fixed-weapon striker it can't fly as."
          },
          "notes": {
            "LargeHardpoint1": "Largest turret mount; the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint1": "Medium turret multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "MediumHardpoint2": "Second medium turret MC; Auto Loader keeps its DPS uninterrupted.",
            "MediumHardpoint3": "Buy a cheap pulse, swap to a Thermal-Vent beam once A-rated for heat-free shield-stripping.",
            "MediumHardpoint4": "Second beam turret; Thermal Vent vents heat so the pair runs cold under sustained fire.",
            "SmallHardpoint1": "Left empty on the buy-only fit; add a small turret MC once the hull is paid off.",
            "SmallHardpoint2": "Second small turret MC adds chip damage; Auto Loader keeps it topped up.",
            "TinyHardpoint1": "First of the shield-booster pair; Heavy Duty multiplies the generator's raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers seven turrets, a fighter, a big shield and cells; Overcharged adds headroom, Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives recover what little mobility the heavy hull allows.",
            "FrameShiftDrive": "A-rated to reach fights and rank turn-ins; only G3 range — a turret tank doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — the class-7 unit feeds all seven mounts plus boost without throttling.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour.",
            "Military02": "Second Heavy-Duty HRP — three military slots stack into the Gunship's signature tank.",
            "Military03": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size6": "Primary shield layer over the armour; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Buy a cheap cargo rack, swap to a fighter bay once A-rated — a remote gun for the saturation platform; hangars are not engineerable.",
            "Slot03_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot04_Size2": "Module Reinforcement protects the cores; not engineerable.",
            "Slot05_Size2": "More Heavy-Duty hull where the slot allows; armour stacks linearly.",
            "Slot06_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
