  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A glass-cannon shield-tank fit built around the three large guns. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern, leaning on shields since the armour is thin.",
          "callout": {
            "label": "Shield-tank the glass cannon",
            "text": "With thin armour and one military slot, the Kestrel survives on shields — a Reinforced bi-weave, two Heavy-Duty boosters and a pair of cell banks. End fights before the shield drops; the hull underneath is brittle."
          },
          "notes": {
            "LargeHardpoint1": "Primary large mount; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "LargeHardpoint3": "Large beam for shield-stripping; Thermal Vent vents heat so it runs cold on a heat-tight small hull.",
            "SmallHardpoint1": "Small pulse adds heat-free shield damage; Efficient keeps draw and heat low.",
            "SmallHardpoint2": "Second small pulse; left empty on the buy-only fit, fitted once the hull is paid off.",
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large gain on the bi-weave's raw MJ.",
            "TinyHardpoint2": "Second Heavy-Duty booster; the Kestrel leans on shields because the armour is thin.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate alongside the distributor; Overcharged feeds three large guns and a strong shield, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives give the speed to dictate range and disengage.",
            "FrameShiftDrive": "A-rated to reach RES sites and turn-ins; only G3 range — combat needs no jump monster.",
            "LifeSupport": "D-rate to save mass on a size-1 slot; Lightweight trims more, and life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — three large guns plus boost strain the class-5 distributor harder than anything else.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "The lone military slot; Heavy-Duty hull reinforcement is the cheapest large multiplier on the thin armour.",
            "Slot01_Size5": "Bi-weave regenerates fast under fire; Reinforced maximises its low base MJ and Hi-Cap adds more.",
            "Slot02_Size4": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size3": "More Heavy-Duty hull where the slot allows — armour stacks linearly.",
            "Slot04_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size2": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot06_Size2": "Second Module Reinforcement protects the cores that keep you flying; not engineerable.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 5,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Multi-Cannons",
              "size": 3,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Corrosive Shell (one) / Auto Loader (rest)",
              "engineer": "Tod McQuinn"
            },
            {
              "module": "Beam Laser",
              "size": 3,
              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Thermal Vent",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Pulse Lasers",
              "size": 1,
              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Phasing Sequence",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Power Distributor",
              "size": 5,
              "grade": "G5",
              "blueprint": "Charge Enhanced",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 5,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
