  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A combat-leaning multirole fit with a fighter bay. Initial is buy-only; A-rated is the multirole baseline; Engineered sharpens its firepower and survivability while keeping the flexibility to swap roles.",
          "callout": {
            "label": "A fighter and a flexible hold",
            "text": "The SLF bay is the Krait Mk II's signature — deploy a wingman in combat, or have an NPC fly it. The rest re-tunes: cargo for trade, a mining suite to mine, a fuel scoop and SRV to explore. Keep role module sets in storage."
          },
          "notes": {
            "LargeHardpoint1": "Primary large multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "LargeHardpoint3": "Large beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "MediumHardpoint1": "Gimballed pulse for chip damage; Efficient cuts heat and draw, Phasing Sequence leaks damage through shields.",
            "MediumHardpoint2": "Second pulse rounds out the battery — same Efficient + Phasing Sequence for cool, shield-piercing fill-in fire.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ for the cheapest large survivability gain.",
            "TinyHardpoint2": "Second Heavy-Duty booster; diminishing returns set in but it still pays before utilities turn to countermeasures.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers three large guns, the SLF bay and a bi-weave; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives push boost toward ~400 m/s — the pace that defines this all-rounder.",
            "FrameShiftDrive": "A-rated + Increased Range with Mass Manager keeps jump range usable across trade and exploration swaps.",
            "LifeSupport": "A-rated for long emergency oxygen; Lightweight trims mass, and life support has no experimental effect.",
            "PowerDistributor": "A-rate this to sustain three large guns and boost together; Charge Enhanced + Super Conduits widen the WEP buffer.",
            "Radar": "Drop to D and go Lightweight; a multirole needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "The SLF hangar is the hull's signature — a wingman that draws fire; hangars are not engineerable.",
            "Slot02_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more (Resistance Augmented is a booster blueprint, not a generator one).",
            "Slot03_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot04_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot05_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size3": "Heavy-Duty hull reinforcement is the cheapest large multiplier on effective armour; Deep Plating adds raw HP.",
            "Slot07_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot09_Size1": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 7,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani / Marsha Hicks"
            },
            {
