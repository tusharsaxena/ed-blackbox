              "grade": "G5",
              "blueprint": "Efficient",
              "experimental": "Thermal Vent (beam) / Phasing Sequence (pulse)",
              "engineer": "Broo Tarquin"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 6,
