  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defensible trade fit: a solid hold, strong shield and enough guns to fight off pirates. Initial is buy-only; A-rated is the trade baseline; Engineered balances cargo, protection and teeth.",
          "callout": {
            "label": "Haul, but keep the teeth",
            "text": "Unlike a pure freighter, the Python keeps its three large guns and a strong shield alongside a ~216t hold — so when a pirate interdicts, you turn and destroy them rather than fleeing. Carry a little less cargo for the privilege of never being a victim."
          },
          "notes": {
            "LargeHardpoint1": "Large gimballed multi-cannon (caps at C-rated); Overcharged + one Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so the deterrent never stops firing.",
            "LargeHardpoint3": "Large beam for shield-stripping; Thermal Vent runs it cold so heat never forces you off the target.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ so it tanks the interdiction.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength for a hauler.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers three guns, the bi-weave and a cell bank; Low Emissions keeps heat and signature down, Thermal Spread bleeds the rest.",
            "MainEngines": "A-rated + Dirty Drives move the laden hull and let it reposition to turn and fight.",
            "FrameShiftDrive": "A-rated + Increased Range G5 with Mass Manager for laden route efficiency — range is the trader's profit.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate so it sustains three guns plus boost while fully laden; Engine Focused biases the laden boost, Super Conduits speed weapon recharge.",
            "Radar": "Drop to D and go Lightweight; a trader needs no sensor range, so save the mass for cargo.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Bi-weave shield regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more — the survival core of a defensible trader.",
            "Slot04_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot06_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot07_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot08_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot09_Size2": "Hull reinforcement backs the shield with armour; Heavy Duty + Deep Plating is the cheapest effective-hull multiplier.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
