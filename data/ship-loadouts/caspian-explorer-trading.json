  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defensible bulk-hauler fit that keeps a bi-weave shield, a four-booster stack and a shield cell bank, mounts one large deterrent gun on the hull's Large hardpoint, then fills every remaining slot with cargo. The Caspian is a large hull with 1 Large + 6 Medium hardpoints, so a hauler can carry a real gun and still keep the hold near-full. Initial is cheapest buy-only with a shield from day one; A-rated is the trade baseline; Engineered maximises laden range and protected cargo.",
          "callout": {
            "label": "Shield the hold, then end the interdiction",
            "text": "The Caspian mounts 1 Large + 6 Medium weapon hardpoints — plenty for a hauler in hostile space. Fit a large gimballed multi-cannon on the Large mount so an interdictor gets shot off your tail rather than merely out-run; keep the bi-weave, the booster stack and the cell bank behind it, and leave the six mediums empty so cargo stays the priority. The boost and class-8 drive still cover a clean high-wake escape when you'd rather not fight."
          },
          "notes": {
            "LargeHardpoint1": "Large gimballed multi-cannon on the hull's Large hardpoint — the deterrent gun; Overcharged plus Corrosive Shell let a hauler actually punish an interdictor instead of only running from one. Gimballed so it tracks without a fight pilot's aim.",
            "TinyHardpoint1": "First of the shield-booster stack; Heavy Duty multiplies the bi-weave's raw MJ to protect the cargo.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength, tanking hits while the gun does its work.",
            "TinyHardpoint3": "Third Heavy-Duty booster; diminishing returns set in but the shield buys the seconds to shoot back or wake out, so it still pays.",
            "TinyHardpoint4": "Fourth Heavy-Duty booster rounds out the shield stack before the utilities turn to countermeasures.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils an interdictor's gimballed fire so you can jump clear.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles while you run.",
            "PowerPlant": "Low Emissions keeps the plant cool and the signature low on contested routes; Thermal Spread bleeds the remaining heat.",
            "MainEngines": "A-rated plus Dirty Drives lift a laden 950t hull's boost — the speed that breaks an interdiction and escapes.",
            "FrameShiftDrive": "The class-8 SCO drive is the one range asset a heavy hull has; Increased Range + Mass Manager stretch the laden jump as far as the mass allows.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "Engine Focused fills the engine capacitor to sustain the escape boost; Super Conduits enlarge it further.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass for cargo and range.",
            "FuelTank": "Stock class-7 tank for long legs between refuelling stops; fuel capacity cannot be engineered.",
            "Slot01_Size7": "Largest cargo rack — 128 t in a single slot, the core of the hold. Cargo racks aren't engineerable.",
            "Slot02_Size6": "Bi-weave shield regenerates fast under fire — the right shield for surviving a hit and running; Reinforced maximises its MJ and Hi-Cap adds more. The hull's primary defence.",
            "Slot03_Size6": "Second big cargo rack. Drop to a fuel scoop only if a route runs far from stations. Cargo racks aren't engineerable.",
            "Slot04_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot07_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing when an escape goes wrong.",
            "Slot08_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot10_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot11_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot12_Size1": "Optional — a last small cargo rack. Cargo racks aren't engineerable.",
            "Slot13_Size1": "Optional — a last small cargo rack. Cargo racks aren't engineerable.",
            "Slot14_Size1": "Small Heavy-Duty hull reinforcement stiffens the frame against the hits that get through the shield; armour stacks linearly."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 8,
              "grade": "G5",
