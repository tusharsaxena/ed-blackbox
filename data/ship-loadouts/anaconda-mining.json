  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete capital miner that keeps real guns and a strong shield for self-defence. Initial is the cheapest buy-only loop; A-Rated is the role-ready mining baseline; Engineered focuses on mobility, defence and heat — the mining tools themselves are not meaningfully engineered, so they stay stock.",
          "callout": {
            "label": "A miner that fights back",
            "text": "The Anaconda's edge over a dedicated mining hull is that it can carry the full extraction suite — lasers, seismic, sub-surface and abrasion — and still mount a huge multi-cannon behind a deep shield. Build the ship for defence and reach; leave the mining hardware stock."
          },
          "notes": {
            "HugeHardpoint1": "Huge gimballed multi-cannon for pirate defence; Overcharged + Corrosive Shell makes the one gun hit hard enough to matter.",
            "LargeHardpoint1": "Primary mining laser; mining lasers cap at size 2, so it under-fills the large mount and carries no blueprint.",
            "LargeHardpoint2": "Seismic charge launcher for core (motherlode) mining; not engineerable.",
            "LargeHardpoint3": "Sub-surface displacement missile for deep deposits; not engineerable.",
            "MediumHardpoint1": "Abrasion blaster knocks surface deposits loose for collectors; not engineerable.",
            "MediumHardpoint2": "Second mining laser to raise laser-mining throughput; not engineerable.",
            "SmallHardpoint1": "Third (size-1) mining laser fills the last small mount; not engineerable.",
            "TinyHardpoint1": "Pulse Wave Analyser to spot deposit-rich rocks and core hotspots; no blueprint.",
            "TinyHardpoint2": "First of three shield boosters; Heavy Duty multiplies the bi-weave's raw MJ for the exposed minutes of cracking a core.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more shield with Super Capacitors.",
            "TinyHardpoint4": "Third Heavy-Duty booster rounds out the defensive stack.",
            "TinyHardpoint5": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint6": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint7": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "PowerPlant": "Runs tools, limpets, a strong shield and guns together; Low Emissions + Thermal Spread keeps this heat-prone hull cool through long sessions.",
            "MainEngines": "A-rated + Dirty Drives so a laden capital miner can still reposition and run when pirates arrive.",
            "FrameShiftDrive": "A-rated + Increased Range to reach distant hotspots and haul a deep ore hold home.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more and life support has no experimental.",
            "PowerDistributor": "A-rated and Engine Focused so the heavy hull keeps its boost charge for escapes; mining-laser WEP draw is trivial on a class-8 distributor.",
            "Radar": "Drop to D and go Lightweight; a miner needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot01_Size7": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises MJ and Fast Charge keeps the quick recharge that defines the bi-weave.",
            "Slot04_Size6": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size5": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot06_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot07_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot09_Size4": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot10_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot11_Size2": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot12_Size1": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets."
          },
          "engineeringPlan": [
            {
              "module": "Power Distributor",
              "size": 8,
              "grade": "G3",
              "blueprint": "Engine Focused",
              "experimental": "(none)",
              "engineer": "The Dweller"
            },
            {
