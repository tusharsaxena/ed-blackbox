  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "multipurpose",
          "intro": "A balanced medium-pad generalist — a defensive multi-cannon-and-laser battery, a class-6 bi-weave over a stacked hull, and a big re-fittable hold. Initial is buy-only; A-rated is the all-round baseline; Engineered lifts a heavy, slow hull to workable across trade, light combat and errands. The Type-8 flexes wide but excels at nothing: small hardpoints only, a class-4 distributor and a class-5 FSD cap its combat and jump ceilings.",
          "callout": {
            "label": "A hauler that dabbles",
            "text": "Strip the guns and stack cargo to trade; keep the bi-weave and boosters to survive open play. But the Type-8 has no large hardpoint, a weak distributor and a short jump — it re-roles between hauling and light combat, never into a warship or an explorer. Buy it for the hold, not the versatility."
          },
          "notes": {
            "MediumHardpoint1": "The only medium mount carries the build's alpha; a gimballed multi-cannon Overcharged with the one Corrosive Shell strips armour resistance for the whole battery.",
            "SmallHardpoint1": "Gimballed small multi-cannon adds kinetic chip damage; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint2": "Second small multi-cannon pairs with the first; Auto Loader keeps its DPS uninterrupted.",
            "SmallHardpoint3": "Small beam for shield-stripping; Thermal Vent vents heat so it runs cold on the Type-8's tight power budget.",
            "SmallHardpoint4": "Gimballed small pulse; Efficient keeps heat and distributor draw low on the weak class-4 plant.",
            "SmallHardpoint5": "Second Efficient pulse rounds out the laser side for steady, cheap-to-run DPS.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster before the last two utilities turn to countermeasures.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "5A feeds six guns, the shield and cells at once; Overcharged adds the headroom the stock plant lacks, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives claw back agility on a slow 400 t hull; even engineered it stays ponderous.",
            "FrameShiftDrive": "A-rated with Increased Range + Mass Manager for the best laden jump a class-5 FSD can give — still short of any dedicated explorer.",
            "LifeSupport": "D-rate to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "The Type-8's weak class-4 distributor is the real combat limiter; A-rate and Charge Enhanced + Super Conduits so it can sustain the boost and the guns at all.",
            "Radar": "Drop to D and go Lightweight; a generalist needs no sensor range, so save the mass for jump.",
            "FuelTank": "Stock class-5 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size7": "Optional — the big size-7 rack is the hull's whole case; adds cargo space for hauling. Cargo racks aren't engineerable.",
            "Slot02_Size6": "A class-6 bi-weave trades 64 t of cargo for a fast-regenerating shield; Reinforced maxes its MJ and Hi-Cap adds more — the survivable all-round choice.",
            "Slot03_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size5": "Hull reinforcement caps at size 5, so a 5D HRP fully fills this slot for max effective armour; Heavy Duty plus Deep Plating stack it.",
            "Slot06_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size4": "Heavy-Duty hull reinforcement (a 4D HRP) where the slot allows; armour stacks linearly.",
            "Slot08_Size2": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 5,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 5,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Power Distributor",
              "size": 4,
              "grade": "G5",
              "blueprint": "Charge Enhanced",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 6,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Hi-Cap",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Multi-Cannons",
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Corrosive Shell (one) / Auto Loader (rest)",
              "engineer": "Tod McQuinn"
            },
            {
