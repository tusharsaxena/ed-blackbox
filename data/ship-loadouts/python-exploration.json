  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "An equipped expedition fit that trades outright range for deep self-sufficiency. Initial is buy-only — the hull stripped to a maxed FSD and the biggest scoop; A-Rated is the expedition baseline; Engineered claws every light-year out of a heavy 350-tonne frame while carrying full kit and redundancy. Hardpoints run clean — no weapons fitted.",
          "callout": {
            "label": "Capacity over range",
            "text": "The Python carries a class-6 scoop, a multi-SRV bay, two AFMUs, a scanner, a landing shield and spare fuel all at once — deep self-sufficiency for long stays. The trade is range: even fully optimised it tops out near ~45 LY, so plan more jumps per leg."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "One booster props up the light landing shield; Heavy Duty adds raw MJ for hard touchdowns.",
            "PowerPlant": "D-rate for low mass; Low Emissions cuts heat and signature so the ship stays cool while scooping.",
            "MainEngines": "D-rate to save weight; Clean Drive Tuning keeps the heavy hull cool and reasonably nimble.",
            "FrameShiftDrive": "A-rate then Increased Range + Mass Manager — the single biggest lever on a short-ranged hull.",
            "LifeSupport": "D-rate and Lightweight to shed mass; life support takes no experimental effect.",
            "PowerDistributor": "D-rate; Engine Focused feeds boost for planet approaches and Stripped Down trims the mass.",
            "Radar": "D-rate and Lightweight; exploration needs no sensor range, so save the tonnes.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size6": "Guardian FSD Booster maxes at size 5, so it under-fills this size-6 slot; still the largest flat range bonus there is.",
            "Slot03_Size6": "Multi-SRV hangar for surface science and exobiology; hangars carry no blueprint.",
            "Slot04_Size5": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot05_Size5": "Light Bi-Weave for landings and the odd scrape; Enhanced Low Power + Stripped Down keep its mass and draw minimal.",
            "Slot06_Size4": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size3": "Repair Limpet Controller fixes hull damage the AFMU cannot; controllers carry no blueprint.",
            "Slot08_Size3": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data.",
            "Slot09_Size2": "Extra fuel stretches range between scoopable stars on sparse routes; tank capacity is fixed.",
            "Slot10_Size1": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo."
          },
