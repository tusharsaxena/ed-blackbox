  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "ax-combat",
          "intro": "A high-damage anti-Xeno fit: heavy Gauss/AX weapons on the large mounts, a fighter for decoy and extra guns, and Guardian hull reinforcement (no military slots, so hardening goes in optionals). Initial is buy-only; AX-fitted adds the kit; Engineered hardens mobility and survival.",
          "callout": {
            "label": "Kill fast, decoy, harden in optionals",
            "text": "With no military slots, the Krait puts Guardian module/hull reinforcement in its optionals — less than a Chieftain can carry, so it leans on ending the fight quickly. The SLF is a key tool: deploy it to split Thargoid attacks while your three large guns melt the hearts. Manage heat hard."
          },
          "notes": {
            "LargeHardpoint1": "Fixed Guardian Gauss — the premium AX heart-killer; size 2 is the largest Gauss made, so it under-mounts this large slot but out-damages anything that fills it.",
            "LargeHardpoint2": "Second fixed Gauss for the alpha that melts an Interceptor's exposed hearts fastest; Guardian weapons take no engineering.",
            "LargeHardpoint3": "Enhanced AX Multi-Cannon fills the large mount with sustained anti-Thargoid DPS between Gauss charges.",
            "MediumHardpoint1": "Enhanced AX Multi-Cannon adds continuous AX fire to keep pressure on hearts and swarm.",
            "MediumHardpoint2": "Fixed Guardian Shard Cannon shreds exposed hearts at close range; Guardian tech, no blueprint.",
            "TinyHardpoint1": "Xeno Scanner reveals Interceptor heart count and cycle — essential targeting data; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Single shield booster; Thermal Resistant hardens the bi-weave against Thargoid thermal damage.",
            "PowerPlant": "A-rate first — Gauss and AX weapons are power-hungry; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives buy the agility to dodge between Thargoid damage windows — the Krait's main survival tool.",
            "FrameShiftDrive": "A-rated + Increased Range to reach distant AX sites and Maelstroms; Mass Manager stretches the jump further.",
            "LifeSupport": "A-rated for long oxygen reserve through a canopy breach; Lightweight trims mass; no experimental effect.",
            "PowerDistributor": "A-rate + Charge Enhanced so the WEP capacitor sustains Gauss volleys; Super Conduits speeds the recharge.",
            "Radar": "Drop to D and go Lightweight — AX needs no sensor range, so save the mass.",
            "FuelTank": "Stock tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Fighter Hangar — the SLF is a decoy that splits Thargoid attacks and adds a second gun; hangars are not engineerable.",
            "Slot02_Size6": "Bi-Weave regenerates fast under fire; Thermal Resistant counters Thargoid thermal and Fast Charge speeds the rebuild.",
            "Slot03_Size5": "Guardian Hull Reinforcement adds armour AND caustic resistance — the AX-specific hardening; Guardian tech, no blueprint.",
            "Slot04_Size5": "Guardian Module Reinforcement protects internals from the lightning the Krait can't harden with military slots; not engineerable.",
            "Slot05_Size4": "Decontamination Limpet Controller scrubs caustic damage; comes only in sizes 1/3/5/7, so a size-3 under-fills this size-4 slot.",
            "Slot06_Size3": "Second Guardian HRP stacks more armour and caustic resistance where the slot allows.",
            "Slot07_Size3": "Module Reinforcement spreads penetrating-hit damage across the cores; not engineerable.",
            "Slot08_Size2": "Third Guardian HRP for more effective armour and caustic resistance in the small slot.",
            "Slot09_Size1": "Guardian FSD Booster extends jump range to reach far AX sites; Guardian tech, not engineerable."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 7,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
