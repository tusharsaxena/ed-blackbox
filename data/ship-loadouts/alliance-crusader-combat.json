  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A crewed gunboat fit with a fighter bay and three military slots. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern with reinforcement and an SLF.",
          "callout": {
            "label": "Build for the crew and the fighter",
            "text": "Fit a fighter hangar and a couple of turret weapons a gunner can control, alongside your own gimballed main guns. The Crusader's value is teamwork — a deployed SLF plus a gunner roughly doubles its effective output."
          },
          "notes": {
            "LargeHardpoint1": "The biggest mount on the hull (Large); Overcharged multi-cannon with the single Corrosive Shell strips armour resistance for the whole battery.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a gimballed beam once A-rated; Thermal Vent vents heat so it runs cold while shield-stripping.",
            "MediumHardpoint2": "Second medium multi-cannon; Auto Loader removes reloads so it never stops firing.",
            "SmallHardpoint1": "Turret pulse the gunner controls; Efficient + Thermal Vent keeps it cool and low-draw on a remote seat.",
            "SmallHardpoint2": "Turret multi-cannon for the gunner; Auto Loader keeps it topped up without a reload pause.",
            "SmallHardpoint3": "Pilot-fired gimballed pulse fills out the battery; Efficient trims heat and distributor draw.",
            "TinyHardpoint1": "First Heavy-Duty shield booster — the cheapest large multiplier over the bi-weave's low base MJ.",
            "TinyHardpoint2": "Second stacked Heavy-Duty booster; diminishing returns set in but it still pays.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Feeds guns, a shield, the fighter bay and turrets; Overcharged adds headroom and Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover what mobility the heavy hull allows — the Crusader is the slowest Alliance trio member.",
            "FrameShiftDrive": "A-rated only to reach fights and turn-ins; G3 range is enough — combat doesn't need a jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this early — guns plus the SLF's draw drain the class-6 distributor fast; Charge Enhanced restores the WEP pool.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Heavy-Duty hull reinforcement in a military slot — the cheapest large multiplier on effective armour.",
            "Military02": "Second Heavy-Duty HRP; the size-4 military slots take a full size-4 HRP so they fill exactly.",
            "Military03": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot01_Size6": "SLF bay — the Crusader's signature; a deployed fighter is a second gun platform that draws fire. Hangars are not engineerable.",
            "Slot02_Size5": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and resistances, Fast Charge keeps the quick recharge.",
            "Slot03_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot04_Size3": "More Heavy-Duty hull where the optional slot allows; armour stacks linearly.",
            "Slot05_Size2": "Module Reinforcement protects the cores; not engineerable.",
            "Slot06_Size2": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Plant",
              "size": 6,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani / Marsha Hicks"
            },
            {
              "module": "Thrusters",
