  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A defended budget mining fit built around the fighter bay. Initial is buy-only; A-rated is the mining baseline; Engineered targets the ship's defence and mobility — the mining tools are deliberately left stock.",
          "callout": {
            "label": "Fighter first, ore second",
            "text": "The fighter hangar is the Keelback's reason to mine — deploy an SLF to drive off pirates while you work the ring. That leaves a small ore hold, refinery and limpet controllers; per-trip hauls are modest, but you survive the rings that kill cheaper miners."
          },
          "notes": {
            "MediumHardpoint1": "Size-2 mining laser fills the medium mount — your main ore-extraction beam; mining tools gain little from engineering, so it stays stock.",
            "MediumHardpoint2": "Sub-surface Displacement Missile cracks sub-surface deposits; left stock — mining tools aren't meaningfully engineered.",
            "SmallHardpoint1": "Abrasion Blaster knocks surface deposits off motherlodes for the collectors to scoop; stock by design.",
            "SmallHardpoint2": "Second mining laser, size-1 on the small mount, adds extraction rate; left stock.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up cores and deposits across the ring; a utility scanner with no blueprint.",
            "TinyHardpoint2": "Shield Booster stacks onto the bi-weave; Heavy Duty multiplies its raw MJ so you tank ring hazards while the SLF fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate to run the fighter bay, lasers, limpets and shield together; Low Emissions cuts heat and signature, Thermal Spread bleeds still more.",
            "MainEngines": "A-rated + Dirty Drives give the speed to reposition in the ring and break interdictions.",
            "FrameShiftDrive": "A-rated + Increased Range reaches hotspot rings and hauls ore home; Mass Manager stretches the laden jump.",
            "LifeSupport": "D-rate this size-1 slot to save mass; Lightweight trims more — life support has no experimental effect.",
            "PowerDistributor": "A-rate for sustained laser and limpet draw; Engine Focused favours boost to escape, since the SLF does the fighting.",
            "Radar": "D-rate and go Lightweight — mining needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Fighter Hangar is the Keelback's whole point — launch an SLF to drive off pirates while you mine; hangars aren't engineerable.",
            "Slot02_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot03_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot04_Size3": "Bi-Weave to survive ring hazards and pirate fire while the SLF fights; Reinforced for buffer, Fast Charge to recover quickly.",
            "Slot05_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot07_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
