  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A durable anti-Xeno fit: a full AX/Guardian weapon suite, three military slots of Guardian reinforcement, and heavy hull and module hardening. Initial is buy-only (bare hull, E cores); A-Rated adds the Thargoid kit once weapons and Guardian tech are unlocked; Engineered maximises endurance, caustic survival and heat handling.",
          "callout": {
            "label": "Tank, harden, endure",
            "text": "The Challenger leans on armour and Guardian reinforcement rather than dodging — stack Guardian hull and module reinforcement across the military slots and optionals, run a thermal-resistant bi-weave, and grind the Thargoid down while it bounces off you. It still needs caustic and heat management; it just survives the hits the Chieftain avoids."
          },
          "notes": {
            "LargeHardpoint1": "Enhanced AX Multi-Cannon (gimballed) is the sustained workhorse against Thargoid hull; AX weapons take no engineering blueprint.",
            "MediumHardpoint1": "Fixed Guardian Gauss Cannon — the heart-cracker that does the real damage to Interceptor exertion points.",
            "MediumHardpoint2": "Second Gauss for paired heart bursts; fixed-mount discipline is the price of its damage.",
            "MediumHardpoint3": "Enhanced AX Multi-Cannon (gimballed) fills between Gauss charges with easy sustained fire.",
            "SmallHardpoint1": "Guardian Shard Cannon — close-range shred against hull and swarm scouts; no small AX multi-cannon exists.",
            "SmallHardpoint2": "Second Shard Cannon for close-in burst when an Interceptor closes.",
            "SmallHardpoint3": "Third Shard Cannon rounds out the close-range battery.",
            "TinyHardpoint1": "Advanced Xeno Scanner reveals Thargoid type and heart count; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Shield booster — Thermal Resistant trades raw MJ for the thermal resist Thargoids punish.",
            "PowerPlant": "A-rate this first; Overcharged adds the headroom three Gauss plus the suite demand, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives buys what agility the heavy hull allows; Drag Drives sharpens the boost.",
            "FrameShiftDrive": "A-rated to relocate between Thargoid sites; Increased Range with Mass Manager offsets the heavy fit.",
            "LifeSupport": "Keep A-rated for the long oxygen timer when Thargoid lightning cracks the canopy; Lightweight trims mass, no experimental.",
            "PowerDistributor": "A-rate early — Gauss cannons are distributor-hungry; Charge Enhanced + Super Conduits sustain the WEP draw.",
            "Radar": "Drop to D and go Lightweight; AX fights are point-blank, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement spreads penetrating-hit damage off the cores; Guardian tech takes no blueprint.",
            "Military02": "Second Guardian Module Reinforcement — module survival is what keeps the guns and drives online.",
            "Military03": "Guardian Hull Reinforcement adds hull and the caustic resistance no other module gives; not engineerable.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Thermal Resistant maxes the resist that matters vs Thargoid thermal, Fast Charge speeds the refill.",
            "Slot02_Size6": "Guardian HRP caps at size 5, so a 5D unit under-fills this size-6 slot — still the best caustic-resist armour block.",
            "Slot03_Size3": "Decontamination Limpet Controller scrubs caustic damage off the hull mid-fight; limpet controllers take no blueprint.",
            "Slot04_Size3": "More Guardian Hull Reinforcement — caustic resist and hull stack linearly.",
            "Slot05_Size2": "Smaller Guardian HRP tops up caustic resistance where the slot allows.",
            "Slot06_Size2": "Module Reinforcement protects internals from penetrating hits; MRP is not engineerable.",
            "Slot07_Size1": "Heavy-Duty hull reinforcement in the last slot; Deep Plating adds raw armour mass."
          },
