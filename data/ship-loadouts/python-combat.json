  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "combat",
          "intro": "A tough, versatile combat fit using the deep optionals to tank. Initial is buy-only; A-rated is the combat-ready baseline; Engineered applies the house combat pattern. Swap optionals for cargo or mining kit to re-role between fights.",
          "callout": {
            "label": "Tank deep, re-role easy",
            "text": "The Python has no military slots but ten optionals to tank with. Its versatility means you can swap several of those optionals for cargo racks or mining kit and turn the combat ship into a hauler or miner in minutes."
          },
          "notes": {
            "LargeHardpoint1": "Primary large multi-cannon; the single Corrosive Shell strips armour resistance for the whole battery.",
            "LargeHardpoint2": "Second large multi-cannon; Auto Loader removes reloads so its DPS never stops.",
            "LargeHardpoint3": "Large beam for shield-stripping; Thermal Vent vents heat so it runs cold under sustained fire.",
            "MediumHardpoint1": "Buy a cheap pulse, swap to a Thermal-Vent beam once A-rated for heat-free shield work.",
            "MediumHardpoint2": "Medium multi-cannon adds sustained kinetic DPS; Auto Loader keeps it topped up.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in shield strength.",
            "TinyHardpoint2": "Second Heavy-Duty booster; diminishing returns set in but it still pays on a no-military-slot hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds chaff salvos. Chaff spoils gimballed and turreted fire.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers three large guns, a big shield and cell banks; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rated + Dirty Drives recover what mobility the heavy hull allows.",
            "FrameShiftDrive": "A-rated to move the hull between fights and re-roles; only G3 range — combat needs no jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — three large guns plus boost drain the class-7 distributor faster than anything else.",
            "Radar": "Drop to D and go Lightweight; combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot03_Size6": "Hull reinforcement caps at size 5, so a 5D HRP under-fills this size-6 slot for max effective armour.",
            "Slot04_Size5": "Second Heavy-Duty HRP at full size 5; armour stacks linearly.",
            "Slot05_Size5": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot06_Size4": "Module Reinforcement spreads penetrating-hit damage across internals; not engineerable.",
            "Slot07_Size3": "More Heavy-Duty hull where the slot allows.",
            "Slot08_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot09_Size2": "Second Module Reinforcement protects the cores; not engineerable.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
