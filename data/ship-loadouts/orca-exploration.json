  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A comfortable touring fit that fills the nine optionals with a full kit. Initial is buy-only; A-rated is the expedition baseline; Engineered shaves mass to claw the range back toward ~45 LY while keeping the scoop, SRV bay and redundancy.",
          "callout": {
            "label": "Full kit, modest range",
            "text": "The Orca carries a class-6 scoop, Guardian booster, two AFMUs, an SRV bay, a scanner and a comfort cabin at once — a complete, self-sufficient touring fit. Even stripped and engineered, the heavy hull and class-5 drive hold range near ~45 LY; spend mass where it earns the most range first."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint3": "Light Shield Booster reinforces the landing shield; Heavy Duty maximises the small buffer for surface touchdowns.",
            "PowerPlant": "D-rate to shed mass, then Low Emissions keeps heat down for aggressive scooping; Thermal Spread bleeds more.",
            "MainEngines": "D-rated thrusters save mass; Clean Drive Tuning runs cool and efficient, Stripped Down trims more mass for range.",
            "FrameShiftDrive": "A-rate FIRST — range is the Orca's weak point; Increased Range G5 + Mass Manager push the laden hull toward ~45 LY.",
            "LifeSupport": "D-rate the size-6 unit and go Lightweight to shed real mass from the liner hull; life support has no experimental effect.",
            "PowerDistributor": "D-rated suffices for an unarmed hull; Engine Focused keeps boost for gravity-well take-offs, Stripped Down trims mass.",
            "Radar": "Drop to D and go Lightweight — exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size5": "Guardian FSD Booster size 5 adds the largest flat jump-range bonus; not engineerable, but needs a Guardian-site run.",
            "Slot03_Size5": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot04_Size5": "Bi-Weave landing shield regenerates fast without docking; Enhanced Low Power + Stripped Down keep it light on mass and power.",
            "Slot05_Size4": "Size-4 SRV hangar for surface sampling and exobiology; vehicle bays carry no blueprint.",
            "Slot06_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot07_Size2": "Extra fuel tank extends jump count between scoopable stars; fuel tanks are not engineerable.",
            "Slot08_Size2": "Economy cabin keeps the Orca's comfort-tourer identity, or swap for science/extra fuel; cabins carry no blueprint.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
