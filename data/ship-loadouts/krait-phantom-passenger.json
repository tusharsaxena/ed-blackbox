  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A medium sightseeing fit — an economy-led cabin suite, a protective shield and a high-range FSD, hardpoints left clean. Initial is buy-only; A-rated is the passenger baseline; Engineered maximises loaded range and keeps the cabins safe. Drop the shield into a cabin slot for the absolute-max ~94-berth board on safe routes.",
          "callout": {
            "label": "Cabins for the board, the shield for the route",
            "text": "Run the economy-led suite for bulk tourist boards; trade one class-5 economy cabin for a single first-class cabin when a VIP fare appears (class 6 is the largest premium cabin it can take). Keep the bi-weave and point defence on pirate-threatened tourist systems — with no comfort bonus to lean on, the Phantom earns on volume and low rebuy, so don't lose a board to a careless gank."
          },
          "notes": {
            "TinyHardpoint1": "Primary shield booster; Heavy Duty multiplies the bi-weave's raw MJ for cheap passenger survivability.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Second Heavy-Duty booster stacks more shield MJ; drop it for a spare utility on safe runs.",
            "PowerPlant": "A-rated for headroom across cabins, shield and modules; Low Emissions runs it cool with Thermal Spread bleeding the rest.",
            "MainEngines": "A-rated + Dirty Drives keep the loaded hull nimble for boosts and quick station turnarounds.",
            "FrameShiftDrive": "A-rate this FIRST — Increased Range + Mass Manager protect the loaded jump range that lets the Phantom work scattered boards.",
            "LifeSupport": "A-rated for emergency-oxygen duration; Lightweight trims mass for range — life support takes no experimental.",
            "PowerDistributor": "A-rated; Engine Focused biases the capacitor toward ENG so the loaded hull can boost away from trouble.",
            "Radar": "D-rate to save mass; sightseeing needs no sensor range, and Lightweight trims more for jump range.",
            "FuelTank": "C-rated stock tank sized to the scoopless cabin fit; fuel capacity cannot be engineered.",
            "Slot01_Size6": "Class-6 economy cabin is the single biggest berth block (32 seats); swap to a class-6 first-class suite for a VIP fare.",
            "Slot02_Size5": "Class-5 economy cabin (16 seats) fills the deep optionals for the bulk board.",
            "Slot03_Size5": "Second class-5 economy cabin; cabins take no engineering — just fit the class the board needs.",
            "Slot04_Size5": "Bi-weave shield regenerates fast under fire; Reinforced maximises MJ and Fast Charge speeds the recharge for passenger safety.",
            "Slot05_Size3": "Class-3 economy cabin (4 seats) tops up the board in the shallow slots.",
            "Slot06_Size3": "Another class-3 economy cabin for volume.",
            "Slot07_Size3": "Third class-3 economy cabin; swap for cargo or a limpet controller when re-roling.",
            "Slot08_Size2": "Class-2 economy cabin (2 seats) — the smallest berth block.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 6,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
