  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A budget medium-pad passenger fit — a deep economy cabin suite behind a shield, hardpoints left clean. Initial is buy-only; A-rated is the passenger baseline; Engineered maximises jump range and keeps the cabins safe. The size-7 optional holds the shield (passenger cabins cap at size 6), freeing all three size-6 slots for fares.",
          "callout": {
            "label": "Cheap seats, medium-pad reach",
            "text": "Fit the cabin mix the board wants — economy for bulk sightseeing, a first or luxury suite for the higher fares — and lean on the Type-8's medium pad to reach outpost tourist beacons the large liners can't dock at. With no liner comfort bonus and a thin shield, the Type-8 competes on cheap volume and pad access, not premium fares. Swap cabins back to cargo racks when the week turns to hauling."
          },
          "notes": {
            "TinyHardpoint1": "First of the shield-booster pair; Heavy Duty multiplies the bi-weave's raw MJ to keep passengers safe.",
            "TinyHardpoint2": "Second Heavy-Duty booster — the cheapest large gain in shield strength on a soft passenger hull.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running when a pirate lights you up.",
            "PowerPlant": "An unarmed hull needs little power, so Low Emissions trims heat and mass; Thermal Spread bleeds the rest for cool cruises.",
            "MainEngines": "A-rated + Dirty Drives keep the loaded barge manoeuvrable in and out of stations.",
            "FrameShiftDrive": "A-rate FIRST — G5 Increased Range plus Mass Manager is the build's identity, stretching the modest size-5 drive as far as it will go.",
            "LifeSupport": "A-rate for emergency-oxygen duration with passengers aboard; Lightweight trims mass and has no experimental effect.",
            "PowerDistributor": "Engine Focused shifts capacity to ENG so the slow hull can keep boosting clear; Super Conduits speeds the recharge.",
            "Radar": "Drop to D and go Lightweight; passenger runs need no sensor range, so save the mass for jump range.",
            "FuelTank": "Stock 5C tank; fuel capacity is fixed and cannot be engineered. Pair with a fuel scoop for long sightseeing legs.",
            "Slot01_Size7": "Bi-weave shield in the size-7 slot (no cabin fits here); Reinforced maximises MJ and Fast Charge restores the bi-weave's quick recovery.",
            "Slot02_Size6": "Economy cabin for bulk sightseeing fares; swap class to suit the board.",
            "Slot03_Size6": "Luxury cabin for the highest-paying VIP fares; passenger cabins are never engineered.",
            "Slot04_Size6": "Economy cabin — the third size-6 slot the relocated shield left free for fares.",
            "Slot05_Size5": "Economy cabin — bulk capacity.",
            "Slot06_Size5": "First-class cabin for the mid-tier fares.",
            "Slot07_Size4": "Economy cabin filling a smaller slot.",
            "Slot08_Size2": "Size-2 slot takes only an economy cabin (business/first/luxury start at size 3+); a couple of extra seats.",
            "Slot09_Size1": "Optional / low-priority — the size-1 slot takes a Supercruise Assist for hands-off cruising between drop-offs; swap for a size-1 economy cabin to squeeze in two more seats."
          },
          "engineeringPlan": [
