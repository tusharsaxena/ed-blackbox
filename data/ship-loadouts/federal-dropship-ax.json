  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "anti-xeno",
          "intro": "A budget AX armour-tank: Guardian Gauss on the mediums for heart damage, an Enhanced AX multi-cannon on the large mount for swarm and caustic missiles, Guardian reinforcement in both military slots and the optionals, and the four utilities run hard on caustic and heat. Initial is buy-only; A-Rated adds the unlocked AX/Guardian kit; Engineered hardens hull, shield, heat and mobility.",
          "callout": {
            "label": "Stand in the fire, harden everything",
            "text": "With the weakest shields of the Federal line, the Dropship leans on armour and Guardian hardening — it survives by absorbing the lightning, not dodging it. Put Gauss on the mediums for heart damage, an AX multi-cannon on the large mount for swarm, and fill both military slots and the optionals with Guardian reinforcement. Run heat and caustic kit hard; Gauss bites into the heat budget fast."
          },
          "notes": {
            "LargeHardpoint1": "Gimballed Enhanced AX multi-cannon clears scout swarms and shoots down caustic missiles; AX weapons cannot be engineered.",
            "MediumHardpoint1": "Guardian Gauss is the heart-damage weapon — fixed, pre-engineered, and brutally power- and heat-hungry.",
            "MediumHardpoint2": "Second fixed Gauss; three on the mediums concentrate the anti-heart burst that ends an Interceptor.",
            "MediumHardpoint3": "Third fixed Gauss — pre-engineered from unlocks, so no blueprint applies.",
            "MediumHardpoint4": "Guardian Shard Cannon shreds the swarm and exerts hearts at close range; pre-engineered, no blueprint.",
            "TinyHardpoint1": "Xeno Scanner reads Interceptor variant and exposes the hearts; scanners carry no blueprint.",
            "TinyHardpoint2": "Optional / low-priority — Ammo Capacity adds caustic-sink charges. Clears caustic damage in Thargoid fights.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "Powers hungry Gauss plus shield and cells; Overcharged adds headroom, Thermal Spread bleeds the extra heat.",
            "MainEngines": "A-rate + Dirty Drives recover what little mobility the heavy hull allows.",
            "FrameShiftDrive": "A-rated with G3 Increased Range to reach AX sites; combat needs no jump monster.",
            "LifeSupport": "D-rate to save mass, Lightweight trims more; life support has no experimental effect.",
            "PowerDistributor": "A-rate this FIRST — Gauss is immensely capacitor-hungry; Charge Enhanced + Super Conduits feed the recharge.",
            "Radar": "Drop to D and go Lightweight; AX combat needs no sensor range, so save the mass.",
            "FuelTank": "Stock C tank; fuel capacity is fixed and cannot be engineered.",
            "Military01": "Guardian Module Reinforcement spreads caustic and penetrating-hit damage across the internals; from unlocks, not blueprints.",
            "Military02": "Second Guardian MRP — the Dropship's whole AX case is refusing to die, so both military slots harden the cores.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire; Thermal Resistant + Hi-Cap give a thermal-hard buffer over the armour tank.",
            "Slot02_Size5": "Guardian HRP adds caustic- and thermal-resistant effective armour; not engineerable.",
            "Slot03_Size5": "Standard HRP takes Heavy Duty + Deep Plating — the cheapest large multiplier on effective armour.",
            "Slot04_Size4": "More Guardian HRP for Thargoid-resistant armour; from unlocks, no blueprint.",
            "Slot05_Size3": "Guardian MRP protects the cores from caustic penetration; not engineerable.",
            "Slot06_Size3": "Decontamination Limpet Controller strips caustic build-up off the hull mid-fight; controllers carry no blueprint.",
            "Slot07_Size2": "Last Guardian HRP tops off the layered armour tank.",
            "Slot08_Size1": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable."
          },
