  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A complete small-ship mining fit for laser and core work. Initial is buy-only; A-rated is the mining baseline; Engineered focuses on mobility, range and a tougher shield — the mining tools themselves are not meaningfully engineered. The shallow internals force hard trade-offs between ore racks and the suite.",
          "callout": {
            "label": "Suite vs. hold — the small-ship trade-off",
            "text": "Nine optionals sound generous, but the refinery, prospector and collector controllers eat most of them — the ore racks that remain total only ~56 t. Drop the bi-weave for a fourth rack if you mine somewhere quiet; keep it where pirates roam. Either way, plan on short trips and frequent dockings."
          },
          "notes": {
            "MediumHardpoint1": "Primary laser-mining tool; a medium fixed laser is the largest the hull mounts, and mining tools carry no weapon blueprint.",
            "MediumHardpoint2": "Core mining's main tool — lob a seismic charge into a fissure to crack the rock; the fixed medium warhead is the only size and is not engineerable.",
            "MediumHardpoint3": "Sub-surface Displacement Missile reaches the deep deposits the blaster can't; medium fixed is the largest, and no blueprint applies.",
            "SmallHardpoint1": "Abrasion Blaster shears surface deposits off a cracked core for the limpets to scoop; mining tools aren't engineerable.",
            "SmallHardpoint2": "A second, small laser adds throughput so a rock is stripped faster; mining lasers carry no blueprint.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks and core fissures; A-rated for the widest reveal, and scanners carry no blueprint.",
            "TinyHardpoint2": "One Heavy-Duty booster roughly doubles the small bi-weave's raw MJ — the cheapest survivability gain on the hull.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more shield MJ for the exposed minutes of cracking a core.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rate it to run the lasers, seismic launcher and limpet swarm together; Low Emissions + Thermal Spread keep heat down through long sessions.",
            "MainEngines": "A-rated thrusters with Dirty Drive Tuning + Drag Drives so the light hull can boost clear of interdictions it can't win.",
            "FrameShiftDrive": "Increased Range + Mass Manager stretch every jump so the short-legged Cobra reaches distant rings and hauls ore home in fewer hops.",
            "LifeSupport": "D-rated and Lightweight — life support is mass to shed on a small frame, and it has no experimental effect.",
            "PowerDistributor": "A-rate the class-4 distributor or the tools and limpets brown out together; Engine Focused at G3 feeds the boost you escape pirates with.",
            "Radar": "Dropped to D and Lightweight — a miner needs no sensor range, so save the mass; sensors have no experimental effect.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot02_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot03_Size4": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments.",
            "Slot04_Size4": "Bi-weave regenerates fast under fire; Reinforced + Fast Charge maximise MJ while keeping the quick recharge — a buffer for cracking a core, not a pirate brawl. Drop it for a fourth rack where it's quiet.",
            "Slot05_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot06_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot07_Size3": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size2": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets.",
            "Slot09_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Power Distributor",
              "size": 4,
              "grade": "G3",
              "blueprint": "Engine Focused",
              "experimental": "—",
              "engineer": "The Dweller"
            },
            {
              "module": "Power Plant",
              "size": 4,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Bi-Weave Shield",
              "size": 4,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Thrusters",
              "size": 4,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Frame Shift Drive",
              "size": 4,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Bulkheads",
              "blueprint": "Lightweight",
              "grade": "G5",
              "engineer": "Selene Jean"
            }
          ]
        }
      }
    },
