      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "exploration",
          "intro": "A roomy budget explorer that keeps its cargo room. Initial is buy-only; A-Rated is the expedition baseline; Engineered maximises jump range while exploiting the Type-6's capacity — explore and haul on the same cheap medium.",
          "callout": {
            "label": "Scoop big, carry cargo",
            "text": "The Type-6's two class-5 optionals take a large A-rated fuel scoop and the class-5 Guardian FSD Booster, with the rest carrying an SRV bay, AFMU, scanner and cargo. Its capacity is the draw — none of the dedicated explorers haul trade goods while they survey."
          },
          "notes": {
            "TinyHardpoint1": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "D-rated to save mass; Low Emissions runs cold so the big class-5 scoop never overheats the hull.",
            "MainEngines": "D-rated for mass; Clean Drive Tuning gives efficient, low-heat travel between jumps.",
            "FrameShiftDrive": "A-rate this FIRST — Increased Range plus Mass Manager is the whole build, pushing the hull to ~48 LY.",
            "LifeSupport": "D-rate and go Lightweight to shed mass; life support has no experimental effect.",
            "PowerDistributor": "D-rated; Engine Focused speeds boost recovery and Stripped Down trims its mass for range.",
            "Radar": "D-rate and go Lightweight; exploration needs no sensor range, so save the mass.",
            "FuelTank": "Stock class-4 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size5": "Optional / low-priority — Shielded hardens the scoop; scoop rate is unchanged. Refuels from stars.",
            "Slot02_Size5": "Guardian FSD Booster adds the largest flat jump bonus available; Guardian modules cannot be engineered.",
            "Slot03_Size4": "Planetary Vehicle Hangar for surface access; the lightweight class keeps mass down and hangars carry no blueprint.",
            "Slot04_Size4": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot05_Size3": "Optional / low-priority — Shielded hardens the AFMU. Repairs modules between fights.",
            "Slot06_Size2": "Minimal bi-weave so a botched landing doesn't end the trip; Enhanced Low Power + Stripped Down keep its mass and draw tiny.",
            "Slot07_Size2": "Optional — Expanded Capacity adds cargo space; worth it for dedicated haulers. Holds cargo.",
            "Slot08_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
