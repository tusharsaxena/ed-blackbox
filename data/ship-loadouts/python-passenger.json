  {
    "header": {
      "appName": "E:D Black Book",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbook",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "passenger",
          "intro": "A defensible passenger fit — a deep cabin suite, a strong shield and a clean FSD, with hardpoints kept light for self-defence. Initial is buy-only; A-rated is the passenger baseline; Engineered keeps the cabins safe and stretches the range. The Python has no military slots, so all reinforcement and cabins share the ten optionals.",
          "callout": {
            "label": "Cabins for the board, a shield for the run",
            "text": "Fit the cabin mix the board demands — economy for bulk sightseeing, first/luxury for VIP fares — and keep a real bi-weave shield and point defence, because the Python's whole case is taking passengers through routes the unarmed liners avoid. With no comfort bonus to lean on, safety and capacity are what set it apart; swap cabins for cargo or guns when the week turns."
          },
          "notes": {
            "LargeHardpoint1": "Gimballed multi-cannon for self-defence; Overcharged with Auto Loader lets it deter an interdictor without reloading mid-scuffle.",
            "LargeHardpoint2": "Second self-defence multi-cannon; the third large mount is left empty to keep the laden hull light.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest large gain in passenger survivability.",
            "TinyHardpoint2": "Second Heavy-Duty booster stacks more shield strength to ride out an interdiction with the manifest aboard.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and Thermal-Vent resets.",
            "PowerPlant": "A-rated to power the shield, cabins and guns; Low Emissions plus Thermal Spread run the laden hull cool and quiet.",
            "MainEngines": "A-rated then Dirty Drive Tuning so the loaded Python can still boost clear of an interdiction.",
            "FrameShiftDrive": "A-rated and Increased Range (G5) with Mass Manager to stretch the modest laden jump; pair with a Guardian booster.",
            "LifeSupport": "Kept A-rated for endurance; Lightweight trims mass — life support has no experimental effect.",
            "PowerDistributor": "A-rated and Engine Focused so the boost capacitor refills fast for repeated escapes; Super Conduits speeds every recharge.",
            "Radar": "Dropped to D and made Lightweight — passenger work needs no sensor range, so save the mass.",
            "FuelTank": "Stock C-rated tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Economy cabin in the largest slot — bulk berths for ordinary tourist boards.",
            "Slot02_Size6": "Bi-weave shield generator, the Python's defining edge; Reinforced maximises MJ and Fast Charge speeds its already-quick regen.",
            "Slot03_Size6": "First-class cabin in the second size-6 slot for high-value VIP fares; swap to luxury for the richest boards.",
            "Slot04_Size5": "Economy cabin adds more bulk berths for mixed manifests.",
            "Slot05_Size5": "First-class cabin for additional VIP seating alongside the economy bulk.",
            "Slot06_Size4": "Economy cabin fills the mid slot; trade up to business if the board pays better.",
            "Slot07_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing for emergencies.",
            "Slot08_Size3": "Economy cabin; swap for cargo or a limpet controller when the week turns.",
            "Slot09_Size2": "Small economy cabin tops up the berth count.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps planets for exploration data."
          },
          "engineeringPlan": [
            {
              "module": "Shield Generator (Bi-Weave)",
              "size": 6,
              "grade": "G5",
              "blueprint": "Reinforced",
              "experimental": "Fast Charge",
              "engineer": "Lei Cheung"
            },
            {
              "module": "Shield Boosters",
              "grade": "G5",
              "blueprint": "Heavy Duty",
              "experimental": "Super Capacitors",
              "engineer": "Didi Vatermann"
            },
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Thrusters",
              "size": 6,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
              "module": "Power Plant",
              "size": 7,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Power Distributor",
              "size": 7,
              "grade": "G5",
              "blueprint": "Engine Focused",
              "experimental": "Super Conduits",
              "engineer": "The Dweller"
            },
            {
              "module": "Multi-Cannons",
              "size": 3,
              "grade": "G5",
              "blueprint": "Overcharged",
              "experimental": "Auto Loader",
              "engineer": "Tod McQuinn"
            },
            {
              "module": "Life Support / Sensors",
              "grade": "G5",
