  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "mining",
          "intro": "A full laser-and-core mining fit that keeps a gun and a real bi-weave for self-defence, using the Corsair's deep medium-pad internals to carry a competitive ore hold. Initial is the cheapest buy-only loop; A-Rated is the role-ready mining baseline; Engineered focuses on range, mobility and shield — the mining tools themselves are not meaningfully engineered, so they stay stock.",
          "callout": {
            "label": "Deep internals, no mining bonus",
            "text": "The Corsair's edge is unusual internal depth for a medium — three size-6 bays behind a full extraction suite — so it out-holds most medium miners while still docking at outposts a capital barge can't reach. What it doesn't bring is any mining hull bonus or exclusive tooling, and the premium hull price buys survivability and breadth, not ore-per-credit. Build for defence and reach; leave the mining hardware stock."
          },
          "notes": {
            "LargeHardpoint1": "Primary mining laser; mining lasers cap at size 2, so it under-fills the large mount and carries no blueprint.",
            "LargeHardpoint2": "Seismic charge launcher for core (motherlode) mining; the medium warhead is the largest the Corsair mounts and it is not engineerable.",
            "LargeHardpoint3": "Sub-surface displacement missile reaches the deep deposits the blaster can't; mining missiles carry no blueprint.",
            "MediumHardpoint1": "Second mining laser to raise laser-mining throughput on a prospected rock; not engineerable.",
            "MediumHardpoint2": "Abrasion blaster shears surface deposits off a cracked core for the collectors to scoop; not engineerable.",
            "MediumHardpoint3": "Lone gimballed multi-cannon for pirate deterrence; Overcharged plus Corrosive Shell make the single gun bite hard enough to see off a chancer.",
            "TinyHardpoint1": "Pulse Wave Analyser lights up mineral-rich rocks and core fissures; scanners carry no blueprint.",
            "TinyHardpoint2": "First of two shield boosters; Heavy Duty multiplies the bi-weave's raw MJ for the exposed minutes of cracking a core.",
            "TinyHardpoint3": "Second Heavy-Duty booster stacks more shield with Super Capacitors.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running.",
            "PowerPlant": "Runs lasers, the seismic launcher, the limpet swarm and a real shield together; Low Emissions plus Thermal Spread hold heat down through long sessions.",
            "MainEngines": "A-rated with Dirty Drive Tuning plus Drag Drives so a laden miner can boost clear of an interdiction it can't out-fight.",
            "FrameShiftDrive": "A-rated with Increased Range plus Mass Manager so the Corsair reaches distant hotspots and hauls a deep ore hold home.",
            "LifeSupport": "D-rated and Lightweight — life support is mass to shed on a miner, and it has no experimental effect.",
            "PowerDistributor": "A-rate the class-7 distributor and Charge Enhanced keeps the boost and laser draw fed together; mining WEP draw is trivial on a class-7 unit.",
            "Radar": "Dropped to D and Lightweight — a miner needs no sensor range, so save the mass; sensors have no experimental effect.",
            "FuelTank": "Stock class-3 tank; fuel capacity is fixed and cannot be engineered.",
            "Slot01_Size6": "Optional — adds cargo space; the size-6 bays are the Corsair's ore-hold advantage over most mediums. Cargo racks aren't engineerable.",
            "Slot02_Size6": "Optional — adds cargo space; worth it for dedicated haul runs. Cargo racks aren't engineerable.",
            "Slot03_Size6": "A size-6 bi-weave regenerates fast under fire; Reinforced maximises MJ and Regeneration speeds the recharge that defines the bi-weave.",
            "Slot04_Size5": "Optional — adds cargo space; worth it for dedicated haul runs. Cargo racks aren't engineerable.",
            "Slot05_Size5": "Optional / low-priority — Lightweight trims the controller's mass. Deploys collector limpets (multi-limpet).",
            "Slot06_Size5": "Optional / low-priority — Shielded hardens the refinery. Processes mined fragments; the size-4 refinery is the largest made.",
            "Slot07_Size4": "Optional — adds cargo space; worth it for dedicated haul runs. Cargo racks aren't engineerable.",
            "Slot08_Size3": "Optional / low-priority — Lightweight trims the controller's mass. Deploys prospector limpets.",
            "Slot09_Size2": "Optional / low-priority — Lightweight trims the controller's mass. A second collector controller keeps limpets in the air.",
            "Slot10_Size1": "Optional / low-priority — Expanded Probe Scanning widens probe coverage. Maps rings and planets for hotspots."
          },
          "engineeringPlan": [
            {
              "module": "Frame Shift Drive",
              "size": 5,
              "grade": "G5",
              "blueprint": "Increased Range",
              "experimental": "Mass Manager",
              "engineer": "Felicity Farseer"
            },
            {
              "module": "Power Plant",
              "size": 7,
              "grade": "G5",
              "blueprint": "Low Emissions",
              "experimental": "Thermal Spread",
              "engineer": "Hera Tani"
            },
            {
              "module": "Thrusters",
              "size": 7,
              "grade": "G5",
              "blueprint": "Dirty Drive Tuning",
              "experimental": "Drag Drives",
              "engineer": "Professor Palin / Mel Brandon"
            },
            {
