  {
    "header": {
      "appName": "E:D Black Box",
      "appVersion": "1.0",
      "appURL": "https://github.com/tusharsaxena/ed-blackbox",
      "appCustomProperties": {
        "state": "engineered",
        "edbb": {
          "role": "trading",
          "intro": "A defensible-hauler fit: the Beluga's vast internals go almost entirely to cargo, kept behind a bi-weave shield, a booster pair and a cell bank, with two medium multi-cannons on its five hardpoints to deter pirates. Initial is buy-only with a shield from day one; A-rated is the trade baseline; Engineered claws back every light-year and MJ a 950 t liner allows.",
          "callout": {
            "label": "Shield it, arm it, then fill it",
            "text": "The Beluga's five medium hardpoints take deterrent guns, but they only discourage a pirate — survival still rests on shields and escape. Keep the size-6 bi-weave, two Heavy-Duty boosters and a cell bank, add a pair of medium multi-cannons, then pack the remaining internals with cargo. It hauls ~298 t behind that shield (~370 t stripped) — respectable, but a Type-9 carries more than double for a fraction of the price."
          },
          "notes": {
            "MediumHardpoint1": "First deterrent multi-cannon; Overcharged with Corrosive Shell strips resistance so even a light gun bites — enough to make a pirate reconsider.",
            "MediumHardpoint2": "Second deterrent multi-cannon; Overcharged with Auto Loader keeps it firing without reloads.",
            "TinyHardpoint1": "First shield booster; Heavy Duty multiplies the bi-weave's raw MJ — the cheapest defence on a lightly-armed hull.",
            "TinyHardpoint2": "Second Heavy-Duty booster rounds out the shield stack.",
            "TinyHardpoint3": "Optional / low-priority — Ammo Capacity adds rounds. Point Defence shoots down incoming missiles and torpedoes.",
            "TinyHardpoint4": "Optional / low-priority — Ammo Capacity adds heat-sink charges. Dumps heat for silent running and a cool high-wake escape.",
            "PowerPlant": "A-rated size-6 plant powers the shield, boosters and cell bank; Low Emissions keeps the signature down on contested routes and Thermal Spread bleeds the heat.",
            "MainEngines": "A-rated + Dirty Drives give the ponderous 950 t hull the boost it needs to break an interdiction — escape is its main defence.",
            "FrameShiftDrive": "A-rated G5 Increased Range with Mass Manager fights the Beluga's worst trait; even so a laden 950 t hull only reaches ~20 LY.",
            "LifeSupport": "The class-8 life support is the biggest mass target — D-rate and go Lightweight; it has no experimental effect.",
            "PowerDistributor": "Engine Focused sustains the boost that escapes interdictions; Super Conduits enlarges the engine capacitor.",
            "Radar": "Drop to D and go Lightweight; trading needs no sensor range, so save the mass for cargo and range.",
            "FuelTank": "Stock C tank sized to the core; fuel capacity cannot be engineered.",
            "Slot01_Size6": "Bi-weave regenerates fast under fire — the right shield for surviving a hit and running; Reinforced maximises its MJ and Hi-Cap adds more.",
            "Slot02_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot03_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot04_Size6": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot05_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot06_Size5": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot07_Size4": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot08_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot09_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot10_Size3": "Optional — adds cargo space; worth it for dedicated haulers. Cargo racks aren't engineerable.",
            "Slot11_Size3": "Optional / low-priority — Specialised cuts the cell bank's heat and power spike. Burst shield healing to survive a sustained interdiction.",
            "Slot12_Size1": "Optional — the smallest rack tops off the hold with two more tonnes. Cargo racks aren't engineerable."
          },
